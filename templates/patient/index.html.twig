<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Mon Espace · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; }
        .navbar {
            background: white; padding: 0 60px;
            display: flex; justify-content: space-between; align-items: center;
            height: 70px; box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: #4A6FA5; }
        .navbar-logo span { color: #E8895A; }
        .navbar-links { display: flex; gap: 32px; align-items: center; }
        .navbar-links a {
            color: #555; text-decoration: none; font-size: 14px; font-weight: 500;
            transition: color 0.2s; position: relative;
        }
        .navbar-links a::after {
            content: ''; position: absolute; bottom: -4px; left: 0;
            width: 0; height: 2px; background: #E8895A; transition: width 0.3s;
        }
        .navbar-links a:hover { color: #4A6FA5; }
        .navbar-links a:hover::after { width: 100%; }
        .navbar-links a.active { color: #4A6FA5; font-weight: 600; }
        .navbar-links a.active::after { width: 100%; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 10px;
            background: #F5EFE6; padding: 8px 16px; border-radius: 30px;
        }
        .user-pill .avatar {
            width: 32px; height: 32px; background: #4A6FA5; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 14px; font-weight: 700;
        }
        .user-pill span { font-size: 13px; color: #2C3E50; font-weight: 600; }
        .btn-logout {
            padding: 8px 18px; background: #E8895A; color: white;
            border-radius: 8px; text-decoration: none; font-size: 13px;
            font-weight: 600; transition: background 0.2s;
        }
        .btn-logout:hover { background: #d4784a; }
        .hero {
            background: linear-gradient(135deg, #4A6FA5 0%, #2C4F7C 100%);
            padding: 70px 60px; color: white; position: relative; overflow: hidden;
        }
        .hero::before {
            content: ''; position: absolute; top: -80px; right: -80px;
            width: 350px; height: 350px; background: rgba(255,255,255,0.05); border-radius: 50%;
        }
        .hero::after {
            content: ''; position: absolute; bottom: -60px; left: 30%;
            width: 250px; height: 250px; background: rgba(232,137,90,0.15); border-radius: 50%;
        }
        .hero-content { position: relative; z-index: 1; max-width: 600px; }
        .hero-badge {
            display: inline-block; background: rgba(232,137,90,0.3); color: #E8C99A;
            padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600;
            margin-bottom: 16px; animation: fadeInDown 0.6s ease;
        }
        .hero h1 {
            font-size: 38px; font-weight: 700; line-height: 1.2; margin-bottom: 14px;
            animation: fadeInUp 0.6s ease 0.1s both;
        }
        .hero h1 span { color: #E8895A; }
        .hero p { font-size: 16px; opacity: 0.8; line-height: 1.6; animation: fadeInUp 0.6s ease 0.2s both; }
        .hero-illustration {
            position: absolute; right: 60px; top: 50%;
            transform: translateY(-50%); font-size: 120px; opacity: 0.15; z-index: 0;
        }
        .stats-bar {
            background: white; margin: -24px 60px 0; border-radius: 16px;
            padding: 24px 32px; display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 16px; box-shadow: 0 8px 30px rgba(0,0,0,0.1);
            position: relative; z-index: 10; animation: fadeInUp 0.6s ease 0.3s both;
        }
        .stat-item { text-align: center; padding: 8px; border-right: 1px solid #F0EAE0; }
        .stat-item:last-child { border-right: none; }
        .stat-item .icon { font-size: 28px; margin-bottom: 6px; }
        .stat-item .number { font-size: 28px; font-weight: 700; color: #4A6FA5; }
        .stat-item .label { font-size: 12px; color: #999; margin-top: 2px; }
        .content { padding: 40px 60px; }
        .section-title {
            font-size: 20px; font-weight: 700; color: #2C3E50; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
        }
        .section-title::after {
            content: ''; flex: 1; height: 2px;
            background: linear-gradient(to right, #E8E0D5, transparent); margin-left: 10px;
        }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
        .grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 40px; }
        .service-card {
            background: white; border-radius: 16px; padding: 28px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
            transition: transform 0.3s, box-shadow 0.3s;
            text-decoration: none; display: block;
            position: relative; overflow: hidden;
        }
        .service-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
            background: linear-gradient(to right, #4A6FA5, #E8895A);
            transform: scaleX(0); transition: transform 0.3s;
        }
        .service-card:hover { transform: translateY(-6px); box-shadow: 0 12px 30px rgba(0,0,0,0.12); }
        .service-card:hover::before { transform: scaleX(1); }
        .service-card .icon { font-size: 36px; margin-bottom: 14px; }
        .service-card h3 { font-size: 15px; font-weight: 700; color: #2C3E50; margin-bottom: 8px; }
        .service-card p { font-size: 13px; color: #999; line-height: 1.5; }
        .service-card .arrow {
            display: inline-block; margin-top: 14px; color: #4A6FA5;
            font-size: 13px; font-weight: 600; transition: transform 0.2s;
        }
        .service-card:hover .arrow { transform: translateX(4px); }
        .profile-panel { background: white; border-radius: 16px; padding: 28px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); }
        .profile-header { text-align: center; padding-bottom: 20px; border-bottom: 1px solid #F0EAE0; margin-bottom: 20px; }
        .profile-avatar {
            width: 70px; height: 70px;
            background: linear-gradient(135deg, #4A6FA5, #E8895A);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 28px; margin: 0 auto 12px;
        }
        .profile-header h3 { font-size: 16px; font-weight: 700; color: #2C3E50; }
        .profile-header p { font-size: 12px; color: #999; margin-top: 4px; }
        .profile-badge {
            display: inline-block; background: #d8fde8; color: #27ae60;
            padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-top: 8px;
        }
        .profile-row {
            display: flex; align-items: center; gap: 10px; padding: 10px 0;
            border-bottom: 1px solid #F5EFE6; font-size: 13px;
        }
        .profile-row:last-child { border-bottom: none; }
        .profile-row .lbl { color: #999; flex: 1; }
        .profile-row .val { color: #2C3E50; font-weight: 600; }
        .btn-edit-profile {
            display: block; text-align: center; margin-top: 16px;
            padding: 10px; background: #4A6FA5; color: white;
            border-radius: 10px; text-decoration: none; font-size: 13px; font-weight: 600;
        }
        .btn-edit-profile:hover { background: #3a5f95; }
        .wellbeing-panel { background: white; border-radius: 16px; padding: 28px; box-shadow: 0 2px 15px rgba(0,0,0,0.06); }
        .wellbeing-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .wellbeing-header h4 { font-size: 15px; font-weight: 700; color: #2C3E50; }
        .wellbeing-item { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid #F5EFE6; }
        .wellbeing-item:last-child { border-bottom: none; }
        .w-icon { font-size: 28px; }
        .w-info { flex: 1; }
        .w-info h4 { font-size: 13px; font-weight: 600; color: #2C3E50; }
        .w-info p { font-size: 11px; color: #999; margin-top: 2px; }
        .w-bar-wrap { width: 100px; }
        .w-bar { height: 6px; border-radius: 3px; background: #F0EAE0; overflow: hidden; }
        .w-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
        .w-pct { font-size: 11px; color: #999; text-align: right; margin-top: 4px; }
        .btn-evaluer {
            display: block; text-align: center; margin-top: 16px;
            padding: 12px; background: #E8895A; color: white;
            border-radius: 10px; text-decoration: none; font-size: 13px; font-weight: 600;
            transition: background 0.2s;
        }
        .btn-evaluer:hover { background: #d4784a; }
        .next-session {
            background: linear-gradient(135deg, #4A6FA5, #6B8FC5);
            border-radius: 16px; padding: 28px; color: white; text-align: center;
            box-shadow: 0 2px 15px rgba(74,111,165,0.3);
        }
        .next-session .big-icon { font-size: 50px; margin-bottom: 14px; }
        .next-session h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
        .next-session p { font-size: 13px; opacity: 0.8; line-height: 1.5; }
        .next-session .btn-session {
            display: inline-block; margin-top: 16px; padding: 10px 24px;
            background: rgba(255,255,255,0.2); border-radius: 8px; color: white;
            text-decoration: none; font-size: 13px; font-weight: 600;
        }
        .next-session .btn-session:hover { background: rgba(255,255,255,0.3); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        .animate { animation: fadeInUp 0.6s ease both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span></div>
    <div class="navbar-links">
        <a href="{{ path('patient_dashboard') }}" class="active">Accueil</a>
        <a href="#">Mes séances</a>
        <a href="#">Messages</a>
        <a href="{{ path('patient_rapports') }}">Rapports</a>
        <a href="{{ path('patient_bien_etre') }}">Bien-être</a>
        <a href="{{ path('patient_profile') }}">Mon profil</a>
    </div>
    <div class="navbar-right">
        <div class="user-pill">
            <div class="avatar">{{ app.user.prenom|slice(0,1)|upper }}</div>
            <span>{{ app.user.prenom }}</span>
        </div>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪 Déconnexion</a>
    </div>
</nav>

<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">🌿 Espace Patient</div>
        <h1>Bonjour, <span>{{ app.user.prenom }}</span> !<br>Comment allez-vous ?</h1>
        <p>Bienvenue sur votre espace personnel. Suivez votre parcours bien-être et restez connecté avec votre coach.</p>
    </div>
    <div class="hero-illustration">🧠</div>
</section>

<div class="stats-bar">
    <div class="stat-item">
        <div class="icon">📅</div>
        <div class="number">0</div>
        <div class="label">Séances effectuées</div>
    </div>
    <div class="stat-item">
        <div class="icon">💬</div>
        <div class="number">0</div>
        <div class="label">Messages</div>
    </div>
    <div class="stat-item">
        <div class="icon">📋</div>
        <div class="number">0</div>
        <div class="label">Rapports</div>
    </div>
    <div class="stat-item">
        <div class="icon">⭐</div>
        <div class="number">{% if last is defined and last %}{{ ((last.sommeil + last.humeur + (100 - last.stress)) / 3)|round }}%{% else %}—{% endif %}</div>
        <div class="label">Score bien-être</div>
    </div>
</div>

<div class="content">

    <div class="section-title animate">🎯 Mes services</div>
    <div class="grid-3">
        <a href="#" class="service-card animate delay-1">
            <div class="icon">🧘</div>
            <h3>Séances de thérapie</h3>
            <p>Planifiez et suivez vos séances avec votre coach personnel.</p>
            <span class="arrow">Voir mes séances →</span>
        </a>
        <a href="{{ path('patient_rapports') }}" class="service-card animate delay-2">
            <div class="icon">📊</div>
            <h3>Suivi de progression</h3>
            <p>Visualisez votre évolution et vos progrès au fil du temps.</p>
            <span class="arrow">Voir mes rapports →</span>
        </a>
        <a href="{{ path('patient_bien_etre') }}" class="service-card animate delay-3">
            <div class="icon">🌿</div>
            <h3>Mon bien-être</h3>
            <p>Évaluez votre état quotidien et suivez votre progression.</p>
            <span class="arrow">Évaluer mon état →</span>
        </a>
    </div>

    <div class="section-title animate">💚 Mon bien-être & profil</div>
    <div class="grid-2">
        <div>
            <div class="wellbeing-panel animate delay-1" style="margin-bottom:20px;">
                <div class="wellbeing-header">
                    <h4>🌿 Dernière évaluation</h4>
                    {% if last %}
                        <span style="font-size:11px;color:#999;">{{ last.createdAt|date('d/m/Y') }}</span>
                    {% endif %}
                </div>
                <div class="wellbeing-item">
                    <span class="w-icon">😴</span>
                    <div class="w-info"><h4>Sommeil</h4><p>Qualité du sommeil</p></div>
                    <div class="w-bar-wrap">
                        <div class="w-bar">
                            <div class="w-fill" id="sleep"
                                 style="width:{% if last %}{{ last.sommeil }}{% else %}0{% endif %}%;background:#4A6FA5;">
                            </div>
                        </div>
                        <div class="w-pct">{% if last %}{{ last.sommeil }}%{% else %}—{% endif %}</div>
                    </div>
                </div>
                <div class="wellbeing-item">
                    <span class="w-icon">🧘</span>
                    <div class="w-info"><h4>Stress</h4><p>Niveau de stress</p></div>
                    <div class="w-bar-wrap">
                        <div class="w-bar">
                            <div class="w-fill" id="stress"
                                 style="width:{% if last %}{{ last.stress }}{% else %}0{% endif %}%;background:#E8895A;">
                            </div>
                        </div>
                        <div class="w-pct">{% if last %}{{ last.stress }}%{% else %}—{% endif %}</div>
                    </div>
                </div>
                <div class="wellbeing-item">
                    <span class="w-icon">😊</span>
                    <div class="w-info"><h4>Humeur</h4><p>Humeur générale</p></div>
                    <div class="w-bar-wrap">
                        <div class="w-bar">
                            <div class="w-fill" id="mood"
                                 style="width:{% if last %}{{ last.humeur }}{% else %}0{% endif %}%;background:#27ae60;">
                            </div>
                        </div>
                        <div class="w-pct">{% if last %}{{ last.humeur }}%{% else %}—{% endif %}</div>
                    </div>
                </div>
                <a href="{{ path('patient_bien_etre') }}" class="btn-evaluer">✏️ Évaluer mon état aujourd'hui</a>
            </div>

            <div class="next-session animate delay-2">
                <div class="big-icon">🗓️</div>
                <h3>Prochaine séance</h3>
                <p>Aucune séance planifiée pour le moment.<br>Contactez votre coach pour en programmer une.</p>
                <a href="#" class="btn-session">📅 Planifier une séance</a>
            </div>
        </div>

        <div class="profile-panel animate delay-1">
            <div class="profile-header">
                <div class="profile-avatar">🌿</div>
                <h3>{{ app.user.prenom }} {{ app.user.nom }}</h3>
                <p>{{ app.user.email }}</p>
                <span class="profile-badge">✅ Compte vérifié</span>
            </div>
            <div class="profile-row">
                <span class="lbl">👤 Prénom</span>
                <span class="val">{{ app.user.prenom }}</span>
            </div>
            <div class="profile-row">
                <span class="lbl">👤 Nom</span>
                <span class="val">{{ app.user.nom }}</span>
            </div>
            <div class="profile-row">
                <span class="lbl">📧 Email</span>
                <span class="val">{{ app.user.email }}</span>
            </div>
            <div class="profile-row">
                <span class="lbl">📞 Téléphone</span>
                <span class="val">{{ app.user.numTel ?? '—' }}</span>
            </div>
            <div class="profile-row">
                <span class="lbl">🌿 Rôle</span>
                <span class="val">Patient</span>
            </div>
            <a href="{{ path('patient_profile') }}" class="btn-edit-profile">✏️ Modifier mon profil</a>
        </div>
    </div>

</div>

</body>
</html>