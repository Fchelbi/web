<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Verification · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif; background: #0D1B2A;
            display: flex; justify-content: center; align-items: center; min-height: 100vh;
        }
        .container {
            display: flex; width: 860px; min-height: 520px;
            border-radius: 24px; overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.5);
        }
        .left-panel {
            background: linear-gradient(160deg, #162232 0%, #0D1B2A 100%);
            width: 45%; padding: 50px 40px;
            display: flex; flex-direction: column;
            justify-content: space-between; color: white;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .logo-area { text-align: center; }
        .logo-icon {
            width: 80px; height: 80px;
            background: rgba(232,137,90,0.15);
            border: 2px solid rgba(232,137,90,0.3);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 36px; margin: 0 auto 16px;
        }
        .logo-area h1 { font-size: 28px; font-weight: 700; color: white; }
        .logo-area h1 span { color: #E8895A; }
        .logo-area p { font-size: 13px; color: #8899AA; margin-top: 6px; }
        .features { display: flex; flex-direction: column; gap: 16px; }
        .feature-item { border-left: 3px solid #E8895A; padding-left: 14px; }
        .feature-item h3 { font-size: 14px; font-weight: 600; color: white; }
        .feature-item p { font-size: 12px; color: #8899AA; margin-top: 2px; }
        .version { text-align: center; font-size: 11px; color: #4A5568; }

        .right-panel {
            background: #162232; width: 55%; padding: 50px 45px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .dots { display: flex; gap: 6px; margin-bottom: 30px; }
        .dot { width: 28px; height: 4px; border-radius: 2px; }
        .dot:nth-child(1) { background: #E8895A; }
        .dot:nth-child(2) { background: rgba(232,137,90,0.4); }
        .dot:nth-child(3) { background: rgba(232,137,90,0.2); }

        .shield { font-size: 48px; margin-bottom: 16px; text-align: center; }
        h2 { font-size: 26px; font-weight: 700; color: white; margin-bottom: 8px; text-align: center; }
        .subtitle { font-size: 13px; color: #8899AA; margin-bottom: 30px; text-align: center; line-height: 1.6; }

        .code-inputs {
            display: flex; gap: 10px; justify-content: center; margin-bottom: 24px;
        }
        .code-input {
            width: 52px; height: 60px; text-align: center;
            font-size: 24px; font-weight: 700; color: white;
            background: rgba(255,255,255,0.05);
            border: 2px solid rgba(255,255,255,0.08);
            border-radius: 12px; outline: none; transition: all 0.2s;
        }
        .code-input:focus { border-color: #E8895A; background: rgba(232,137,90,0.05); }
        .code-input.filled { border-color: rgba(39,174,96,0.5); background: rgba(39,174,96,0.05); }

        .error-msg {
            background: rgba(231,76,60,0.1); color: #e74c3c;
            border: 1px solid rgba(231,76,60,0.2);
            padding: 12px 16px; border-radius: 10px;
            font-size: 13px; margin-bottom: 16px; text-align: center;
        }

        .remember-row {
            display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
            padding: 12px 16px; background: rgba(255,255,255,0.03);
            border-radius: 10px; border: 1px solid rgba(255,255,255,0.05);
        }
        .remember-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: #E8895A; }
        .remember-row label { font-size: 13px; color: #8899AA; cursor: pointer; }

        .btn-verify {
            width: 100%; padding: 15px; background: #E8895A; color: white;
            border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
            cursor: pointer; transition: all 0.2s; margin-bottom: 12px;
        }
        .btn-verify:hover { background: #d4784a; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(232,137,90,0.3); }

        .timer { text-align: center; font-size: 13px; color: #8899AA; margin-bottom: 12px; }
        .timer span { color: #E8895A; font-weight: 700; }

        .btn-resend {
            width: 100%; padding: 13px; background: transparent;
            color: #8899AA; border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px; font-size: 14px; font-weight: 600;
            cursor: pointer; transition: all 0.2s; text-decoration: none; display: block; text-align: center;
        }
        .btn-resend:hover { background: rgba(255,255,255,0.05); color: white; }
    </style>
</head>
<body>
<div class="container">
    <div class="left-panel">
        <div class="logo-area">
            <div class="logo-icon">🧠</div>
            <h1>Echo<span>Care</span></h1>
            <p>Psychologie · Bien-etre</p>
        </div>
        <div class="features">
            <div class="feature-item">
                <h3>🔐 Double securite</h3>
                <p>Verification en 2 etapes</p>
            </div>
            <div class="feature-item">
                <h3>📧 Code par email</h3>
                <p>Valable 10 minutes</p>
            </div>
            <div class="feature-item">
                <h3>🛡️ Protection maximale</h3>
                <p>Vos donnees securisees</p>
            </div>
        </div>
        <div class="version">EchoCare v2.0</div>
    </div>

    <div class="right-panel">
        <div class="dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>

        <div class="shield">🔐</div>
        <h2>Verification requise</h2>
        <p class="subtitle">Entrez le code a 6 chiffres envoye a votre adresse email</p>

        {% if error is defined and error %}
            <div class="error-msg">❌ {{ error }}</div>
        {% endif %}

        <form method="post" id="twoFaForm">
            <div class="code-inputs">
                <input type="text" class="code-input" id="c1" maxlength="1" inputmode="numeric">
                <input type="text" class="code-input" id="c2" maxlength="1" inputmode="numeric">
                <input type="text" class="code-input" id="c3" maxlength="1" inputmode="numeric">
                <input type="text" class="code-input" id="c4" maxlength="1" inputmode="numeric">
                <input type="text" class="code-input" id="c5" maxlength="1" inputmode="numeric">
                <input type="text" class="code-input" id="c6" maxlength="1" inputmode="numeric">
            </div>
            <input type="hidden" name="code" id="hiddenCode">

            <div class="remember-row">
               <input type="checkbox" name="save_device" id="save_device">
                <label for="save_device">Se souvenir de cet appareil (10 jours)</label>
            </div>

            <button type="submit" class="btn-verify" onclick="submitCode()">✅ Verifier le code</button>
        </form>

        <div class="timer">Code expire dans <span id="countdown">10:00</span></div>
        <a href="{{ path('app_login') }}" class="btn-resend">← Retour a la connexion</a>
    </div>
</div>

<script>
// Auto-focus et navigation entre les cases
const inputs = document.querySelectorAll('.code-input');
inputs.forEach((input, idx) => {
    input.addEventListener('input', function() {
        this.value = this.value.replace(/[^0-9]/g, '');
        if (this.value) {
            this.classList.add('filled');
            if (idx < inputs.length - 1) inputs[idx + 1].focus();
        } else {
            this.classList.remove('filled');
        }
    });
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value && idx > 0) {
            inputs[idx - 1].focus();
            inputs[idx - 1].classList.remove('filled');
        }
    });
    input.addEventListener('paste', function(e) {
        const paste = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
        paste.split('').forEach((char, i) => {
            if (inputs[idx + i]) {
                inputs[idx + i].value = char;
                inputs[idx + i].classList.add('filled');
            }
        });
        e.preventDefault();
    });
});
inputs[0].focus();

function submitCode() {
    let code = '';
    inputs.forEach(i => code += i.value);
    document.getElementById('hiddenCode').value = code;
}

// Countdown 10 minutes
let timeLeft = 600;
const countdown = document.getElementById('countdown');
const timer = setInterval(() => {
    timeLeft--;
    const m = Math.floor(timeLeft / 60);
    const s = timeLeft % 60;
    countdown.textContent = m + ':' + (s < 10 ? '0' : '') + s;
    if (timeLeft <= 0) {
        clearInterval(timer);
        countdown.textContent = 'Expire !';
        countdown.style.color = '#e74c3c';
    }
}, 1000);
</script>
</body>
</html>
