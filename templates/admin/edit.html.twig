<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier Utilisateur · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; min-height: 100vh; }
        .navbar {
            background: #4A6FA5; padding: 16px 40px;
            display: flex; justify-content: space-between; align-items: center; color: white;
        }
        .navbar h1 { font-size: 20px; font-weight: 700; }
        .navbar h1 span { color: #E8895A; }
        .navbar a {
            color: white; text-decoration: none;
            background: rgba(255,255,255,0.15);
            padding: 8px 16px; border-radius: 8px; font-size: 13px;
        }
        .navbar a:hover { background: rgba(255,255,255,0.25); }
        .content { padding: 40px; display: flex; justify-content: center; }
        .card {
            background: white; border-radius: 16px;
            padding: 40px; width: 100%; max-width: 600px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }
        .card h2 { font-size: 22px; color: #2C3E50; margin-bottom: 6px; }
        .card p { font-size: 13px; color: #999; margin-bottom: 28px; }
        .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .field-group { display: flex; flex-direction: column; margin-bottom: 18px; }
        .field-label {
            font-size: 11px; font-weight: 700; color: #4A6FA5;
            letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px;
        }
        input, select {
            padding: 12px 16px; border: 1.5px solid #E8E0D5;
            border-radius: 10px; background: #F5EFE6;
            font-size: 14px; color: #333; outline: none;
            transition: border-color 0.2s; width: 100%;
        }
        input:focus, select:focus { border-color: #4A6FA5; background: white; }
        input.error { border-color: #e74c3c; }
        .error-msg { font-size: 11px; color: #e74c3c; margin-top: 4px; display: none; }
        .password-wrapper { position: relative; }
        .password-wrapper input { padding-right: 44px; }
        .toggle-pw {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%); cursor: pointer; font-size: 16px;
        }
        .hint { font-size: 11px; color: #aaa; margin-top: 4px; }
        .btn-submit {
            width: 100%; padding: 14px; background: #4A6FA5;
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; cursor: pointer; margin-top: 8px;
        }
        .btn-submit:hover { background: #3a5f95; }
        .btn-cancel {
            width: 100%; padding: 13px; background: transparent;
            color: #E8895A; border: 1.5px solid #E8895A;
            border-radius: 10px; font-size: 14px; font-weight: 600;
            text-decoration: none; display: block; text-align: center;
            margin-top: 10px; transition: all 0.2s;
        }
        .btn-cancel:hover { background: #E8895A; color: white; }
    </style>
</head>
<body>

<nav class="navbar">
    <h1>Echo<span>Care</span> · Admin</h1>
    <a href="{{ path('admin_dashboard') }}">← Retour</a>
</nav>

<div class="content">
    <div class="card">
        <h2>✏️ Modifier l'utilisateur</h2>
        <p>Modifiez les informations de <strong>{{ user.nom }} {{ user.prenom }}</strong></p>

        <form method="post" id="editForm" novalidate>
            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Nom</label>
                    <input type="text" name="nom" id="nom"
                           value="{{ user.nom }}" required>
                    <span class="error-msg" id="nom-error">Min 2 caractères</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Prénom</label>
                    <input type="text" name="prenom" id="prenom"
                           value="{{ user.prenom }}" required>
                    <span class="error-msg" id="prenom-error">Min 2 caractères</span>
                </div>
            </div>

            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <input type="email" name="email" id="email"
                           value="{{ user.email }}" required>
                    <span class="error-msg" id="email-error">Email invalide</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Téléphone</label>
                    <input type="text" name="num_tel" id="num_tel"
                           value="{{ user.numTel }}">
                    <span class="error-msg" id="tel-error">8 chiffres requis</span>
                </div>
            </div>

            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Nouveau mot de passe</label>
                    <div class="password-wrapper">
                        <input type="password" name="password" id="password" placeholder="••••••••">
                        <span class="toggle-pw" onclick="togglePw('password', this)">👁️</span>
                    </div>
                    <span class="hint">Laisser vide pour ne pas changer</span>
                    <span class="error-msg" id="pw-error">Min 8 car. majuscule, chiffre, symbole</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Confirmer mot de passe</label>
                    <div class="password-wrapper">
                        <input type="password" name="confirm_password" id="confirm_password" placeholder="••••••••">
                        <span class="toggle-pw" onclick="togglePw('confirm_password', this)">👁️</span>
                    </div>
                    <span class="error-msg" id="confirm-error">Mots de passe différents</span>
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">Rôle</label>
                <select name="role" id="role" required>
                    <option value="Patient" {{ user.role == 'Patient' ? 'selected' : '' }}>🌿 Patient</option>
                    <option value="Coach"   {{ user.role == 'Coach'   ? 'selected' : '' }}>🏋️ Coach</option>
                    <option value="Admin"   {{ user.role == 'Admin'   ? 'selected' : '' }}>👑 Admin</option>
                </select>
                <span class="error-msg" id="role-error">Veuillez choisir un rôle</span>
            </div>

            <button type="submit" class="btn-submit">💾 Enregistrer</button>
        </form>
        <a href="{{ path('admin_dashboard') }}" class="btn-cancel">Annuler</a>
    </div>
</div>

<script>
    function togglePw(id, el) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        el.textContent = input.type === 'password' ? '👁️' : '🙈';
    }

    document.getElementById('editForm').addEventListener('submit', function (e) {
        let valid = true;
        const show = (id) => { document.getElementById(id).style.display = 'block'; };
        const hide = (id) => { document.getElementById(id).style.display = 'none'; };

        const nom = document.getElementById('nom');
        const prenom = document.getElementById('prenom');
        const email = document.getElementById('email');
        const tel = document.getElementById('num_tel');
        const pw = document.getElementById('password');
        const cpw = document.getElementById('confirm_password');
        const role = document.getElementById('role');

        if (nom.value.trim().length < 2) { nom.classList.add('error'); show('nom-error'); valid = false; }
        else { nom.classList.remove('error'); hide('nom-error'); }

        if (prenom.value.trim().length < 2) { prenom.classList.add('error'); show('prenom-error'); valid = false; }
        else { prenom.classList.remove('error'); hide('prenom-error'); }

        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) { email.classList.add('error'); show('email-error'); valid = false; }
        else { email.classList.remove('error'); hide('email-error'); }

        if (tel.value && !/^\d{8}$/.test(tel.value.replace(/\s/g, ''))) { tel.classList.add('error'); show('tel-error'); valid = false; }
        else { tel.classList.remove('error'); hide('tel-error'); }

        // Mot de passe optionnel mais si rempli doit être fort
        if (pw.value) {
            if (!/^(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/.test(pw.value)) {
                pw.classList.add('error'); show('pw-error'); valid = false;
            } else { pw.classList.remove('error'); hide('pw-error'); }

            if (pw.value !== cpw.value) { cpw.classList.add('error'); show('confirm-error'); valid = false; }
            else { cpw.classList.remove('error'); hide('confirm-error'); }
        } else {
            pw.classList.remove('error'); hide('pw-error');
            cpw.classList.remove('error'); hide('confirm-error');
        }

        if (!role.value) { role.classList.add('error'); show('role-error'); valid = false; }
        else { role.classList.remove('error'); hide('role-error'); }

        if (!valid) e.preventDefault();
    });
</script>
</body>
</html>