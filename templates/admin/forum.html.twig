{% extends 'layout.html.twig' %}

{% block title %}Forum Admin{% endblock %}

{% block topbar %}
    <div class="top-bar" style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; margin-bottom: 16px;">
        <h1 class="page-title" style="margin-bottom: 2px; font-size: 1.25rem;">Forum Admin</h1>
        <p style="color:var(--text-muted);font-size:0.85rem; margin-top: 2px;">Manage forum posts, moderate content with Gemini AI, and control user access.</p>
    </div>
{% endblock %}

{% block content %}
<div class="forum-admin-container">

    {# ─── OVERVIEW STATS ─── #}
    <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));">
        <div class="stat-card glassmorphism" style="animation-delay:0.05s;">
            <div class="stat-icon">
                <i data-lucide="file-text"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Total Posts</p>
                <p class="stat-value">{{ stats.total_posts }}</p>
            </div>
        </div>

        <div class="stat-card glassmorphism" style="animation-delay:0.1s;">
            <div class="stat-icon" style="background:rgba(126,200,227,0.1);border-color:rgba(126,200,227,0.2);">
                <i data-lucide="users" style="color:var(--accent);"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Active Users</p>
                <p class="stat-value" style="color:var(--accent);">{{ stats.active_users }}</p>
            </div>
        </div>

        <div class="stat-card glassmorphism" style="animation-delay:0.15s;">
            <div class="stat-icon" style="background:rgba(245,158,11,0.1);border-color:rgba(245,158,11,0.2);">
                <i data-lucide="alert-triangle" style="color:var(--warning);"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Flagged Posts</p>
                <p class="stat-value" style="color:var(--warning);">{{ stats.flagged_posts }}</p>
            </div>
        </div>

        <div class="stat-card glassmorphism" style="animation-delay:0.2s;">
            <div class="stat-icon" style="background:var(--danger-bg);border-color:var(--danger-border);">
                <i data-lucide="user-x" style="color:var(--danger);"></i>
            </div>
            <div class="stat-info">
                <p class="stat-label">Banned Users</p>
                <p class="stat-value" style="color:var(--danger);">{{ stats.banned_users }}</p>
            </div>
        </div>
    </div>

    {# ─── ANALYTICS CHARTS ─── #}
    <div class="analytics-grid">
        <div class="chart-card glassmorphism">
            <h3 class="chart-title">
                <i data-lucide="trending-up" style="width:18px;height:18px;color:var(--primary-color);"></i>
                Posts Activity (30 days)
            </h3>
            <div class="chart-wrap">
                <canvas id="postsPerDayChart"></canvas>
            </div>
        </div>
        <div class="chart-card glassmorphism">
            <h3 class="chart-title">
                <i data-lucide="pie-chart" style="width:18px;height:18px;color:var(--accent);"></i>
                Posts by Category
            </h3>
            <div class="chart-wrap">
                <canvas id="postsByCategoryChart"></canvas>
            </div>
        </div>
    </div>

    {# ─── AI MODERATION PANEL ─── #}
    <div class="ai-scan-panel glassmorphism" style="animation:slideUp 0.5s ease forwards;animation-delay:0.3s;opacity:0;">
        <div class="ai-scan-header">
            <div class="ai-scan-info">
                <div class="ai-scan-icon">
                    <span class="gemini-sparkle">✦</span>
                </div>
                <div>
                    <h3 style="margin:0;color:var(--text-main);font-size:1.1rem;font-weight:700;">Gemini AI Moderation</h3>
                    <p style="margin:0.2rem 0 0 0;color:var(--text-muted);font-size:0.85rem;">
                        Scan all forum posts for inappropriate, abusive, harmful, or unsafe content using Google Gemini AI.
                    </p>
                </div>
            </div>
            <form method="post" action="{{ path('app_admin_forum_moderate_all') }}" style="margin:0;">
                <button type="submit" class="scan-btn" onclick="this.classList.add('btn-loading');this.closest('form').submit();">
                    <i data-lucide="scan" style="width:18px;height:18px;"></i>
                    Scan All Posts
                </button>
            </form>
        </div>
    </div>

    {# ─── NEEDS REVIEW — FLAGGED POSTS ─── #}
    {% if flaggedPosts|length > 0 %}
    <div style="margin-top:1.5rem;animation:slideUp 0.5s ease forwards;animation-delay:0.35s;opacity:0;">
        <h2 style="color:var(--text-main);margin:0 0 1.5rem 0;font-size:1.2rem;font-weight:700;display:flex;align-items:center;gap:0.6rem;">
            <i data-lucide="shield-alert" style="width:20px;height:20px;color:var(--warning);"></i>
            Needs Review
            <span style="background:rgba(245,158,11,0.15);color:var(--warning);padding:0.2rem 0.7rem;border-radius:12px;font-size:0.8rem;font-weight:700;border:1px solid rgba(245,158,11,0.3);">
                {{ flaggedPosts|length }}
            </span>
        </h2>

        <div class="needs-review-list">
            {% for post in flaggedPosts %}
            <div class="needs-review-card glassmorphism" style="animation-delay:{{ loop.index * 0.05 }}s;">
                <div class="needs-review-content">
                    <div class="needs-review-header">
                        <h4 style="margin:0;color:var(--text-main);font-size:1rem;font-weight:600;">{{ post.title }}</h4>
                        <span class="status-badge status-badge-{{ post.moderationStatus }}">
                            {{ post.moderationStatus|capitalize }}
                        </span>
                    </div>
                    <p style="margin:0.4rem 0;color:var(--text-subtle);font-size:0.85rem;">
                        by <strong style="color:var(--text-muted);">{{ post.user.prenom }} {{ post.user.nom }}</strong>
                        {% if post.user.isBanned() %}
                            <span class="ban-badge">Banned</span>
                        {% endif %}
                        · {{ post.createdAt|date('M j, Y H:i') }}
                    </p>
                    {% if post.flagReason %}
                    <div class="flag-reason">
                        <i data-lucide="alert-circle" style="width:14px;height:14px;flex-shrink:0;color:var(--warning);"></i>
                        <span>{{ post.flagReason }}</span>
                    </div>
                    {% endif %}
                    <p style="margin:0.5rem 0 0 0;color:var(--text-muted);font-size:0.9rem;">
                        {{ post.content|length > 150 ? post.content|slice(0,150) ~ '...' : post.content }}
                    </p>
                </div>
                <div class="needs-review-actions">
                    <form method="post" action="{{ path('app_admin_forum_approve', {'id': post.id}) }}" style="display:inline;">
                        <button type="submit" class="btn btn-icon btn-action" data-tooltip="Approve" style="color:#22c55e;">
                            <i data-lucide="check-circle" style="width:16px;height:16px;"></i>
                        </button>
                    </form>
                    <form method="post" action="{{ path('app_admin_forum_reject', {'id': post.id}) }}" style="display:inline;">
                        <button type="submit" class="btn btn-icon btn-action" data-tooltip="Reject/Hide" style="color:var(--warning);">
                            <i data-lucide="eye-off" style="width:16px;height:16px;"></i>
                        </button>
                    </form>
                    <form method="post" action="{{ path('app_admin_forum_delete_post', {'id': post.id}) }}" style="display:inline;" onsubmit="return confirm('Permanently delete this post?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('forum_delete' ~ post.id) }}">
                        <button type="submit" class="btn btn-icon btn-danger" data-tooltip="Delete">
                            <i data-lucide="trash-2" style="width:16px;height:16px;"></i>
                        </button>
                    </form>
                    {% if not post.user.isBanned() %}
                    <form method="post" action="{{ path('app_admin_forum_toggle_ban', {'id': post.user.id}) }}" style="display:inline;" onsubmit="return confirm('Ban user {{ post.user.prenom }} {{ post.user.nom }}?');">
                        <button type="submit" class="btn btn-icon btn-danger" data-tooltip="Ban User">
                            <i data-lucide="user-x" style="width:16px;height:16px;"></i>
                        </button>
                    </form>
                    {% else %}
                    <form method="post" action="{{ path('app_admin_forum_toggle_ban', {'id': post.user.id}) }}" style="display:inline;">
                        <button type="submit" class="btn btn-icon btn-action" data-tooltip="Unban User" style="color:#22c55e;">
                            <i data-lucide="user-check" style="width:16px;height:16px;"></i>
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ─── ALL POSTS TABLE ─── #}
    <div style="margin-top:1.5rem;animation:slideUp 0.5s ease forwards;animation-delay:0.4s;opacity:0;">
        <h2 style="color:var(--text-main);margin:0 0 1.5rem 0;font-size:1.2rem;font-weight:700;display:flex;align-items:center;gap:0.6rem;">
            <i data-lucide="layout-list" style="width:20px;height:20px;color:var(--primary-color);"></i>
            Posts Management
        </h2>

        <div class="glassmorphism" style="padding:1.5rem;overflow-x:auto;">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th style="text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in allPosts %}
                    <tr>
                        <td style="color:var(--text-subtle);font-weight:600;">#{{ post.id }}</td>
                        <td>
                            <a href="{{ path('app_post_show', {'id': post.id}) }}" style="color:var(--text-main);text-decoration:none;font-weight:600;">
                                {{ post.title|length > 40 ? post.title|slice(0,40) ~ '...' : post.title }}
                            </a>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <span style="color:var(--text-main);font-weight:500;">{{ post.user.prenom }} {{ post.user.nom }}</span>
                                {% if post.user.isBanned() %}
                                    <span class="ban-badge">Banned</span>
                                {% endif %}
                            </div>
                        </td>
                        <td>
                            <span class="category-badge">{{ post.category.name }}</span>
                        </td>
                        <td>
                            {% if post.isFlagged() %}
                                <span class="status-badge status-badge-flagged">
                                    <i data-lucide="alert-triangle" style="width:12px;height:12px;"></i>
                                    Flagged
                                </span>
                            {% elseif post.moderationStatus == 'rejected' %}
                                <span class="status-badge status-badge-rejected">Rejected</span>
                            {% elseif post.moderationStatus == 'pending' %}
                                <span class="status-badge status-badge-pending">Pending</span>
                            {% else %}
                                <span class="status-badge status-badge-approved">Approved</span>
                            {% endif %}
                        </td>
                        <td style="color:var(--text-subtle);font-size:0.85rem;">{{ post.createdAt|date('M j, Y') }}</td>
                        <td style="text-align:center;">
                            <div style="display:flex;gap:0.4rem;justify-content:center;">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-icon btn-icon-sm btn-action" data-tooltip="View">
                                    <i data-lucide="eye" style="width:14px;height:14px;"></i>
                                </a>
                                <form method="post" action="{{ path('app_admin_forum_moderate_single', {'id': post.id}) }}" style="display:inline;">
                                    <button type="submit" class="btn btn-icon btn-icon-sm btn-action" data-tooltip="AI Scan" style="color:var(--accent);">
                                        <i data-lucide="sparkles" style="width:14px;height:14px;"></i>
                                    </button>
                                </form>
                                <form method="post" action="{{ path('app_admin_forum_toggle_flag', {'id': post.id}) }}" style="display:inline;">
                                    <button type="submit" class="btn btn-icon btn-icon-sm btn-action" data-tooltip="{{ post.isFlagged() ? 'Unflag' : 'Flag' }}" style="color:{{ post.isFlagged() ? 'var(--warning)' : 'var(--text-subtle)' }};">
                                        <i data-lucide="flag" style="width:14px;height:14px;"></i>
                                    </button>
                                </form>
                                <form method="post" action="{{ path('app_admin_forum_delete_post', {'id': post.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this post?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('forum_delete' ~ post.id) }}">
                                    <button type="submit" class="btn btn-icon btn-icon-sm btn-danger" data-tooltip="Delete">
                                        <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" style="text-align:center;padding:2.5rem;color:var(--text-subtle);">
                            No posts found
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ─── COMMENTS MANAGEMENT — NEW SECTION ─── #}
    <div style="margin-top:1.5rem;animation:slideUp 0.5s ease forwards;animation-delay:0.45s;opacity:0;">
        <h2 style="color:var(--text-main);margin:0 0 1.5rem 0;font-size:1.2rem;font-weight:700;display:flex;align-items:center;gap:0.6rem;">
            <i data-lucide="message-square" style="width:20px;height:20px;color:var(--accent);"></i>
            Comments Management
        </h2>

        <div class="glassmorphism" style="padding:1.5rem;overflow-x:auto;">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Comment Content</th>
                        <th>Author</th>
                        <th>Reference Post</th>
                        <th>Date</th>
                        <th style="text-align:center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for comment in allComments %}
                    <tr>
                        <td style="color:var(--text-subtle);font-weight:600;">#{{ comment.id }}</td>
                        <td>
                            <p style="margin:0;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-main);">
                                {{ comment.content }}
                            </p>
                        </td>
                        <td>{{ comment.user.prenom }} {{ comment.user.nom }}</td>
                        <td>
                            <a href="{{ path('app_post_show', {'id': comment.post.id}) }}" style="color:var(--primary-color);text-decoration:none;font-size:0.85rem;">
                                {{ comment.post.title|length > 30 ? comment.post.title|slice(0,30) ~ '...' : comment.post.title }}
                            </a>
                        </td>
                        <td style="color:var(--text-subtle);font-size:0.85rem;">{{ comment.createdAt|date('M j, Y') }}</td>
                        <td style="text-align:center;">
                            <form method="post" action="{{ path('app_admin_forum_delete_comment', {'id': comment.id}) }}" style="display:inline;" onsubmit="return confirm('Permanently delete this comment?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('forum_delete_comment' ~ comment.id) }}">
                                <button type="submit" class="btn btn-icon btn-icon-sm btn-danger" data-tooltip="Delete">
                                    <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;padding:2.5rem;color:var(--text-subtle);">
                            No comments found
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# ─── CHART.JS ─── #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const commonFont = { family: "'Inter', sans-serif" };
    const gridColor = 'rgba(255,255,255,0.06)';
    const textColor = '#94a3b8';

    // ── Posts Per Day Line Chart ──
    const daysData = {{ postsPerDay|json_encode|raw }};
    const dayLabels = Object.keys(daysData).map(d => {
        const dt = new Date(d);
        return dt.toLocaleDateString('en', { month: 'short', day: 'numeric' });
    });
    const dayValues = Object.values(daysData);

    new Chart(document.getElementById('postsPerDayChart'), {
        type: 'line',
        data: {
            labels: dayLabels,
            datasets: [{
                label: 'Posts',
                data: dayValues,
                borderColor: '#e8895a',
                backgroundColor: 'rgba(232, 137, 90,0.1)',
                borderWidth: 2.5,
                fill: true,
                tension: 0.4,
                pointRadius: 3,
                pointBackgroundColor: '#e8895a',
                pointBorderColor: '#fff',
                pointBorderWidth: 1.5,
                pointHoverRadius: 6,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(15,22,35,0.95)',
                    titleFont: commonFont,
                    bodyFont: commonFont,
                    borderColor: 'rgba(232, 137, 90,0.3)',
                    borderWidth: 1,
                    padding: 10,
                    cornerRadius: 8,
                }
            },
            scales: {
                x: {
                    grid: { color: gridColor },
                    ticks: { color: textColor, font: { size: 11, ...commonFont }, maxRotation: 45 }
                },
                y: {
                    beginAtZero: true,
                    grid: { color: gridColor },
                    ticks: { color: textColor, font: { size: 11, ...commonFont }, stepSize: 1 }
                }
            }
        }
    });

    // ── Posts By Category Doughnut ──
    const catData = {{ postsByCategory|json_encode|raw }};
    const catLabels = Object.keys(catData);
    const catValues = Object.values(catData);
    const catColors = [
        '#e8895a', '#7ec8e3', '#f59e0b', '#22c55e', '#a78bfa',
        '#fb923c', '#f472b6', '#38bdf8', '#34d399', '#c084fc'
    ];

    new Chart(document.getElementById('postsByCategoryChart'), {
        type: 'doughnut',
        data: {
            labels: catLabels,
            datasets: [{
                data: catValues,
                backgroundColor: catColors.slice(0, catLabels.length),
                borderColor: 'rgba(15,22,35,0.8)',
                borderWidth: 2,
                hoverOffset: 8,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: textColor,
                        font: { size: 12, ...commonFont },
                        padding: 15,
                        usePointStyle: true,
                        pointStyleWidth: 10,
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(15,22,35,0.95)',
                    titleFont: commonFont,
                    bodyFont: commonFont,
                    borderColor: 'rgba(232, 137, 90,0.3)',
                    borderWidth: 1,
                    padding: 10,
                    cornerRadius: 8,
                }
            }
        }
    });
});
</script>
{% endblock %}
