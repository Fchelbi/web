{% extends 'layout.html.twig' %}

{% block title %}Dashboard Admin · EchoCare{% endblock %}

{% block topbar %}
    <div class="top-bar" style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 20px; margin-bottom: 24px;">
        <h2>👥 Gestion des Utilisateurs</h2>
        <div style="display:flex;gap:10px;align-items:center;">
            <a href="{{ path('admin_dashboard') }}" class="btn-refresh" title="Actualiser">🔄</a>
            <a href="{{ path('admin_user_new') }}" class="btn-add">+ Ajouter</a>
            <a href="{{ path('admin_export_pdf') }}" class="btn-green">📄 PDF</a>
        </div>
    </div>
{% endblock %}

{% block content %}
    <style>
        .navbar h1 span { color: #E8895A; }
        .navbar-right { display: flex; gap: 10px; align-items: center; }
        .navbar a {
            color: #8899AA; text-decoration: none;
            background: rgba(255,255,255,0.05);
            padding: 8px 16px; border-radius: 8px; font-size: 13px;
            transition: all 0.2s; border: 1px solid rgba(255,255,255,0.05);
        }
        .navbar a:hover { background: rgba(232,137,90,0.15); color: #E8895A; border-color: rgba(232,137,90,0.3); }

        .content { padding: 0; }

        .top-bar {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
        }
        .top-bar h2 { font-size: 22px; color: white; font-weight: 700; }

        .btn-add {
            background: #E8895A; color: white; padding: 10px 20px;
            border-radius: 10px; text-decoration: none; font-size: 14px;
            font-weight: 600; transition: all 0.2s;
        }
        .btn-add:hover { background: #d4784a; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(232,137,90,0.3); }

        .btn-green {
            background: rgba(39,174,96,0.15); color: #27ae60; padding: 10px 20px;
            border-radius: 10px; text-decoration: none; font-size: 14px;
            font-weight: 600; border: 1px solid rgba(39,174,96,0.3); transition: all 0.2s;
        }
        .btn-green:hover { background: rgba(39,174,96,0.25); }

        .btn-refresh {
            background: rgba(255,255,255,0.05); color: #8899AA; padding: 10px 14px;
            border-radius: 10px; text-decoration: none; font-size: 18px;
            border: 1px solid rgba(255,255,255,0.05); transition: all 0.2s;
        }
        .btn-refresh:hover { background: rgba(232,137,90,0.15); color: #E8895A; }

        .filters {
            background: #162232; padding: 16px 20px; border-radius: 12px;
            display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .filters input, .filters select {
            padding: 10px 14px; border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; background: rgba(255,255,255,0.05);
            font-size: 14px; outline: none; flex: 1; min-width: 160px;
            color: white; transition: border-color 0.2s;
        }
        .filters input::placeholder { color: #4A5568; }
        .filters select option { background: #162232; }
        .filters input:focus, .filters select:focus { border-color: #E8895A; }
        .filters button {
            padding: 10px 20px; background: #E8895A; color: white;
            border: none; border-radius: 8px; cursor: pointer;
            font-size: 14px; font-weight: 600; transition: all 0.2s;
        }
        .filters button:hover { background: #d4784a; }

        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1.25rem; }
        .stat-card {
            background: var(--card-bg); padding: 0.9rem 1rem; border-radius: var(--radius-md);
            border: 1px solid var(--border-color); text-align: center;
            transition: transform 0.2s; position: relative; overflow: hidden;
        }
        .stat-card:hover { transform: translateY(-2px); border-color: var(--border-hover); }
        .stat-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; }
        .stat-card.total::before { background: #E8895A; }
        .stat-card.admins::before { background: #9b59b6; }
        .stat-card.coachs::before { background: #3498db; }
        .stat-card.patients::before { background: #27ae60; }
        .stat-card .number { font-size: 1.6rem; font-weight: 700; line-height: 1; }
        .stat-card.total .number { color: #E8895A; }
        .stat-card.admins .number { color: #9b59b6; }
        .stat-card.coachs .number { color: #3498db; }
        .stat-card.patients .number { color: #27ae60; }
        .stat-card .label { font-size: 0.72rem; color: #8899AA; margin-top: 0.25rem; }

        table {
            width: 100%; background: #162232; border-radius: 14px;
            overflow: hidden; border-collapse: collapse;
            border: 1px solid rgba(255,255,255,0.05);
        }
        thead { background: rgba(232,137,90,0.1); }
        thead th {
            padding: 14px 16px; text-align: left; font-size: 13px;
            font-weight: 600; color: #E8895A; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        tbody tr { border-bottom: 1px solid rgba(255,255,255,0.03); transition: background 0.15s; }
        tbody tr:hover { background: rgba(255,255,255,0.03); }
        tbody td { padding: 14px 16px; font-size: 14px; color: #CBD5E0; }
        .td-name { color: white; font-weight: 600; }

        .badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .badge-admin { background: rgba(155,89,182,0.2); color: #9b59b6; border: 1px solid rgba(155,89,182,0.3); }
        .badge-coach { background: rgba(52,152,219,0.2); color: #3498db; border: 1px solid rgba(52,152,219,0.3); }
        .badge-patient { background: rgba(39,174,96,0.2); color: #27ae60; border: 1px solid rgba(39,174,96,0.3); }

        .actions { display: flex; gap: 8px; }
        .btn-edit {
            padding: 6px 14px; background: rgba(74,111,165,0.2); color: #6B9FD4;
            border-radius: 8px; text-decoration: none; font-size: 13px;
            border: 1px solid rgba(74,111,165,0.3); transition: all 0.2s;
        }
        .btn-edit:hover { background: rgba(74,111,165,0.4); color: white; }
        .btn-delete {
            padding: 6px 14px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border: 1px solid rgba(231,76,60,0.3); border-radius: 8px;
            font-size: 13px; cursor: pointer; transition: all 0.2s;
        }
        .btn-delete:hover { background: rgba(231,76,60,0.3); color: white; }
        .empty { text-align: center; padding: 40px; color: #4A5568; font-size: 15px; }

        .pagination-wrap { margin-top: 24px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
        .pagination { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; justify-content: center; }
        .pagination a, .pagination span {
            display: inline-flex; align-items: center; justify-content: center;
            min-width: 38px; height: 38px; padding: 0 12px; border-radius: 8px;
            font-size: 14px; font-weight: 600; text-decoration: none; transition: all 0.2s;
        }
        .pagination a { background: #162232; color: #8899AA; border: 1px solid rgba(255,255,255,0.05); }
        .pagination a:hover { background: rgba(232,137,90,0.15); color: #E8895A; border-color: rgba(232,137,90,0.3); }
        .pagination .current { background: #E8895A; color: white; border: 1px solid #E8895A; }
        .pagination .disabled { background: rgba(255,255,255,0.02); color: #4A5568; border: 1px solid rgba(255,255,255,0.03); cursor: default; }
        .pagination .dots { background: none; border: none; color: #4A5568; }
        .pagination-info { font-size: 13px; color: #4A5568; }
        .pagination-info strong { color: #E8895A; }

        /* Modal Face ID */
        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7); z-index: 9999;
            display: flex; align-items: center; justify-content: center;
            animation: fadeIn 0.3s ease; backdrop-filter: blur(4px);
        }
        .modal-box {
            background: #162232; border-radius: 20px; padding: 40px;
            max-width: 440px; width: 100%; text-align: center;
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 30px 80px rgba(0,0,0,0.5);
            animation: slideUp 0.3s ease;
        }
        .modal-box h2 { color: white; font-size: 22px; margin-bottom: 10px; }
        .modal-box p { color: #8899AA; font-size: 14px; margin-bottom: 28px; line-height: 1.6; }
        .modal-btns { display: flex; gap: 12px; justify-content: center; }
        .modal-yes {
            padding: 12px 28px; background: #E8895A; color: white;
            border-radius: 10px; text-decoration: none; font-weight: 600; font-size: 14px;
            transition: all 0.2s;
        }
        .modal-yes:hover { background: #d4784a; }
        .modal-no {
            padding: 12px 28px; background: rgba(255,255,255,0.05); color: #8899AA;
            border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
            font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s;
        }
        .modal-no:hover { background: rgba(255,255,255,0.1); color: white; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('searchInput')?.addEventListener('input', filterTable);
    document.getElementById('roleFilter')?.addEventListener('change', filterTable);
});
function filterTable() {
    const search = document.getElementById('searchInput')?.value.toLowerCase() || '';
    const role = document.getElementById('roleFilter')?.value.toLowerCase() || '';
    const rows = document.querySelectorAll('tbody tr.data-row');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const roleCell = row.querySelector('td:nth-child(5)')?.textContent.toLowerCase() || '';
        row.style.display = text.includes(search) && (!role || roleCell.includes(role)) ? '' : 'none';
    });
}
function closeFaceModal() {
    document.getElementById('faceIdModal').style.display = 'none';
    fetch('/clear-face-prompt');
}
</script>

{% if app.session.get('show_face_id_prompt') %}
<div class="modal-overlay" id="faceIdModal">
    <div class="modal-box">
        <div style="font-size:60px;margin-bottom:16px;">👁️</div>
        <h2>Configurer votre Face ID</h2>
        <p>Vous n'avez pas encore enregistre votre visage.<br>Voulez-vous le faire maintenant ?</p>
        <div class="modal-btns">
            <a href="{{ path('face_register') }}" class="modal-yes">✅ Oui, configurer</a>
            <button onclick="closeFaceModal()" class="modal-no">⏭️ Plus tard</button>
        </div>
    </div>
</div>
{% endif %}

<div class="content">

    <div class="stats">
        <div class="stat-card total">
            <div class="number">{{ total }}</div>
            <div class="label">Total</div>
        </div>
        <div class="stat-card admins">
            <div class="number">{{ totalAdmins }}</div>
            <div class="label">Admins</div>
        </div>
        <div class="stat-card coachs">
            <div class="number">{{ totalCoachs }}</div>
            <div class="label">Coachs</div>
        </div>
        <div class="stat-card patients">
            <div class="number">{{ totalPatients }}</div>
            <div class="label">Patients</div>
        </div>
    </div>

    <form method="get" class="filters">
        <input type="text" id="searchInput" name="search"
               placeholder="🔍 Rechercher par nom, prenom ou email..."
               value="{{ search }}">
        <select id="roleFilter" name="role">
            <option value="">Tous les roles</option>
            <option value="Admin" {{ role == 'Admin' ? 'selected' : '' }}>👑 Admin</option>
            <option value="Coach" {{ role == 'Coach' ? 'selected' : '' }}>🏋️ Coach</option>
            <option value="Patient" {{ role == 'Patient' ? 'selected' : '' }}>🌿 Patient</option>
        </select>
        <button type="submit">Filtrer</button>
    </form>

    <div style="overflow-x: auto; border-radius: 14px;">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Nom Prenom</th>
                <th>Email</th>
                <th>Telephone</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if users is empty %}
                <tr><td colspan="6" class="empty">Aucun utilisateur trouve</td></tr>
            {% else %}
                {% for user in users %}
                <tr class="data-row">
                    <td style="color:#4A5568;">{{ user.id }}</td>
                    <td class="td-name">{{ user.nom }} {{ user.prenom }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.numTel ?? '—' }}</td>
                    <td>
                        {% if user.role %}
                        <span class="badge badge-{{ user.role|lower }}">
                            {% if user.role == 'Admin' %}👑{% elseif user.role == 'Coach' %}🏋️{% else %}🌿{% endif %}
                            {{ user.role }}
                        </span>
                        {% else %}
                        <span class="badge" style="background:rgba(255,255,255,0.05);color:#4A5568;border:1px solid rgba(255,255,255,0.08);">❓ N/A</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="actions">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn-edit">✏️ Modifier</a>
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}"
                                  onsubmit="return confirm('Supprimer cet utilisateur ?')" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button type="submit" class="btn-delete">🗑️</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            {% endif %}
        </tbody>
    </table>
    </div>

    {% if totalPages > 1 %}
    <div class="pagination-wrap">
        <div class="pagination">
            {% if page > 1 %}
                <a href="?page={{ page - 1 }}&search={{ search|url_encode }}&role={{ role|url_encode }}">← Prec.</a>
            {% else %}
                <span class="disabled">← Prec.</span>
            {% endif %}

            {% set pStart = max(1, page - 2) %}
            {% set pEnd = min(totalPages, page + 2) %}

            {% if pStart > 1 %}
                <a href="?page=1&search={{ search|url_encode }}&role={{ role|url_encode }}">1</a>
                {% if pStart > 2 %}<span class="dots">…</span>{% endif %}
            {% endif %}

            {% for p in pStart..pEnd %}
                {% if p == page %}
                    <span class="current">{{ p }}</span>
                {% else %}
                    <a href="?page={{ p }}&search={{ search|url_encode }}&role={{ role|url_encode }}">{{ p }}</a>
                {% endif %}
            {% endfor %}

            {% if pEnd < totalPages %}
                {% if pEnd < totalPages - 1 %}<span class="dots">…</span>{% endif %}
                <a href="?page={{ totalPages }}&search={{ search|url_encode }}&role={{ role|url_encode }}">{{ totalPages }}</a>
            {% endif %}

            {% if page < totalPages %}
                <a href="?page={{ page + 1 }}&search={{ search|url_encode }}&role={{ role|url_encode }}">Suiv. →</a>
            {% else %}
                <span class="disabled">Suiv. →</span>
            {% endif %}
        </div>
        <div class="pagination-info">
            <strong>{{ total }}</strong> utilisateur(s) — Page <strong>{{ page }}</strong> / <strong>{{ totalPages }}</strong>
        </div>
    </div>
    {% endif %}
</div>

{% endblock %}