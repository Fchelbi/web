<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Analytics · EchoCare Admin</title>
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; min-height: 100vh; }
        .navbar {
            background: #4A6FA5; padding: 16px 40px;
            display: flex; justify-content: space-between; align-items: center; color: white;
        }
        .navbar h1 { font-size: 20px; font-weight: 700; }
        .navbar h1 span { color: #E8895A; }
        .navbar-right { display: flex; gap: 10px; }
        .navbar a {
            color: white; text-decoration: none;
            background: rgba(255,255,255,0.15);
            padding: 8px 16px; border-radius: 8px; font-size: 13px;
        }
        .navbar a:hover { background: rgba(255,255,255,0.25); }
        .content { padding: 30px 40px; }
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 24px; font-weight: 700; color: #2C3E50; }
        .page-header p { font-size: 14px; color: #999; margin-top: 4px; }

        /* KPI Cards */
        .kpi-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 16px; margin-bottom: 24px;
        }
        .kpi-card {
            background: white; border-radius: 16px; padding: 24px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
            position: relative; overflow: hidden;
            transition: transform 0.2s;
        }
        .kpi-card:hover { transform: translateY(-4px); }
        .kpi-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        }
        .kpi-card.blue::before { background: #4A6FA5; }
        .kpi-card.orange::before { background: #E8895A; }
        .kpi-card.green::before { background: #27ae60; }
        .kpi-card.purple::before { background: #9b59b6; }
        .kpi-icon { font-size: 32px; margin-bottom: 10px; }
        .kpi-value { font-size: 36px; font-weight: 700; color: #2C3E50; }
        .kpi-label { font-size: 13px; color: #999; margin-top: 4px; }
        .kpi-trend { font-size: 12px; margin-top: 8px; }
        .kpi-trend.up { color: #27ae60; }
        .kpi-trend.down { color: #e74c3c; }

        /* Charts Grid */
        .charts-grid {
            display: grid; grid-template-columns: 2fr 1fr;
            gap: 20px; margin-bottom: 24px;
        }
        .chart-card {
            background: white; border-radius: 16px; padding: 24px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
        }
        .chart-card h3 { font-size: 16px; font-weight: 700; color: #2C3E50; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

        /* Bien-être Cards */
        .bienetre-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px; }
        .bienetre-card {
            background: white; border-radius: 16px; padding: 24px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06); text-align: center;
        }
        .bienetre-card .icon { font-size: 36px; margin-bottom: 12px; }
        .bienetre-card .value { font-size: 32px; font-weight: 700; }
        .bienetre-card .label { font-size: 13px; color: #999; margin-top: 4px; }
        .progress-ring { margin: 10px auto; }

        /* Recent Users */
        .recent-card {
            background: white; border-radius: 16px; padding: 24px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
        }
        .recent-card h3 { font-size: 16px; font-weight: 700; color: #2C3E50; margin-bottom: 16px; }
        .user-item {
            display: flex; align-items: center; gap: 14px;
            padding: 12px 0; border-bottom: 1px solid #F5EFE6;
        }
        .user-item:last-child { border-bottom: none; }
        .user-avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background: linear-gradient(135deg, #4A6FA5, #E8895A);
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 700; font-size: 14px;
        }
        .user-info h4 { font-size: 14px; font-weight: 600; color: #2C3E50; }
        .user-info p { font-size: 12px; color: #999; margin-top: 2px; }
        .badge {
            margin-left: auto; padding: 4px 12px;
            border-radius: 20px; font-size: 11px; font-weight: 600;
        }
        .badge-admin { background: #fde8d8; color: #E8895A; }
        .badge-coach { background: #d8eafd; color: #4A6FA5; }
        .badge-patient { background: #d8fde8; color: #27ae60; }

        .grid-2-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
    </style>
</head>
<body>

<nav class="navbar">
    <h1>Echo<span>Care</span> · Analytics</h1>
    <div class="navbar-right">
        <a href="{{ path('admin_dashboard') }}">← Dashboard</a>
        <a href="{{ path('app_logout') }}">🚪 Déconnexion</a>
    </div>
</nav>

<div class="content">
    <div class="page-header">
        <h2>📊 Dashboard Analytics</h2>
        <p>Vue d'ensemble des statistiques EchoCare</p>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card blue">
            <div class="kpi-icon">👥</div>
            <div class="kpi-value">{{ total }}</div>
            <div class="kpi-label">Utilisateurs total</div>
            <div class="kpi-trend up">↑ Actifs</div>
        </div>
        <div class="kpi-card orange">
            <div class="kpi-icon">👑</div>
            <div class="kpi-value">{{ totalAdmins }}</div>
            <div class="kpi-label">Administrateurs</div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon">🏋️</div>
            <div class="kpi-value">{{ totalCoachs }}</div>
            <div class="kpi-label">Coachs</div>
        </div>
        <div class="kpi-card purple">
            <div class="kpi-icon">🌿</div>
            <div class="kpi-value">{{ totalPatients }}</div>
            <div class="kpi-label">Patients</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-grid">
        <div class="chart-card">
            <h3>📈 Répartition des utilisateurs</h3>
            <canvas id="barChart" height="120"></canvas>
        </div>
        <div class="chart-card">
            <h3>🥧 Par rôle</h3>
            <canvas id="pieChart" height="200"></canvas>
        </div>
    </div>

    <!-- Bien-être moyen -->
    <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:16px;">🌿 Bien-être moyen des patients</h3>
    <div class="bienetre-grid">
        <div class="bienetre-card">
            <div class="icon">😴</div>
            <div class="value" style="color:#4A6FA5;">
                {{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round : '—' }}%
            </div>
            <div class="label">Qualité du sommeil</div>
        </div>
        <div class="bienetre-card">
            <div class="icon">🧘</div>
            <div class="value" style="color:#E8895A;">
                {{ avgBienEtre.avgStress ? avgBienEtre.avgStress|round : '—' }}%
            </div>
            <div class="label">Niveau de stress</div>
        </div>
        <div class="bienetre-card">
            <div class="icon">😊</div>
            <div class="value" style="color:#27ae60;">
                {{ avgBienEtre.avgHumeur ? avgBienEtre.avgHumeur|round : '—' }}%
            </div>
            <div class="label">Humeur générale</div>
        </div>
    </div>

    <!-- Recent + Chart -->
    <div class="grid-2-1">
        <div class="chart-card">
            <h3>📊 Score bien-être</h3>
            <canvas id="radarChart" height="120"></canvas>
        </div>

        <div class="recent-card">
            <h3>🕐 Derniers inscrits</h3>
            {% for user in lastUsers %}
            <div class="user-item">
                <div class="user-avatar">{{ user.prenom|slice(0,1)|upper }}</div>
                <div class="user-info">
                    <h4>{{ user.prenom }} {{ user.nom }}</h4>
                    <p>{{ user.email }}</p>
                </div>
                <span class="badge badge-{{ user.role|lower }}">{{ user.role }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
google.charts.load('current', {'packages':['corechart', 'bar']});
google.charts.setOnLoadCallback(drawCharts);

function drawCharts() {
    // Bar Chart
    var barData = google.visualization.arrayToDataTable([
        ['Rôle', 'Nombre', { role: 'style' }],
        ['Admins', {{ totalAdmins }}, '#E8895A'],
        ['Coachs', {{ totalCoachs }}, '#4A6FA5'],
        ['Patients', {{ totalPatients }}, '#27ae60'],
    ]);
    var barOptions = {
        title: 'Répartition des utilisateurs',
        titleTextStyle: { color: '#2C3E50', fontSize: 14, bold: true },
        legend: { position: 'none' },
        bar: { groupWidth: '50%' },
        backgroundColor: 'transparent',
        chartArea: { width: '80%', height: '70%' },
        vAxis: { gridlines: { color: '#F0EAE0' }, minValue: 0 },
        hAxis: { textStyle: { color: '#555' } },
        animation: { startup: true, duration: 1000, easing: 'out' },
    };
    new google.visualization.ColumnChart(document.getElementById('barChart')).draw(barData, barOptions);

    // Pie Chart
    var pieData = google.visualization.arrayToDataTable([
        ['Rôle', 'Nombre'],
        ['Admins', {{ totalAdmins }}],
        ['Coachs', {{ totalCoachs }}],
        ['Patients', {{ totalPatients }}],
    ]);
    var pieOptions = {
        title: 'Répartition par rôle',
        titleTextStyle: { color: '#2C3E50', fontSize: 14, bold: true },
        colors: ['#E8895A', '#4A6FA5', '#27ae60'],
        backgroundColor: 'transparent',
        chartArea: { width: '90%', height: '80%' },
        pieHole: 0.4,
        legend: { position: 'bottom' },
        animation: { startup: true, duration: 1000, easing: 'out' },
    };
    new google.visualization.PieChart(document.getElementById('pieChart')).draw(pieData, pieOptions);

    // Radar → on utilise un Bar Chart horizontal
    var radarData = google.visualization.arrayToDataTable([
        ['Indicateur', 'Valeur', { role: 'style' }, { role: 'annotation' }],
        ['Sommeil', {{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round : 0 }}, '#4A6FA5', '{{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round : 0 }}%'],
        ['Humeur',  {{ avgBienEtre.avgHumeur  ? avgBienEtre.avgHumeur|round  : 0 }}, '#27ae60', '{{ avgBienEtre.avgHumeur  ? avgBienEtre.avgHumeur|round  : 0 }}%'],
        ['Anti-Stress', {{ avgBienEtre.avgStress ? (100 - avgBienEtre.avgStress)|round : 0 }}, '#E8895A', '{{ avgBienEtre.avgStress ? (100 - avgBienEtre.avgStress)|round : 0 }}%'],
    ]);
    var radarOptions = {
        title: 'Score bien-être moyen',
        titleTextStyle: { color: '#2C3E50', fontSize: 14, bold: true },
        legend: { position: 'none' },
        backgroundColor: 'transparent',
        chartArea: { width: '75%', height: '70%' },
        hAxis: { minValue: 0, maxValue: 100, gridlines: { color: '#F0EAE0' } },
        animation: { startup: true, duration: 1000, easing: 'out' },
    };
    new google.visualization.BarChart(document.getElementById('radarChart')).draw(radarData, radarOptions);
}
</script>
</body>
</html>