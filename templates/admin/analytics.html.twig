{% extends 'layout.html.twig' %}

{% block title %}Analytics · EchoCare Admin{% endblock %}

{% block javascripts %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
{% endblock %}

{% block topbar %}
    <div class="top-bar" style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 12px; margin-bottom: 16px;">
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%;">
            <h2 style="font-size: 1.25rem; margin: 0;">📊 Dashboard Analytics</h2>
            <p style="color: #8899AA; margin: 4px 0 0 0; font-size: 0.8rem;">Vue d'ensemble des statistiques EchoCare</p>
        </div>
    </div>
{% endblock %}

{% block content %}
    <style>
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }
        .kpi-card {
            background: var(--card-bg); border-radius: var(--radius-md); padding: 0.75rem 1rem;
            border: 1px solid var(--border-color); backdrop-filter: blur(8px);
            transition: transform 0.25s, box-shadow 0.25s; position: relative; overflow: hidden;
        }
        .kpi-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--border-hover); }
        .kpi-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; }
        .kpi-card.blue::after { background: #4A6FA5; }
        .kpi-card.orange::after { background: #E8895A; }
        .kpi-card.green::after { background: #27ae60; }
        .kpi-card.purple::after { background: #9b59b6; }
        .kpi-icon { font-size: 1.2rem; margin-bottom: 0.3rem; }
        .kpi-value { font-size: 1.4rem; font-weight: 700; line-height: 1; }
        .kpi-card.blue .kpi-value { color: #4A6FA5; }
        .kpi-card.orange .kpi-value { color: #E8895A; }
        .kpi-card.green .kpi-value { color: #27ae60; }
        .kpi-card.purple .kpi-value { color: #9b59b6; }
        .kpi-label { font-size: 0.7rem; color: #8899AA; margin-top: 0.25rem; }
        .kpi-trend { font-size: 0.65rem; margin-top: 0.3rem; color: #27ae60; }

        .charts-grid { display: grid; grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); gap: 0.75rem; margin-bottom: 1rem; }
        @media (max-width: 900px) {
            .charts-grid { grid-template-columns: minmax(0, 1fr); }
        }
        .chart-card {
            background: var(--card-bg); border-radius: var(--radius-md); padding: 1rem;
            border: 1px solid var(--border-color); backdrop-filter: blur(8px);
            display: flex; flex-direction: column; min-width: 0;
        }
        .chart-card:hover { border-color: var(--border-hover); }
        .chart-card h3 { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem; }

        .bienetre-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1rem; }
        @media (max-width: 768px) {
            .bienetre-grid { grid-template-columns: 1fr; }
        }
        .bienetre-card {
            background: var(--card-bg); border-radius: var(--radius-md); padding: 0.75rem;
            border: 1px solid var(--border-color); text-align: center;
        }
        .bienetre-card .icon { font-size: 1.2rem; margin-bottom: 0.3rem; }
        .bienetre-card .value { font-size: 1.4rem; font-weight: 700; line-height: 1; }
        .bienetre-card .label { font-size: 0.7rem; color: #8899AA; margin-top: 0.2rem; }

        .grid-2-1 { display: grid; grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); gap: 0.75rem; }
        @media (max-width: 900px) {
            .grid-2-1 { grid-template-columns: minmax(0, 1fr); }
        }
        .recent-card {
            background: var(--card-bg); border-radius: var(--radius-md); padding: 1rem;
            border: 1px solid var(--border-color);
        }
        .recent-card h3 { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.8rem; }
        .user-item {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .user-item:last-child { border-bottom: none; }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 700; font-size: 11px;
        }
        .user-info h4 { font-size: 0.8rem; font-weight: 600; color: var(--text-main); margin: 0; }
        .user-info p { font-size: 0.7rem; color: #8899AA; margin: 0.1rem 0 0; }
        .analytics-badge { margin-left: auto; padding: 2px 8px; border-radius: 20px; font-size: 0.7rem; font-weight: 600; }
        .analytics-badge-admin { background: rgba(155,89,182,0.2); color: #9b59b6; }
        .analytics-badge-coach { background: rgba(52,152,219,0.2); color: #3498db; }
        .analytics-badge-patient { background: rgba(39,174,96,0.2); color: #27ae60; }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
        .animate { animation: fadeInUp 0.35s ease both; }
        .delay-1 { animation-delay: 0.05s; }
        .delay-2 { animation-delay: 0.1s; }
        .delay-3 { animation-delay: 0.15s; }
    </style>

<div>

    <div class="kpi-grid">
        <div class="kpi-card blue animate delay-1">
            <div class="kpi-icon">👥</div>
            <div class="kpi-value">{{ total }}</div>
            <div class="kpi-label">Utilisateurs total</div>
            <div class="kpi-trend">↑ Actifs</div>
        </div>
        <div class="kpi-card orange animate delay-2">
            <div class="kpi-icon">👑</div>
            <div class="kpi-value">{{ totalAdmins }}</div>
            <div class="kpi-label">Administrateurs</div>
        </div>
        <div class="kpi-card green animate delay-3">
            <div class="kpi-icon">🏋️</div>
            <div class="kpi-value">{{ totalCoachs }}</div>
            <div class="kpi-label">Coachs</div>
        </div>
        <div class="kpi-card purple animate delay-3">
            <div class="kpi-icon">🌿</div>
            <div class="kpi-value">{{ totalPatients }}</div>
            <div class="kpi-label">Patients</div>
        </div>
    </div>

    <div class="charts-grid">
        <div class="chart-card animate">
            <h3>📈 Repartition des utilisateurs</h3>
            <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="barChart"></canvas>
            </div>
        </div>
        <div class="chart-card animate delay-1">
            <h3>🥧 Par role</h3>
            <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>

    <h3 style="font-size:16px;font-weight:700;color:white;margin-bottom:12px;">🌿 Bien-etre moyen des patients</h3>
    <div class="bienetre-grid">
        <div class="bienetre-card animate delay-1">
            <div class="icon">😴</div>
            <div class="value" style="color:#4A6FA5;">{{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round : '—' }}%</div>
            <div class="label">Qualite du sommeil</div>
        </div>
        <div class="bienetre-card animate delay-2">
            <div class="icon">🧘</div>
            <div class="value" style="color:#E8895A;">{{ avgBienEtre.avgStress ? avgBienEtre.avgStress|round : '—' }}%</div>
            <div class="label">Niveau de stress</div>
        </div>
        <div class="bienetre-card animate delay-3">
            <div class="icon">😊</div>
            <div class="value" style="color:#27ae60;">{{ avgBienEtre.avgHumeur ? avgBienEtre.avgHumeur|round : '—' }}%</div>
            <div class="label">Humeur generale</div>
        </div>
    </div>

    <div class="grid-2-1">
        <div class="chart-card animate">
            <h3>📊 Score bien-etre</h3>
            <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="radarChart"></canvas>
            </div>
        </div>
        <div class="recent-card animate delay-1">
            <h3>🕐 Derniers inscrits</h3>
            {% for user in lastUsers %}
            <div class="user-item">
                <div class="user-avatar">{{ user.prenom|slice(0,1)|upper }}</div>
                <div class="user-info">
                    <h4>{{ user.prenom }} {{ user.nom }}</h4>
                    <p>{{ user.email }}</p>
                </div>
                <span class="analytics-badge analytics-badge-{{ user.role|lower }}">{{ user.role }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
Chart.defaults.color = '#8899AA';
Chart.defaults.borderColor = 'rgba(255,255,255,0.05)';

new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
        labels: ['Admins', 'Coachs', 'Patients'],
        datasets: [{
            label: 'Utilisateurs',
            data: [{{ totalAdmins }}, {{ totalCoachs }}, {{ totalPatients }}],
            backgroundColor: ['rgba(232,137,90,0.7)', 'rgba(74,111,165,0.7)', 'rgba(39,174,96,0.7)'],
            borderColor: ['#E8895A', '#4A6FA5', '#27ae60'],
            borderWidth: 1, borderRadius: 8,
            maxBarThickness: 60
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#8899AA' } },
            x: { grid: { display: false }, ticks: { color: '#8899AA' } }
        },
        animation: { duration: 1500 }
    }
});

new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
        labels: ['Admins', 'Coachs', 'Patients'],
        datasets: [{
            data: [{{ totalAdmins }}, {{ totalCoachs }}, {{ totalPatients }}],
            backgroundColor: ['rgba(232,137,90,0.8)', 'rgba(74,111,165,0.8)', 'rgba(39,174,96,0.8)'],
            borderColor: ['#E8895A', '#4A6FA5', '#27ae60'],
            borderWidth: 2,
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: '#8899AA', padding: 16 } } },
        cutout: '65%',
        animation: { duration: 1500 }
    }
});

new Chart(document.getElementById('radarChart'), {
    type: 'radar',
    data: {
        labels: ['Sommeil', 'Humeur', 'Anti-Stress'],
        datasets: [{
            label: 'Moyenne patients',
            data: [
                {{ avgBienEtre.avgSommeil ? avgBienEtre.avgSommeil|round : 0 }},
                {{ avgBienEtre.avgHumeur ? avgBienEtre.avgHumeur|round : 0 }},
                {{ avgBienEtre.avgStress ? (100 - avgBienEtre.avgStress)|round : 0 }}
            ],
            backgroundColor: 'rgba(232,137,90,0.15)',
            borderColor: '#E8895A',
            pointBackgroundColor: '#E8895A',
            pointBorderColor: '#0D1B2A',
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#8899AA' } } },
        scales: {
            r: {
                beginAtZero: true, max: 100,
                grid: { color: 'rgba(255,255,255,0.05)' },
                ticks: { color: '#8899AA', backdropColor: 'transparent' },
                pointLabels: { color: '#8899AA' }
            }
        },
        animation: { duration: 1500 }
    }
});
</script>
{% endblock %}