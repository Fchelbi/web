{% extends 'base.html.twig' %}

{% block title %}Liste des psychologues{% endblock %}

{% block body %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Nos psychologues</h1>
            <p class="text-muted mb-0">Choisissez le professionnel qui correspond le mieux a votre besoin.</p>
        </div>
        <a href="{{ path('consultation_list') }}" class="btn btn-outline-secondary">Retour aux consultations</a>
    </div>

    <div class="row g-4">
        {% for psychologue in psychologues %}
            <div class="col-md-6 col-xl-4">
                <div class="card page-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 mb-1">{{ psychologue.nomComplet }}</h2>
                        <div class="text-primary fw-semibold mb-3">{{ psychologue.specialite }}</div>
                        <p class="text-muted mb-3">{{ psychologue.description }}</p>
                        <div class="small text-muted mb-4">Telephone : {{ psychologue.telephone }}</div>

                        <div class="mt-auto">
                            <a href="{{ path('consultation_add_with_psychologue', {'psychologue': psychologue.id}) }}" class="btn btn-primary w-100">
                                Prendre rendez-vous
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info mb-0">
                    Aucun psychologue n'est disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
