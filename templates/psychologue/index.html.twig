{% extends 'base.html.twig' %}

{% block title %}Liste des psychologues{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0D1B2A; min-height: 100vh; color: white; }
        .navbar {
            background: #162232; padding: 0 40px; height: 70px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: white; }
        .navbar-logo span { color: #E8895A; }
        .navbar-links { display: flex; gap: 32px; align-items: center; }
        .navbar-links a {
            color: #8899AA; text-decoration: none; font-size: 14px;
            font-weight: 500; transition: color 0.2s; padding: 0 8px;
        }
        .navbar-links a:hover { color: white; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-name { font-size: 14px; color: #8899AA; }
        .btn-logout {
            padding: 8px 18px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border-radius: 8px; text-decoration: none; font-size: 13px;
            font-weight: 600; border: 1px solid rgba(231,76,60,0.2); transition: all 0.2s;
        }
        .btn-logout:hover { background: rgba(231,76,60,0.3); }
        .content { padding: 40px; }
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 26px; font-weight: 700; color: white; }
        .page-header p { font-size: 14px; color: #8899AA; margin-top: 6px; }
        .page-header-banner {
            background: linear-gradient(135deg, #162232 0%, #0D1B2A 100%);
            border: 1px solid rgba(232,137,90,0.2);
            border-radius: 12px;
            padding: 32px;
            margin-bottom: 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .page-header-banner h1 { font-size: 28px; font-weight: 700; color: white; margin-bottom: 8px; }
        .page-header-banner p { font-size: 14px; color: #8899AA; margin: 0; }
        .page-header-banner-content { flex: 1; }
        
        .btn {
            padding: 10px 18px; border-radius: 8px; font-size: 13px; font-weight: 600;
            text-decoration: none; border: 1px solid transparent; cursor: pointer;
            transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-primary {
            background: #4A6FA5; color: white;
        }
        .btn-primary:hover {
            background: #3A5585; box-shadow: 0 4px 12px rgba(74,111,165,0.3);
        }
        .btn-secondary {
            background: rgba(232,137,90,0.15); color: #E8895A; border: 1px solid rgba(232,137,90,0.3);
        }
        .btn-secondary:hover {
            background: rgba(232,137,90,0.25);
        }

        .psychologists-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 24px;
            margin-bottom: 32px;
        }
        .psychologist-card {
            background: #162232; border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px; padding: 24px;
            transition: all 0.2s;
        }
        .psychologist-card:hover {
            transform: translateY(-4px);
            border-color: rgba(232,137,90,0.3);
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        }
        .psychologist-name { font-size: 18px; font-weight: 700; color: white; margin-bottom: 4px; }
        .psychologist-role { font-size: 13px; color: #E8895A; font-weight: 600; margin-bottom: 12px; }
        .psychologist-email { font-size: 13px; color: #8899AA; margin-bottom: 8px; }
        .psychologist-phone { font-size: 13px; color: #8899AA; margin-bottom: 20px; }
        .psychologist-button {
            width: 100%;
        }

        .pagination {
            display: flex; justify-content: center; gap: 8px; margin-top: 32px;
        }
        .pagination a, .pagination span {
            padding: 8px 12px; border-radius: 6px; font-size: 13px;
            text-decoration: none; border: 1px solid rgba(255,255,255,0.1);
            color: #8899AA; transition: all 0.2s;
        }
        .pagination a:hover {
            background: rgba(232,137,90,0.2); border-color: rgba(232,137,90,0.3); color: #E8895A;
        }
        .pagination .current {
            background: #4A6FA5; color: white; border-color: #4A6FA5;
        }
    </style>
</head>
<body>
    <div class="content">
        <div class="page-header-banner">
            <div class="page-header-banner-content">
                <h1>Nos psychologues</h1>
                <p>Choisissez le professionnel qui correspond le mieux à votre besoin et prenez rendez-vous en quelques clics.</p>
            </div>
            <a href="{{ path('consultation_list') }}" class="btn btn-secondary">← Retour</a>
        </div>

        <div class="psychologists-grid">
            {% for psychologue in psychologues %}
                <div class="psychologist-card">
                    <div class="psychologist-name">{{ psychologue.nomComplet }}</div>
                    <div class="psychologist-role">{{ psychologue.role ?: 'Coach' }}</div>
                    <div class="psychologist-email">{{ psychologue.email }}</div>
                    <div class="psychologist-phone">📞 {{ psychologue.numTel ?: 'Non renseigné' }}</div>
                    
                    <a href="{{ path('consultation_add_with_psychologue', {'psychologue': psychologue.id}) }}" class="btn btn-primary psychologist-button">
                        Prendre rendez-vous
                    </a>
                </div>
            {% else %}
                <div style="grid-column: 1/-1; text-align: center; color: #8899AA; padding: 40px;">
                    Aucun psychologue n'est disponible pour le moment.
                </div>
            {% endfor %}
        </div>

        <div class="pagination">
            {{ knp_pagination_render(psychologues, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
        </div>
    </div>
</body>
</html>
{% endblock %}
