{% extends 'base.html.twig' %}

{% block title %}Liste des psychologues{% endblock %}

{% block body %}
    <section class="page-card p-4 p-md-5 mb-4 overflow-hidden" style="background: linear-gradient(135deg, #4A6FA5 0%, #2C4F7C 100%); color: white;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="text-uppercase small fw-semibold mb-2" style="letter-spacing: 0.08em; color: rgba(255,255,255,0.75);">Selection du praticien</div>
                <h1 class="h2 mb-2">Nos psychologues</h1>
                <p class="mb-0" style="color: rgba(255,255,255,0.82);">Choisissez le professionnel qui correspond le mieux a votre besoin et prenez rendez-vous en quelques clics.</p>
            </div>
            <a href="{{ path('consultation_list') }}" class="btn btn-light" style="color: #2C4F7C;">Retour aux consultations</a>
        </div>
    </section>

    <div class="row g-4">
        {% for psychologue in psychologues %}
            <div class="col-md-6 col-xl-4">
                <div class="card page-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 mb-1">{{ psychologue.nomComplet }}</h2>
                        <div class="fw-semibold mb-3" style="color: #E8895A;">{{ psychologue.specialite }}</div>
                        <p class="text-muted mb-3">{{ psychologue.description }}</p>
                        <div class="small text-muted mb-4">Telephone : {{ psychologue.telephone }}</div>

                        <div class="mt-auto">
                            <a href="{{ path('consultation_add_with_psychologue', {'psychologue': psychologue.id}) }}" class="btn btn-primary w-100">
                                Prendre rendez-vous
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info mb-0">
                    Aucun psychologue n'est disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
