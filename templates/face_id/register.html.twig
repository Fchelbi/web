<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Enregistrer Face ID · EchoCare</title>
    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .card {
            background: white; border-radius: 20px; padding: 40px;
            max-width: 600px; width: 100%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1); text-align: center;
        }
        h1 { font-size: 24px; color: #2C3E50; margin-bottom: 8px; }
        p { font-size: 14px; color: #999; margin-bottom: 24px; }
        .video-wrapper {
            position: relative; display: inline-block;
            border-radius: 16px; overflow: hidden;
            border: 3px solid #4A6FA5;
        }
        video { display: block; width: 480px; height: 360px; background: #000; }
        canvas { position: absolute; top: 0; left: 0; }
        .status {
            margin: 20px 0; padding: 14px 20px;
            border-radius: 10px; font-size: 14px; font-weight: 600;
        }
        .status.loading { background: #fef3cd; color: #856404; }
        .status.ready { background: #d8fde8; color: #27ae60; }
        .status.error { background: #ffe0e0; color: #c0392b; }
        .status.success { background: #d8fde8; color: #27ae60; font-size: 18px; }
        .btn {
            padding: 14px 32px; background: #E8895A; color: white;
            border: none; border-radius: 10px; font-size: 15px;
            font-weight: 600; cursor: pointer; transition: background 0.2s;
            margin: 8px;
        }
        .btn:hover { background: #d4784a; }
        .btn:disabled { background: #ccc; cursor: not-allowed; }
        .btn-secondary {
            padding: 14px 32px; background: #4A6FA5; color: white;
            border: none; border-radius: 10px; font-size: 15px;
            font-weight: 600; cursor: pointer; text-decoration: none;
            display: inline-block; margin: 8px;
        }
        .steps {
            display: flex; justify-content: center; gap: 20px;
            margin-bottom: 24px;
        }
        .step {
            display: flex; flex-direction: column; align-items: center;
            gap: 6px; font-size: 12px; color: #999;
        }
        .step .circle {
            width: 32px; height: 32px; border-radius: 50%;
            background: #F0EAE0; display: flex; align-items: center;
            justify-content: center; font-size: 14px;
        }
        .step.active .circle { background: #4A6FA5; color: white; }
        .step.done .circle { background: #27ae60; color: white; }
    </style>
</head>
<body>
<div class="card">
    <h1>🔐 Enregistrer votre Face ID</h1>
    <p>Positionnez votre visage dans le cadre et restez immobile</p>

    <div class="steps">
        <div class="step active" id="step1">
            <div class="circle">1</div>
            <span>Caméra</span>
        </div>
        <div class="step" id="step2">
            <div class="circle">2</div>
            <span>Détection</span>
        </div>
        <div class="step" id="step3">
            <div class="circle">3</div>
            <span>Enregistrement</span>
        </div>
    </div>

    <div class="video-wrapper">
        <video id="video" autoplay muted></video>
        <canvas id="canvas"></canvas>
    </div>

    <div class="status loading" id="status">⏳ Chargement des modèles IA...</div>

    <div>
        <button class="btn" id="captureBtn" disabled onclick="capture()">
            📸 Enregistrer mon visage
        </button>
        <a href="{{ path('admin_dashboard') }}" class="btn-secondary">← Retour</a>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const status = document.getElementById('status');
const captureBtn = document.getElementById('captureBtn');

async function loadModels() {
    const MODEL_URL = '/models';
    await Promise.all([
        faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
        faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    status.className = 'status ready';
    status.textContent = '✅ Modèles chargés ! Activez la caméra.';
    startCamera();
}

async function startCamera() {
    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;
    video.addEventListener('play', () => {
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        detectFace();
        document.getElementById('step1').className = 'step done';
        document.getElementById('step2').className = 'step active';
    });
}

async function detectFace() {
    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks()
        .withFaceDescriptor();

    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (detection) {
        faceapi.draw.drawDetections(canvas, [detection]);
        faceapi.draw.drawFaceLandmarks(canvas, [detection]);
        status.className = 'status ready';
        status.textContent = '😊 Visage détecté ! Cliquez pour enregistrer.';
        captureBtn.disabled = false;
    } else {
        status.className = 'status loading';
        status.textContent = '👤 Aucun visage détecté...';
        captureBtn.disabled = true;
    }

    setTimeout(detectFace, 200);
}

async function capture() {
    captureBtn.disabled = true;
    status.className = 'status loading';
    status.textContent = '⏳ Analyse en cours...';

    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks()
        .withFaceDescriptor();

    if (!detection) {
        status.className = 'status error';
        status.textContent = '❌ Visage non détecté. Réessayez.';
        captureBtn.disabled = false;
        return;
    }

    const descriptor = Array.from(detection.descriptor);

    const res = await fetch('{{ path("face_register_save") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ descriptor })
    });

    const data = await res.json();

    if (data.success) {
        document.getElementById('step2').className = 'step done';
        document.getElementById('step3').className = 'step done';
        status.className = 'status success';
        status.textContent = '🎉 Face ID enregistré avec succès !';
        setTimeout(() => window.location.href = '{{ path("admin_dashboard") }}', 2000);
    } else {
        status.className = 'status error';
        status.textContent = '❌ Erreur lors de l\'enregistrement.';
        captureBtn.disabled = false;
    }
}

loadModels();
</script>
</body>
</html>