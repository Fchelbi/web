<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Enregistrer Face ID · EchoCare</title>
    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif; background: #0D1B2A;
            display: flex; justify-content: center; align-items: center; min-height: 100vh;
        }
        .card {
            background: #162232; border-radius: 24px; padding: 40px;
            max-width: 620px; width: 100%;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 30px 80px rgba(0,0,0,0.5); text-align: center;
        }
        .logo { font-size: 22px; font-weight: 700; color: white; margin-bottom: 6px; }
        .logo span { color: #E8895A; }
        h1 { font-size: 24px; font-weight: 700; color: white; margin-bottom: 8px; }
        p { font-size: 14px; color: #8899AA; margin-bottom: 24px; }

        .steps { display: flex; justify-content: center; gap: 20px; margin-bottom: 24px; }
        .step { display: flex; flex-direction: column; align-items: center; gap: 6px; font-size: 12px; color: #8899AA; }
        .step .circle {
            width: 32px; height: 32px; border-radius: 50%;
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
            display: flex; align-items: center; justify-content: center; font-size: 14px; color: #4A5568;
        }
        .step.active .circle { background: rgba(232,137,90,0.2); border-color: #E8895A; color: #E8895A; }
        .step.done .circle { background: rgba(39,174,96,0.2); border-color: #27ae60; color: #27ae60; }

        .video-wrapper {
            position: relative; display: inline-block;
            border-radius: 16px; overflow: hidden;
            border: 2px solid rgba(232,137,90,0.3); margin-bottom: 16px;
        }
        video { display: block; width: 480px; height: 360px; background: #0D1B2A; }
        canvas { position: absolute; top: 0; left: 0; }

        .status {
            margin: 16px 0; padding: 14px 20px;
            border-radius: 10px; font-size: 14px; font-weight: 600;
        }
        .status.loading { background: rgba(232,137,90,0.1); color: #E8895A; border: 1px solid rgba(232,137,90,0.2); }
        .status.ready { background: rgba(39,174,96,0.1); color: #27ae60; border: 1px solid rgba(39,174,96,0.2); }
        .status.error { background: rgba(231,76,60,0.1); color: #e74c3c; border: 1px solid rgba(231,76,60,0.2); }
        .status.success { background: rgba(39,174,96,0.1); color: #27ae60; border: 1px solid rgba(39,174,96,0.2); font-size: 18px; }

        .btn {
            padding: 14px 32px; background: #E8895A; color: white;
            border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
            cursor: pointer; transition: all 0.2s; margin: 8px;
        }
        .btn:hover { background: #d4784a; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(232,137,90,0.3); }
        .btn:disabled { background: rgba(255,255,255,0.05); color: #4A5568; cursor: not-allowed; transform: none; box-shadow: none; }
        .btn-secondary {
            padding: 14px 32px; background: rgba(255,255,255,0.05); color: #8899AA;
            border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
            font-size: 14px; font-weight: 600; cursor: pointer;
            text-decoration: none; display: inline-block; margin: 8px; transition: all 0.2s;
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); color: white; }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">Echo<span>Care</span></div>
    <h1>🔐 Enregistrer votre Face ID</h1>
    <p>Positionnez votre visage dans le cadre et restez immobile</p>

    <div class="steps">
        <div class="step active" id="step1">
            <div class="circle">1</div>
            <span>Camera</span>
        </div>
        <div class="step" id="step2">
            <div class="circle">2</div>
            <span>Detection</span>
        </div>
        <div class="step" id="step3">
            <div class="circle">3</div>
            <span>Enregistrement</span>
        </div>
    </div>

    <div class="video-wrapper">
        <video id="video" autoplay muted></video>
        <canvas id="canvas"></canvas>
    </div>

    <div class="status loading" id="status">⏳ Chargement des modeles IA...</div>

    <div>
        <button class="btn" id="captureBtn" disabled onclick="capture()">📸 Enregistrer mon visage</button>
        <a href="{{ path('admin_dashboard') }}" class="btn-secondary">← Retour</a>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const status = document.getElementById('status');
const captureBtn = document.getElementById('captureBtn');

async function loadModels() {
    const MODEL_URL = '/models';
    await Promise.all([
        faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
        faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
        faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    status.className = 'status ready';
    status.textContent = '✅ Modeles charges ! Camera en cours...';
    startCamera();
}

async function startCamera() {
    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;
    video.addEventListener('play', () => {
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        detectFace();
        document.getElementById('step1').className = 'step done';
        document.getElementById('step2').className = 'step active';
    });
}

async function detectFace() {
    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks().withFaceDescriptor();
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    if (detection) {
        faceapi.draw.drawDetections(canvas, [detection]);
        faceapi.draw.drawFaceLandmarks(canvas, [detection]);
        status.className = 'status ready';
        status.textContent = '😊 Visage detecte ! Cliquez pour enregistrer.';
        captureBtn.disabled = false;
    } else {
        status.className = 'status loading';
        status.textContent = '👤 Positionnez votre visage...';
        captureBtn.disabled = true;
    }
    setTimeout(detectFace, 200);
}

async function capture() {
    captureBtn.disabled = true;
    status.className = 'status loading';
    status.textContent = '⏳ Analyse en cours...';
    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks().withFaceDescriptor();
    if (!detection) {
        status.className = 'status error';
        status.textContent = '❌ Visage non detecte. Reessayez.';
        captureBtn.disabled = false;
        return;
    }
    const descriptor = Array.from(detection.descriptor);
    const res = await fetch('{{ path("face_register_save") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ descriptor })
    });
    const data = await res.json();
    if (data.success) {
        document.getElementById('step2').className = 'step done';
        document.getElementById('step3').className = 'step done';
        status.className = 'status success';
        status.textContent = '🎉 Face ID enregistre avec succes !';
        setTimeout(() => window.location.href = '{{ path("admin_dashboard") }}', 2000);
    } else {
        status.className = 'status error';
        status.textContent = '❌ Erreur lors de l\'enregistrement.';
        captureBtn.disabled = false;
    }
}
loadModels();
</script>
</body>
</html>
