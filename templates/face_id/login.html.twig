<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion Face ID · EchoCare</title>
    <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #F0E6D8;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh;
        }
        .container {
            display: flex; width: 820px; min-height: 560px;
            border-radius: 20px; overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        }
        .left-panel {
            background: #4A6FA5; width: 45%; padding: 50px 40px;
            display: flex; flex-direction: column;
            justify-content: space-between; color: white;
        }
        .logo-area { text-align: center; }
        .logo-icon {
            width: 80px; height: 80px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%; display: flex;
            align-items: center; justify-content: center;
            font-size: 36px; margin: 0 auto 16px;
        }
        .logo-area h1 { font-size: 28px; font-weight: 700; }
        .logo-area h1 span { color: #E8895A; }
        .logo-area p { font-size: 13px; opacity: 0.7; margin-top: 6px; }
        .features { display: flex; flex-direction: column; gap: 16px; }
        .feature-item { border-left: 3px solid #E8895A; padding-left: 14px; }
        .feature-item h3 { font-size: 14px; font-weight: 600; }
        .feature-item p { font-size: 12px; opacity: 0.7; margin-top: 2px; }
        .version { text-align: center; font-size: 11px; opacity: 0.4; }
        .right-panel {
            background: #FAF7F2; width: 55%; padding: 40px 45px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .dots { display: flex; gap: 6px; margin-bottom: 24px; }
        .dot { width: 28px; height: 4px; border-radius: 2px; }
        .dot:nth-child(1) { background: #E8895A; }
        .dot:nth-child(2) { background: #E8C99A; }
        .dot:nth-child(3) { background: #4A6FA5; }
        h2 { font-size: 24px; font-weight: 700; color: #2C3E50; margin-bottom: 6px; }
        .subtitle { font-size: 13px; color: #999; margin-bottom: 24px; }
        .video-wrapper {
            position: relative; border-radius: 16px;
            overflow: hidden; border: 3px solid #4A6FA5;
            margin-bottom: 16px;
        }
        video { display: block; width: 100%; height: 240px; background: #000; object-fit: cover; }
        canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
        .status {
            padding: 12px 16px; border-radius: 10px;
            font-size: 13px; font-weight: 600; margin-bottom: 16px;
            text-align: center;
        }
        .status.loading { background: #fef3cd; color: #856404; }
        .status.ready { background: #d8fde8; color: #27ae60; }
        .status.error { background: #ffe0e0; color: #c0392b; }
        .status.success { background: #d8fde8; color: #27ae60; }
        .scanning-ring {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 150px; height: 150px;
            border: 3px solid #E8895A;
            border-radius: 50%;
            animation: pulse 2s infinite;
            pointer-events: none;
        }
        @keyframes pulse {
            0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.5; }
            100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        }
        .btn-scan {
            width: 100%; padding: 14px; background: #E8895A;
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            transition: background 0.2s; margin-bottom: 10px;
        }
        .btn-scan:hover { background: #d4784a; }
        .btn-scan:disabled { background: #ccc; cursor: not-allowed; }
        .separator {
            text-align: center; color: #ccc; font-size: 13px;
            margin: 12px 0; position: relative;
        }
        .separator::before, .separator::after {
            content: ''; position: absolute; top: 50%;
            width: 42%; height: 1px; background: #E8E0D5;
        }
        .separator::before { left: 0; }
        .separator::after { right: 0; }
        .btn-password {
            width: 100%; padding: 13px; background: transparent;
            color: #4A6FA5; border: 1.5px solid #4A6FA5;
            border-radius: 10px; font-size: 14px; font-weight: 600;
            text-decoration: none; display: block; text-align: center;
            transition: all 0.2s;
        }
        .btn-password:hover { background: #4A6FA5; color: white; }
    </style>
</head>
<body>
<div class="container">
    <div class="left-panel">
        <div class="logo-area">
            <div class="logo-icon">🧠</div>
            <h1>Echo<span>Care</span></h1>
            <p>Psychologie · Bien-être</p>
        </div>
        <div class="features">
            <div class="feature-item">
                <h3>🔐 Connexion sécurisée</h3>
                <p>Reconnaissance faciale IA</p>
            </div>
            <div class="feature-item">
                <h3>⚡ Accès instantané</h3>
                <p>Plus besoin de mot de passe</p>
            </div>
            <div class="feature-item">
                <h3>🛡️ Admin uniquement</h3>
                <p>Réservé aux administrateurs</p>
            </div>
        </div>
        <div class="version">EchoCare v2.0</div>
    </div>

    <div class="right-panel">
        <div class="dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>
        <h2>Connexion Face ID 🔐</h2>
        <p class="subtitle">Regardez la caméra pour vous connecter</p>

        <div class="video-wrapper">
            <video id="video" autoplay muted playsinline></video>
            <canvas id="canvas"></canvas>
            <div class="scanning-ring" id="ring"></div>
        </div>

        <div class="status loading" id="status">⏳ Chargement des modèles IA...</div>

        <button class="btn-scan" id="scanBtn" disabled onclick="scan()">
            👁️ Scanner mon visage
        </button>

        <div class="separator">ou</div>
        <a href="{{ path('app_login') }}" class="btn-password">🔑 Connexion par mot de passe</a>
    </div>
</div>

<script>
const video = document.getElementById('video');
const canvas = document.getElementById('canvas');
const status = document.getElementById('status');
const scanBtn = document.getElementById('scanBtn');
const ring = document.getElementById('ring');

async function loadModels() {
    try {
        const MODEL_URL = '/models';
        await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
            faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
            faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
        ]);
        status.className = 'status ready';
        status.textContent = '✅ Prêt ! Activez la caméra.';
        startCamera();
    } catch(e) {
        status.className = 'status error';
        status.textContent = '❌ Erreur chargement modèles : ' + e.message;
    }
}

async function startCamera() {
    try {
        const stream = await navigator.mediaDevices.getUserMedia({ video: true });
        video.srcObject = stream;
        video.addEventListener('play', () => {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            detectLoop();
        });
    } catch(e) {
        status.className = 'status error';
        status.textContent = '❌ Caméra non accessible : ' + e.message;
    }
}

async function detectLoop() {
    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks()
        .withFaceDescriptor();

    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (detection) {
        faceapi.draw.drawDetections(canvas, [detection]);
        status.className = 'status ready';
        status.textContent = '😊 Visage détecté ! Cliquez pour vous connecter.';
        scanBtn.disabled = false;
        ring.style.borderColor = '#27ae60';
    } else {
        status.className = 'status loading';
        status.textContent = '👤 Positionnez votre visage...';
        scanBtn.disabled = true;
        ring.style.borderColor = '#E8895A';
    }

    setTimeout(detectLoop, 300);
}

async function scan() {
    scanBtn.disabled = true;
    status.className = 'status loading';
    status.textContent = '⏳ Vérification en cours...';

    const detection = await faceapi
        .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
        .withFaceLandmarks()
        .withFaceDescriptor();

    if (!detection) {
        status.className = 'status error';
        status.textContent = '❌ Visage non détecté. Réessayez.';
        scanBtn.disabled = false;
        return;
    }

    const descriptor = Array.from(detection.descriptor);

    const res = await fetch('{{ path("face_login_verify") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ descriptor })
    });

    const data = await res.json();

    if (data.success) {
        status.className = 'status success';
        status.textContent = '🎉 Visage reconnu ! Redirection...';
        ring.style.borderColor = '#27ae60';
        setTimeout(() => window.location.href = data.redirect, 1500);
    } else {
        status.className = 'status error';
        status.textContent = '❌ Visage non reconnu. Réessayez.';
        ring.style.borderColor = '#e74c3c';
        scanBtn.disabled = false;
    }
}

loadModels();
</script>
</body>
</html>