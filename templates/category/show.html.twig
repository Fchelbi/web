{% extends 'layout.html.twig' %}

{% block title %}Category — {{ category.name }}{% endblock %}

{% block content %}
<div style="max-width:700px;margin:0 auto;">
    <div class="post-card glassmorphism" style="animation:scaleIn 0.5s ease forwards;">
        <h1 class="page-title" style="font-size:1.6rem;">Category Details</h1>

        <div style="margin-bottom:1.5rem;">
            <label style="display:block;color:var(--text-subtle);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.4rem;font-weight:600;">Name</label>
            <p style="color:var(--text-main);font-size:1.1rem;font-weight:600;margin:0;display:flex;align-items:center;gap:0.5rem;">
                <i data-lucide="tag" style="width:18px;height:18px;color:var(--primary-color);"></i>
                {{ category.name }}
            </p>
        </div>

        <div style="display:flex;gap:0.6rem;padding-top:1.5rem;border-top:1px solid var(--border-color);">
            <a href="{{ path('app_category_index') }}" class="btn btn-icon btn-secondary" data-tooltip="Back">
                <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
            </a>
            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-icon btn-action" data-tooltip="Edit">
                <i data-lucide="pencil" style="width:16px;height:16px;"></i>
            </a>
            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
