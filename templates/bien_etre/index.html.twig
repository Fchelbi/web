<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Mon Bien-être · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; }
        .navbar {
            background: white; padding: 0 60px;
            display: flex; justify-content: space-between; align-items: center;
            height: 70px; box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: #4A6FA5; }
        .navbar-logo span { color: #E8895A; }
        .navbar-links { display: flex; gap: 32px; }
        .navbar-links a {
            color: #555; text-decoration: none; font-size: 14px;
            font-weight: 500; transition: color 0.2s;
        }
        .navbar-links a:hover, .navbar-links a.active { color: #4A6FA5; font-weight: 600; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 10px;
            background: #F5EFE6; padding: 8px 16px; border-radius: 30px;
        }
        .user-pill .avatar {
            width: 32px; height: 32px; background: #4A6FA5; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 14px; font-weight: 700;
        }
        .btn-logout {
            padding: 8px 18px; background: #E8895A; color: white;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
        }
        .back-btn {
            padding: 8px 18px; background: #4A6FA5; color: white;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
        }
        .content { padding: 40px 60px; max-width: 900px; margin: 0 auto; }
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 24px; font-weight: 700; color: #2C3E50; }
        .page-header p { font-size: 14px; color: #999; margin-top: 4px; }

        .success-msg {
            background: #d8fde8; color: #27ae60;
            padding: 14px 20px; border-radius: 10px;
            font-size: 14px; margin-bottom: 20px;
        }

        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

        .panel {
            background: white; border-radius: 16px; padding: 28px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
        }
        .panel h3 { font-size: 16px; font-weight: 700; color: #2C3E50; margin-bottom: 20px; }

        .slider-group { margin-bottom: 24px; }
        .slider-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 10px;
        }
        .slider-label { display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #2C3E50; }
        .slider-value {
            font-size: 20px; font-weight: 700;
            min-width: 50px; text-align: right;
        }
        input[type="range"] {
            width: 100%; height: 6px; border-radius: 3px;
            outline: none; cursor: pointer; appearance: none;
            border: none; background: transparent;
        }
        input[type="range"]::-webkit-slider-runnable-track {
            height: 6px; border-radius: 3px; background: #F0EAE0;
        }
        input[type="range"]::-webkit-slider-thumb {
            appearance: none; width: 20px; height: 20px;
            border-radius: 50%; margin-top: -7px; cursor: pointer;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        .mood-hint { font-size: 11px; color: #aaa; margin-top: 6px; text-align: center; }

        .btn-save {
            width: 100%; padding: 14px; background: #E8895A;
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            transition: background 0.2s; margin-top: 8px;
        }
        .btn-save:hover { background: #d4784a; }

        /* Current values */
        .current-panel { }
        .current-item {
            display: flex; align-items: center; gap: 14px;
            padding: 16px 0; border-bottom: 1px solid #F5EFE6;
        }
        .current-item:last-child { border-bottom: none; }
        .c-icon { font-size: 32px; }
        .c-info { flex: 1; }
        .c-info h4 { font-size: 14px; font-weight: 600; color: #2C3E50; margin-bottom: 6px; }
        .c-bar { height: 8px; background: #F0EAE0; border-radius: 4px; overflow: hidden; }
        .c-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }
        .c-value { font-size: 16px; font-weight: 700; min-width: 40px; text-align: right; }

        .no-data {
            text-align: center; padding: 40px 20px; color: #999;
        }
        .no-data .icon { font-size: 48px; margin-bottom: 12px; }
        .no-data p { font-size: 14px; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span></div>
    <div class="navbar-links">
        <a href="{{ path('patient_dashboard') }}">Accueil</a>
        <a href="#">Mes séances</a>
        <a href="#">Messages</a>
        <a href="{{ path('patient_rapports') }}">Rapports</a>
        <a href="{{ path('patient_bien_etre') }}" class="active">Bien-être</a>
        <a href="{{ path('patient_profile') }}">Mon profil</a>
    </div>
    <div class="navbar-right">
        <a href="{{ path('patient_dashboard') }}" class="back-btn">← Retour</a>
        <div class="user-pill">
            <div class="avatar">{{ app.user.prenom|slice(0,1)|upper }}</div>
            <span>{{ app.user.prenom }}</span>
        </div>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪</a>
    </div>
</nav>

<div class="content">
    <div class="page-header">
        <h2>🌿 Mon Bien-être</h2>
        <p>Évaluez votre état quotidien pour suivre votre progression</p>
    </div>

    {% if success %}
        <div class="success-msg">✅ {{ success }}</div>
    {% endif %}

    <div class="grid-2">
        <!-- Formulaire -->
        <div class="panel">
            <h3>📝 Évaluation du jour</h3>

            <form method="post" id="bienEtreForm">

                <!-- Sommeil -->
                <div class="slider-group">
                    <div class="slider-header">
                        <span class="slider-label">😴 Sommeil</span>
                        <span class="slider-value" id="sommeilVal" style="color:#4A6FA5;">50%</span>
                    </div>
                    <input type="range" name="sommeil" id="sommeil"
                           min="0" max="100" value="50"
                           oninput="updateSlider('sommeil', this.value, '#4A6FA5')"
                           style="--thumb-color:#4A6FA5;">
                    <div class="mood-hint" id="sommeilHint">Moyen</div>
                </div>

                <!-- Stress -->
                <div class="slider-group">
                    <div class="slider-header">
                        <span class="slider-label">🧘 Niveau de stress</span>
                        <span class="slider-value" id="stressVal" style="color:#E8895A;">50%</span>
                    </div>
                    <input type="range" name="stress" id="stress"
                           min="0" max="100" value="50"
                           oninput="updateSlider('stress', this.value, '#E8895A')"
                           style="--thumb-color:#E8895A;">
                    <div class="mood-hint" id="stressHint">Moyen</div>
                </div>

                <!-- Humeur -->
                <div class="slider-group">
                    <div class="slider-header">
                        <span class="slider-label">😊 Humeur</span>
                        <span class="slider-value" id="humeurVal" style="color:#27ae60;">50%</span>
                    </div>
                    <input type="range" name="humeur" id="humeur"
                           min="0" max="100" value="50"
                           oninput="updateSlider('humeur', this.value, '#27ae60')"
                           style="--thumb-color:#27ae60;">
                    <div class="mood-hint" id="humeurHint">Moyen</div>
                </div>

                <button type="submit" class="btn-save">💾 Enregistrer mon état</button>
            </form>
        </div>

        <!-- Dernières valeurs -->
        <div class="panel current-panel">
            <h3>📊 Dernière évaluation</h3>

            {% if last %}
                <p style="font-size:12px;color:#999;margin-bottom:16px;">
                    📅 {{ last.createdAt|date('d/m/Y à H:i') }}
                </p>
                <div class="current-item">
                    <span class="c-icon">😴</span>
                    <div class="c-info">
                        <h4>Sommeil</h4>
                        <div class="c-bar">
                            <div class="c-fill" style="width:{{ last.sommeil }}%;background:#4A6FA5;"></div>
                        </div>
                    </div>
                    <span class="c-value" style="color:#4A6FA5;">{{ last.sommeil }}%</span>
                </div>
                <div class="current-item">
                    <span class="c-icon">🧘</span>
                    <div class="c-info">
                        <h4>Stress</h4>
                        <div class="c-bar">
                            <div class="c-fill" style="width:{{ last.stress }}%;background:#E8895A;"></div>
                        </div>
                    </div>
                    <span class="c-value" style="color:#E8895A;">{{ last.stress }}%</span>
                </div>
                <div class="current-item">
                    <span class="c-icon">😊</span>
                    <div class="c-info">
                        <h4>Humeur</h4>
                        <div class="c-bar">
                            <div class="c-fill" style="width:{{ last.humeur }}%;background:#27ae60;"></div>
                        </div>
                    </div>
                    <span class="c-value" style="color:#27ae60;">{{ last.humeur }}%</span>
                </div>
            {% else %}
                <div class="no-data">
                    <div class="icon">📋</div>
                    <p>Aucune évaluation encore.<br>Remplissez le formulaire !</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    function getHint(val, type) {
        if (type === 'stress') {
            if (val < 25) return '😌 Très faible';
            if (val < 50) return '🙂 Faible';
            if (val < 75) return '😟 Moyen';
            return '😰 Élevé';
        }
        if (val < 25) return '😞 Très mauvais';
        if (val < 50) return '😐 Faible';
        if (val < 75) return '🙂 Moyen';
        return '😊 Excellent';
    }

    function updateSlider(name, val, color) {
        document.getElementById(name + 'Val').textContent = val + '%';
        const hints = { sommeil: 'sommeil', stress: 'stress', humeur: 'humeur' };
        document.getElementById(name + 'Hint').textContent = getHint(parseInt(val), name);

        // Update thumb color
        const input = document.getElementById(name);
        input.style.setProperty('--thumb-color', color);
    }

    // Style sliders
    document.querySelectorAll('input[type="range"]').forEach(input => {
        const color = input.style.getPropertyValue('--thumb-color') || '#4A6FA5';
        input.style.cssText += `
            background: linear-gradient(to right, ${color} 0%, ${color} 50%, #F0EAE0 50%, #F0EAE0 100%);
        `;
        input.addEventListener('input', function() {
            const pct = (this.value - this.min) / (this.max - this.min) * 100;
            this.style.background = `linear-gradient(to right, ${color} 0%, ${color} ${pct}%, #F0EAE0 ${pct}%, #F0EAE0 100%)`;
        });
    });
</script>
</body>
</html>