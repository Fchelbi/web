<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Messagerie · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0D1B2A; color: white; height: 100vh; display: flex; flex-direction: column; }
        .navbar {
            background: #162232; padding: 0 40px; height: 70px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05); flex-shrink: 0;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: white; }
        .navbar-logo span { color: #E8895A; }
        .navbar-right { display: flex; gap: 10px; align-items: center; }
        .btn-back {
            padding: 8px 18px; background: rgba(255,255,255,0.05); color: #8899AA;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(255,255,255,0.05); transition: all 0.2s;
        }
        .btn-back:hover { background: rgba(232,137,90,0.15); color: #E8895A; }
        .btn-logout {
            padding: 8px 18px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(231,76,60,0.2);
        }
        .chat-container { display: flex; flex: 1; overflow: hidden; }
        .sidebar {
            width: 300px; background: #162232; border-right: 1px solid rgba(255,255,255,0.05);
            display: flex; flex-direction: column; flex-shrink: 0;
        }
        .sidebar-header { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .sidebar-header h3 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 12px; }
        .search-box {
            padding: 10px 14px; background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
            color: white; font-size: 13px; outline: none; width: 100%;
        }
        .search-box::placeholder { color: #4A5568; }
        .contacts-list { flex: 1; overflow-y: auto; }
        .contact-item {
            display: flex; align-items: center; gap: 12px; padding: 14px 20px;
            cursor: pointer; transition: background 0.2s; text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .contact-item:hover { background: rgba(255,255,255,0.03); }
        .contact-item.active { background: rgba(232,137,90,0.1); border-left: 3px solid #E8895A; }
        .contact-avatar {
            width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700; color: white; position: relative;
        }
        .online-dot {
            position: absolute; bottom: 1px; right: 1px;
            width: 10px; height: 10px; border-radius: 50%; border: 2px solid #162232;
        }
        .online-dot.online { background: #27ae60; }
        .online-dot.offline { background: #4A5568; }
        .contact-info { flex: 1; min-width: 0; }
        .contact-name { font-size: 14px; font-weight: 600; color: white; }
        .contact-role { font-size: 11px; color: #8899AA; margin-top: 2px; }
        .unread-badge {
            background: #E8895A; color: white; border-radius: 50%;
            width: 20px; height: 20px; font-size: 11px; font-weight: 700;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .chat-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .chat-header {
            padding: 16px 24px; background: #162232;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            display: flex; align-items: center; gap: 14px; flex-shrink: 0;
        }
        .chat-header .avatar {
            width: 44px; height: 44px; border-radius: 50%;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700; color: white;
        }
        .chat-header-info { flex: 1; }
        .chat-header-info h3 { font-size: 16px; font-weight: 700; color: white; }
        .chat-header-info p { font-size: 12px; margin-top: 2px; }
        .status-online { color: #27ae60; }
        .status-offline { color: #4A5568; }
        .chat-header-actions { display: flex; gap: 8px; align-items: center; }
        
        
        .btn-delete-conv {
            padding: 8px 14px; background: rgba(231,76,60,0.1); color: #e74c3c;
            border: 1px solid rgba(231,76,60,0.2); border-radius: 8px;
            font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s;
        }
        .btn-delete-conv:hover { background: rgba(231,76,60,0.2); }
        .messages-area { flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 12px; }
        .messages-area::-webkit-scrollbar { width: 4px; }
        .messages-area::-webkit-scrollbar-track { background: transparent; }
        .messages-area::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
        .message-bubble { display: flex; gap: 10px; max-width: 70%; position: relative; }
        .message-bubble.sent { margin-left: auto; flex-direction: row-reverse; }
        .bubble-avatar {
            width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, #4A6FA5, #E8895A);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700; color: white;
        }
        .bubble-content { display: flex; flex-direction: column; gap: 4px; }
        .bubble-text {
            padding: 12px 16px; border-radius: 16px; font-size: 14px; line-height: 1.5;
            background: rgba(255,255,255,0.05); color: white;
            border: 1px solid rgba(255,255,255,0.08); position: relative;
        }
        .message-bubble.sent .bubble-text { background: #E8895A; color: white; border-color: #E8895A; }
        .bubble-time { font-size: 11px; color: #4A5568; display: flex; align-items: center; gap: 6px; }
        .message-bubble.sent .bubble-time { text-align: right; justify-content: flex-end; }
        .msg-actions {
            display: none; position: absolute; top: -34px; right: 0;
            background: #1A2B3C; border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px; padding: 4px; gap: 4px; z-index: 10;
        }
        .message-bubble:hover .msg-actions { display: flex; }
        .msg-actions button {
            background: none; border: none; color: #8899AA; cursor: pointer;
            padding: 4px 8px; border-radius: 4px; font-size: 12px; transition: all 0.2s;
        }
        .msg-actions button:hover { background: rgba(255,255,255,0.1); color: white; }
        .msg-modified { font-size: 10px; color: #4A5568; font-style: italic; }
        .empty-chat {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center; color: #4A5568;
        }
        .empty-chat .icon { font-size: 64px; margin-bottom: 16px; opacity: 0.3; }
        .empty-chat p { font-size: 16px; }
        .chat-input-area {
            padding: 16px 24px; background: #162232;
            border-top: 1px solid rgba(255,255,255,0.05); flex-shrink: 0;
        }
        .input-row { display: flex; gap: 12px; align-items: center; }
        .msg-input {
            flex: 1; padding: 14px 18px; background: rgba(255,255,255,0.05);
            border: 1.5px solid rgba(255,255,255,0.08); border-radius: 12px;
            color: white; font-size: 14px; outline: none; transition: border-color 0.2s;
            resize: none; height: 50px; font-family: inherit;
        }
        .msg-input::placeholder { color: #4A5568; }
        .msg-input:focus { border-color: #E8895A; }
        .btn-send {
            width: 50px; height: 50px; background: #E8895A; border: none;
            border-radius: 12px; cursor: pointer; display: flex;
            align-items: center; justify-content: center; font-size: 20px;
            transition: all 0.2s; flex-shrink: 0;
        }
        .btn-send:hover { background: #d4784a; transform: scale(1.05); }
        .btn-send:disabled { background: #4A5568; cursor: not-allowed; transform: none; }
        .no-contact-selected {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center; color: #4A5568;
        }
        .no-contact-selected .icon { font-size: 80px; margin-bottom: 20px; opacity: 0.2; }
        .no-contact-selected h3 { font-size: 20px; color: #8899AA; margin-bottom: 8px; }
        .no-contact-selected p { font-size: 14px; }
        .edit-modal {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7); z-index: 100;
            align-items: center; justify-content: center;
        }
        .edit-modal.show { display: flex; }
        .edit-modal-box {
            background: #162232; border-radius: 16px; padding: 24px;
            max-width: 400px; width: 90%; border: 1px solid rgba(255,255,255,0.1);
        }
        .edit-modal-box h3 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 16px; }
        .edit-input {
            width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.05);
            border: 1.5px solid rgba(255,255,255,0.08); border-radius: 10px;
            color: white; font-size: 14px; outline: none; margin-bottom: 16px;
        }
        .edit-input:focus { border-color: #E8895A; }
        .edit-btns { display: flex; gap: 10px; }
        .btn-edit-save {
            flex: 1; padding: 10px; background: #E8895A; color: white;
            border: none; border-radius: 8px; font-weight: 600; cursor: pointer;
        }
        .btn-edit-cancel {
            flex: 1; padding: 10px; background: rgba(255,255,255,0.05); color: #8899AA;
            border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; cursor: pointer;
        }

        /* Notification */
        .notif-popup {
            position: fixed; bottom: 24px; right: 24px; z-index: 999;
            background: #162232; border: 1px solid rgba(232,137,90,0.3);
            border-radius: 14px; padding: 16px 20px; max-width: 300px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            display: flex; align-items: center; gap: 14px;
            animation: slideInRight 0.3s ease;
        }
        .notif-avatar {
            width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; color: white;
        }
        .notif-content { flex: 1; min-width: 0; }
        .notif-name { font-size: 13px; font-weight: 700; color: white; }
        .notif-msg { font-size: 12px; color: #8899AA; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }
    </style>
</head>
<body>

<div class="edit-modal" id="editModal">
    <div class="edit-modal-box">
        <h3>✏️ Modifier le message</h3>
        <input type="text" class="edit-input" id="editInput" placeholder="Nouveau message...">
        <div class="edit-btns">
            <button class="btn-edit-save" onclick="saveEdit()">💾 Enregistrer</button>
            <button class="btn-edit-cancel" onclick="closeEdit()">Annuler</button>
        </div>
    </div>
</div>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span> · Messagerie</div>
    <div class="navbar-right">
        {% if app.user.role == 'Patient' %}
            <a href="{{ path('patient_dashboard') }}" class="btn-back">← Retour</a>
        {% elseif app.user.role == 'Coach' %}
            <a href="{{ path('coach_dashboard') }}" class="btn-back">← Retour</a>
        {% endif %}
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪</a>
    </div>
</nav>

<div class="chat-container">
    <div class="sidebar">
        <div class="sidebar-header">
            <h3>💬 Messages
                {% if unreadCount > 0 %}
                    <span style="background:#E8895A;color:white;border-radius:20px;padding:2px 8px;font-size:12px;margin-left:8px;">{{ unreadCount }}</span>
                {% endif %}
            </h3>
            <input type="text" class="search-box" placeholder="🔍 Rechercher..." id="searchContact">
        </div>
        <div class="contacts-list" id="contactsList">
            {% for c in contacts %}
            <a href="{{ path('messagerie_conversation', {id: c.id}) }}"
               class="contact-item {% if contact is defined and contact.id == c.id %}active{% endif %}"
               id="contact-{{ c.id }}">
                <div class="contact-avatar">
                    {{ c.prenom|slice(0,1)|upper }}
                    <span class="online-dot offline" id="dot-{{ c.id }}"></span>
                </div>
                <div class="contact-info">
                    <div class="contact-name">{{ c.prenom }} {{ c.nom }}</div>
                    <div class="contact-role">
                        {% if c.role == 'Coach' %}🏋️ Coach{% elseif c.role == 'Patient' %}🌿 Patient{% else %}👑 Admin{% endif %}
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>

    <div class="chat-area">
        {% if contact is defined and contact %}

        <div class="chat-header">
            <div class="avatar">{{ contact.prenom|slice(0,1)|upper }}</div>
            <div class="chat-header-info">
                <h3>{{ contact.prenom }} {{ contact.nom }}</h3>
                <p id="contactStatus" class="status-offline">● Hors ligne</p>
            </div>
            <div class="chat-header-actions">
                <button class="btn-delete-conv" onclick="deleteConversation()">🗑️</button>
            </div>
        </div>

        <div class="messages-area" id="messagesArea">
            {% if messages is defined and messages|length > 0 %}
                {% for msg in messages %}
                <div class="message-bubble {% if msg.expediteur.id == currentUser.id %}sent{% endif %}"
                     id="msg-{{ msg.id }}"
                     data-id="{{ msg.id }}"
                     data-own="{{ msg.expediteur.id == currentUser.id ? 'true' : 'false' }}">
                    {% if msg.expediteur.id == currentUser.id %}
                    <div class="msg-actions">
                        <button onclick="editMsg({{ msg.id }}, '{{ msg.contenu|e('js') }}')">✏️</button>
                        <button onclick="deleteMsg({{ msg.id }})">🗑️</button>
                    </div>
                    {% endif %}
                    <div class="bubble-avatar">{{ msg.expediteur.prenom|slice(0,1)|upper }}</div>
                    <div class="bubble-content">
                        <div class="bubble-text" id="text-{{ msg.id }}">{{ msg.contenu }}</div>
                        <div class="bubble-time">
                            {{ msg.dateEnvoi ? msg.dateEnvoi|date('H:i') : '' }}
                            {% if msg.modifie %}<span class="msg-modified">(modifie)</span>{% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="empty-chat" id="emptyChat">
                    <div class="icon">💬</div>
                    <p>Commencez la conversation !</p>
                </div>
            {% endif %}
        </div>

        <div class="chat-input-area">
            <div class="input-row">
                <textarea class="msg-input" id="msgInput"
                    placeholder="Ecrivez votre message..."
                    rows="1"></textarea>
                <button class="btn-send" id="sendBtn" type="button">➤</button>
            </div>
        </div>

        {% else %}

        <div class="no-contact-selected">
            <div class="icon">💬</div>
            <h3>Votre messagerie</h3>
            <p>Selectionnez un contact pour commencer</p>
        </div>

        {% endif %}
    </div>
</div>

<script>
const contactId      = {{ contact is defined and contact ? contact.id : 'null' }};
const currentUserId  = {{ currentUser.id }};
const contactInitial = '{{ contact is defined and contact ? contact.prenom|slice(0,1)|upper : "?" }}';
const contactName    = '{{ contact is defined and contact ? contact.prenom ~ " " ~ contact.nom : "" }}';
const myInitial      = '{{ currentUser.prenom|slice(0,1)|upper }}';

let isSending    = false;
let lastMsgId    = {{ messages is defined and messages|length > 0 ? messages|last.id : 0 }};
let editingMsgId = null;

// Demande permission notifications
if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
}

function scrollToBottom() {
    const area = document.getElementById('messagesArea');
    if (area) area.scrollTop = area.scrollHeight;
}
scrollToBottom();

async function sendMessage() {
    if (isSending) return;
    const input   = document.getElementById('msgInput');
    const contenu = input.value.trim();
    if (!contenu || !contactId) return;

    isSending = true;
    document.getElementById('sendBtn').disabled = true;

    try {
        const formData = new FormData();
        formData.append('contenu', contenu);

        const res  = await fetch(`/messagerie/${contactId}/send`, { method: 'POST', body: formData });
        const data = await res.json();

        if (data.success) {
            input.value = '';
            appendMessage(data);
            lastMsgId = data.id;
            scrollToBottom();
        } else if (data.banned) {
            showBanAlert(data.message);
        } else if (data.warning) {
            input.value = '';
            showWarning(data.message, data.count);
        }
    } catch(e) {}

    isSending = false;
    document.getElementById('sendBtn').disabled = false;
}

function showWarning(message, count) {
    const colors = ['', '#f39c12', '#E8895A', '#e74c3c'];
    const color  = colors[count] || '#e74c3c';
    const warn   = document.createElement('div');
    warn.style.cssText = `
        position:fixed; top:20px; right:20px; z-index:999;
        background:#1A2B3C; border:2px solid ${color};
        border-radius:14px; padding:20px 24px; max-width:320px;
        box-shadow:0 10px 30px rgba(0,0,0,0.4);
        animation: slideIn 0.3s ease;
    `;
    warn.innerHTML = `
        <p style="color:${color};font-weight:700;font-size:15px;margin-bottom:8px;">⚠️ Avertissement ${count}/3</p>
        <p style="color:#8899AA;font-size:13px;line-height:1.5;">${message}</p>
        <div style="margin-top:12px;height:4px;background:rgba(255,255,255,0.1);border-radius:2px;">
            <div style="height:100%;width:${(count/3)*100}%;background:${color};border-radius:2px;"></div>
        </div>
    `;
    document.body.appendChild(warn);
    setTimeout(() => warn.remove(), 4000);
}

function showBanAlert(message) {
    document.body.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#0D1B2A;">
            <div style="background:#162232;border-radius:20px;padding:50px 40px;max-width:480px;text-align:center;border:2px solid #e74c3c;">
                <div style="font-size:80px;margin-bottom:20px;">🚫</div>
                <h2 style="color:#e74c3c;font-size:24px;margin-bottom:16px;">Compte Banni</h2>
                <p style="color:#8899AA;font-size:15px;line-height:1.6;margin-bottom:24px;">${message}</p>
                <a href="/logout" style="display:inline-block;padding:14px 32px;background:#e74c3c;color:white;border-radius:10px;text-decoration:none;font-weight:700;">
                    Se deconnecter
                </a>
            </div>
        </div>
    `;
}

function showNotification(msg) {
    // Notification navigateur
    if ('Notification' in window && Notification.permission === 'granted') {
        new Notification('💬 ' + contactName, {
            body: msg.contenu,
            icon: '/favicon.ico',
        });
    }

    // Popup dans l'app
    const notif = document.createElement('div');
    notif.className = 'notif-popup';
    notif.innerHTML = `
        <div class="notif-avatar">${contactInitial}</div>
        <div class="notif-content">
            <div class="notif-name">${contactName}</div>
            <div class="notif-msg">${msg.contenu}</div>
        </div>
    `;
    document.body.appendChild(notif);
    setTimeout(() => notif.remove(), 4000);
}

function appendMessage(data) {
    const area   = document.getElementById('messagesArea');
    const isSent = data.expediteurId == currentUserId;
    const empty  = area.querySelector('.empty-chat');
    if (empty) empty.remove();
    if (document.getElementById(`msg-${data.id}`)) return;

    const div = document.createElement('div');
    div.className = `message-bubble ${isSent ? 'sent' : ''}`;
    div.id = `msg-${data.id}`;
    div.dataset.id  = data.id;
    div.dataset.own = isSent ? 'true' : 'false';
    div.innerHTML = `
        ${isSent ? `<div class="msg-actions">
            <button onclick="editMsg(${data.id}, document.getElementById('text-${data.id}').textContent.trim())">✏️</button>
            <button onclick="deleteMsg(${data.id})">🗑️</button>
        </div>` : ''}
        <div class="bubble-avatar">${isSent ? myInitial : contactInitial}</div>
        <div class="bubble-content">
            <div class="bubble-text" id="text-${data.id}">${data.contenu}</div>
            <div class="bubble-time">${data.dateEnvoi}</div>
        </div>
    `;
    area.appendChild(div);
}

function editMsg(id, contenu) {
    editingMsgId = id;
    document.getElementById('editInput').value = contenu;
    document.getElementById('editModal').classList.add('show');
}

function closeEdit() {
    editingMsgId = null;
    document.getElementById('editModal').classList.remove('show');
}

async function saveEdit() {
    if (!editingMsgId) return;
    const newContenu = document.getElementById('editInput').value.trim();
    if (!newContenu) return;

    const res  = await fetch(`/messagerie/msg/${editingMsgId}/edit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contenu: newContenu })
    });
    const data = await res.json();

    if (data.success) {
        const textEl = document.getElementById(`text-${editingMsgId}`);
        if (textEl) textEl.textContent = newContenu;
        closeEdit();
    } else if (data.warning) {
        closeEdit();
        showWarning(data.message, 1);
    }
}

async function deleteMsg(id) {
    if (!confirm('Supprimer ce message ?')) return;
    const res  = await fetch(`/messagerie/msg/${id}/delete`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
        const el = document.getElementById(`msg-${id}`);
        if (el) el.remove();
    }
}

async function deleteConversation() {
    if (!confirm('Supprimer toute la conversation de votre cote ?')) return;
    const res  = await fetch(`/messagerie/${contactId}/delete-conversation`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
        document.getElementById('messagesArea').innerHTML = `
            <div class="empty-chat">
                <div class="icon">💬</div>
                <p>Conversation supprimee.</p>
            </div>
        `;
        lastMsgId = 0;
    }
}

document.getElementById('msgInput')?.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
    }
});

document.getElementById('sendBtn')?.addEventListener('click', sendMessage);

if (contactId) {
    // Auto refresh messages + notifications
    setInterval(async () => {
        try {
            const res  = await fetch(`/messagerie/${contactId}/messages`);
            const msgs = await res.json();
            msgs.forEach(msg => {
                if (msg.id > lastMsgId) {
                    appendMessage({
                        id: msg.id,
                        contenu: msg.contenu,
                        dateEnvoi: msg.dateEnvoi,
                        expediteurId: msg.expediteurId,
                    });

                    // Notification si message reçu (pas envoyé par moi)
                    if (msg.expediteurId != currentUserId) {
                        showNotification(msg);
                    }

                    lastMsgId = msg.id;
                    scrollToBottom();
                }
            });
        } catch(e) {}
    }, 3000);

    // Statut en ligne
    setInterval(async () => {
        try {
            const res  = await fetch(`/messagerie/${contactId}/status`);
            const data = await res.json();
            const statusEl = document.getElementById('contactStatus');
            const dotEl    = document.getElementById(`dot-${contactId}`);
            if (data.online) {
                if (statusEl) { statusEl.textContent = '● En ligne'; statusEl.className = 'status-online'; }
                if (dotEl)    { dotEl.className = 'online-dot online'; }
            } else {
                if (statusEl) { statusEl.textContent = '● Hors ligne'; statusEl.className = 'status-offline'; }
                if (dotEl)    { dotEl.className = 'online-dot offline'; }
            }
        } catch(e) {}
    }, 5000);
}

document.getElementById('searchContact')?.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.contact-item').forEach(item => {
        item.style.display = item.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
</script>

</body>
</html>