<style>
/* ========================================
   GLOBAL FORUM MODAL
   ======================================== */
.global-forum-sidebar {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -46%) scale(0.94);
    width: 420px;
    max-width: calc(100vw - 2rem);
    max-height: 85vh;
    background: rgba(13, 27, 42, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(255, 255, 255, 0.04);
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.25s;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    font-family: 'Inter', 'Segoe UI', sans-serif;
    color: white;
    overflow-y: auto;
}

.global-forum-sidebar.open {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
}

.global-forum-sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.55);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
}

.global-forum-sidebar-overlay.show {
    opacity: 1;
    visibility: visible;
}

/* ── Header ── */
.gfs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
}

.gfs-header h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
}

.gfs-close {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.07);
    color: #8899AA;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
}

.gfs-close:hover {
    background: rgba(231, 76, 60, 0.15);
    border-color: rgba(231, 76, 60, 0.25);
    color: #e74c3c;
}

/* ── Nav items ── */
.gfs-nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}

.gfs-nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    color: #CBD5E0;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
}

.gfs-nav-item:hover {
    background: rgba(232, 137, 90, 0.1);
    border-color: rgba(232, 137, 90, 0.3);
    color: #E8895A;
    transform: translateX(3px);
}

.gfs-nav-item.admin-link {
    background: rgba(245, 158, 11, 0.05);
    border-color: rgba(245, 158, 11, 0.15);
    color: #fbbf24;
    position: relative;
    overflow: hidden;
}

.gfs-nav-item.admin-link::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 3px; height: 100%;
    background: #fbbf24;
}

.gfs-nav-item.admin-link:hover {
    background: rgba(245, 158, 11, 0.15);
    border-color: rgba(245, 158, 11, 0.3);
    color: #fbbf24;
}

.gfs-nav-item.admin-link-disabled {
    opacity: 0.45;
    pointer-events: none;
    cursor: not-allowed;
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.03);
    color: #8899AA;
}

/* ── Section label ── */
.gfs-section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: #8899AA;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 0.75rem 0.25rem 0.25rem;
}

/* ── Badge ── */
.gfs-badge {
    margin-left: auto;
    font-size: 0.68rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
}

/* ── Floating toggle button ── */
.gfs-toggle-btn {
    position: fixed;
    bottom: 110px;
    right: 30px;
    width: 56px;
    height: 56px;
    background: var(--card-bg, rgba(22, 34, 50, 0.95));
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-color, rgba(255,255,255,0.1));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main, #e2e8f0);
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    z-index: 9997;
    transition: all 0.25s ease;
}

.gfs-toggle-btn:hover {
    background: var(--primary-color, #6096ba);
    border-color: var(--primary-color, #6096ba);
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(96, 150, 186, 0.35);
}
</style>

<!-- Toggle Button -->
<button class="gfs-toggle-btn" id="gfsToggleBtn" title="Community Forum">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
</button>

<!-- Overlay -->
<div class="global-forum-sidebar-overlay" id="gfsOverlay"></div>

<!-- Modal -->
<div class="global-forum-sidebar" id="gfsSidebar" role="dialog" aria-modal="true" aria-label="Community Forum Menu">
    <div class="gfs-header">
        <h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#E8895A;">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            Community
        </h3>
        <button class="gfs-close" id="gfsCloseBtn" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <div class="gfs-nav">
        <a href="{{ path('app_post_index') }}" class="gfs-nav-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            Community Feed
        </a>
        <a href="{{ path('app_category_index') }}" class="gfs-nav-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
            Categories
        </a>
        <a href="{{ path('app_post_new') }}" class="gfs-nav-item" style="border-style: dashed; justify-content: center; color: #E8895A; border-color: rgba(232,137,90,0.3);">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Create Post
        </a>

        <div class="gfs-section-label">Admin Space</div>

        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_forum') }}" class="gfs-nav-item admin-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                Forum Admin
                <span class="gfs-badge" style="background:rgba(245,158,11,0.2);color:#fbbf24;">Admin</span>
            </a>
        {% else %}
            <div class="gfs-nav-item admin-link-disabled" title="Administrator access required">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                Forum Admin
                <span class="gfs-badge">Locked</span>
            </div>
        {% endif %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const modal   = document.getElementById('gfsSidebar');
    const overlay = document.getElementById('gfsOverlay');
    const toggleBtn = document.getElementById('gfsToggleBtn');
    const closeBtn  = document.getElementById('gfsCloseBtn');

    function openModal() {
        modal.classList.add('open');
        overlay.classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        modal.classList.remove('open');
        overlay.classList.remove('show');
        document.body.style.overflow = '';
    }

    if (toggleBtn) toggleBtn.addEventListener('click', openModal);
    if (closeBtn)  closeBtn.addEventListener('click', closeModal);
    if (overlay)   overlay.addEventListener('click', closeModal);

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });
});
</script>
