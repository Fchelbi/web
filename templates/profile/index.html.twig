<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Mon Profil · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0D1B2A; min-height: 100vh; color: white; }
        .navbar {
            background: #162232; padding: 0 60px; height: 70px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: white; }
        .navbar-logo span { color: #E8895A; }
        .navbar-links { display: flex; gap: 32px; }
        .navbar-links a {
            color: #8899AA; text-decoration: none; font-size: 14px;
            font-weight: 500; transition: color 0.2s; position: relative;
        }
        .navbar-links a::after {
            content: ''; position: absolute; bottom: -4px; left: 0;
            width: 0; height: 2px; background: #E8895A; transition: width 0.3s;
        }
        .navbar-links a:hover { color: white; }
        .navbar-links a:hover::after, .navbar-links a.active::after { width: 100%; }
        .navbar-links a.active { color: white; font-weight: 600; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 10px;
            background: rgba(255,255,255,0.05); padding: 8px 16px;
            border-radius: 30px; border: 1px solid rgba(255,255,255,0.08);
        }
        .user-pill .avatar {
            width: 32px; height: 32px; background: #E8895A;
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; color: white; font-size: 14px; font-weight: 700;
        }
        .user-pill span { font-size: 13px; color: #CBD5E0; font-weight: 600; }
        .btn-back {
            padding: 8px 18px; background: rgba(255,255,255,0.05); color: #8899AA;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(255,255,255,0.05); transition: all 0.2s;
        }
        .btn-back:hover { background: rgba(232,137,90,0.15); color: #E8895A; }
        .btn-logout {
            padding: 8px 18px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(231,76,60,0.2);
        }
        .content { padding: 40px 60px; max-width: 900px; margin: 0 auto; }
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 24px; font-weight: 700; color: white; }
        .page-header p { font-size: 14px; color: #8899AA; margin-top: 4px; }
        .alert-success {
            background: rgba(39,174,96,0.1); color: #27ae60;
            border: 1px solid rgba(39,174,96,0.2);
            padding: 14px 20px; border-radius: 10px; font-size: 14px; margin-bottom: 20px;
        }
        .alert-error {
            background: rgba(231,76,60,0.1); color: #e74c3c;
            border: 1px solid rgba(231,76,60,0.2);
            padding: 14px 20px; border-radius: 10px; font-size: 14px; margin-bottom: 20px;
        }
        .grid-2 { display: grid; grid-template-columns: 1fr 2fr; gap: 24px; }
        .profile-card {
            background: #162232; border-radius: 16px; padding: 28px; text-align: center;
            border: 1px solid rgba(255,255,255,0.05); height: fit-content;
        }
        .profile-avatar {
            width: 90px; height: 90px;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 36px; margin: 0 auto 16px;
        }
        .profile-card h3 { font-size: 18px; font-weight: 700; color: white; }
        .profile-card p { font-size: 13px; color: #8899AA; margin-top: 4px; }
        .profile-badge {
            display: inline-block; margin-top: 10px;
            background: rgba(39,174,96,0.15); color: #27ae60;
            border: 1px solid rgba(39,174,96,0.3);
            padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
        }
        .profile-info { margin-top: 20px; text-align: left; }
        .info-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 13px;
        }
        .info-item:last-child { border-bottom: none; }
        .info-item .lbl { color: #8899AA; flex: 1; }
        .info-item .val { color: white; font-weight: 600; font-size: 12px; }
        .form-card {
            background: #162232; border-radius: 16px; padding: 28px;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .form-card h3 { font-size: 16px; font-weight: 700; color: white; margin-bottom: 20px; }
        .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .field-group { display: flex; flex-direction: column; margin-bottom: 16px; }
        .field-label {
            font-size: 11px; font-weight: 700; color: #8899AA;
            letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px;
        }
        input {
            padding: 12px 16px; border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 10px; background: rgba(255,255,255,0.05);
            font-size: 14px; color: white; outline: none;
            transition: border-color 0.2s; width: 100%;
        }
        input::placeholder { color: #4A5568; }
        input:focus { border-color: #E8895A; background: rgba(232,137,90,0.05); }
        input:disabled { opacity: 0.4; cursor: not-allowed; }
        .password-wrapper { position: relative; }
        .password-wrapper input { padding-right: 44px; }
        .toggle-pw {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%); cursor: pointer; font-size: 16px;
        }
        .divider { border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 20px 0; }
        .btn-save {
            width: 100%; padding: 14px; background: #E8895A; color: white;
            border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
            cursor: pointer; transition: all 0.2s; margin-top: 8px;
        }
        .btn-save:hover { background: #d4784a; transform: translateY(-1px); box-shadow: 0 6px 16px rgba(232,137,90,0.3); }
        .hint { font-size: 11px; color: #4A5568; margin-top: 4px; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span></div>
    <div class="navbar-links">
        <a href="{{ path('patient_dashboard') }}">Accueil</a>
        <a href="#">Mes seances</a>
        <a href="#">Messages</a>
        <a href="{{ path('patient_bien_etre') }}">Bien-etre</a>
        <a href="{{ path('app_post_index') }}">Forum</a>
        <a href="{{ path('patient_profile') }}" class="active">Mon profil</a>
    </div>
    <div class="navbar-right">
        <a href="{{ path('patient_dashboard') }}" class="btn-back">← Retour</a>
        <div class="user-pill">
            <div class="avatar">{{ app.user.prenom|slice(0,1)|upper }}</div>
            <span>{{ app.user.prenom }}</span>
        </div>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪</a>
    </div>
</nav>

<div class="content">
    <div class="page-header">
        <h2>👤 Mon Profil</h2>
        <p>Gerez vos informations personnelles</p>
    </div>

    {% if success is defined and success %}
        <div class="alert-success">✅ {{ success }}</div>
    {% endif %}
    {% if error is defined and error %}
        <div class="alert-error">❌ {{ error }}</div>
    {% endif %}

    <div class="grid-2">
        <div class="profile-card">
            <div class="profile-avatar">🌿</div>
            <h3>{{ user.prenom }} {{ user.nom }}</h3>
            <p>{{ user.email }}</p>
            <span class="profile-badge">✅ Compte verifie</span>
            <div class="profile-info">
                <div class="info-item">
                    <span class="lbl">📧 Email</span>
                    <span class="val">{{ user.email }}</span>
                </div>
                <div class="info-item">
                    <span class="lbl">📞 Tel</span>
                    <span class="val">{{ user.numTel ?? '—' }}</span>
                </div>
                <div class="info-item">
                    <span class="lbl">🌿 Role</span>
                    <span class="val">Patient</span>
                </div>
            </div>
        </div>

        <div class="form-card">
            <h3>✏️ Modifier mes informations</h3>
            <form method="post" novalidate>
                <div class="row-2">
                    <div class="field-group">
                        <label class="field-label">Nom</label>
                        <input type="text" name="nom" value="{{ user.nom }}" required>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Prenom</label>
                        <input type="text" name="prenom" value="{{ user.prenom }}" required>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <input type="email" value="{{ user.email }}" disabled>
                </div>
                <div class="field-group">
                    <label class="field-label">Telephone</label>
                    <input type="text" name="num_tel" value="{{ user.numTel ?? '' }}">
                </div>

                <hr class="divider">
                <h3 style="color:white;font-size:15px;font-weight:700;margin-bottom:16px;">🔐 Changer le mot de passe</h3>

                <div class="row-2">
                    <div class="field-group">
                        <label class="field-label">Nouveau mot de passe</label>
                        <div class="password-wrapper">
                            <input type="password" name="password" id="pw" placeholder="••••••••">
                            <span class="toggle-pw" onclick="togglePw('pw',this)">👁️</span>
                        </div>
                        <span class="hint">Laisser vide pour ne pas changer</span>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Confirmer</label>
                        <div class="password-wrapper">
                            <input type="password" name="confirm_password" id="cpw" placeholder="••••••••">
                            <span class="toggle-pw" onclick="togglePw('cpw',this)">👁️</span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-save">💾 Enregistrer les modifications</button>
            </form>
        </div>
    </div>
</div>

<script>
function togglePw(id, el) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
    el.textContent = input.type === 'password' ? '👁️' : '🙈';
}
</script>
</body>
</html>
