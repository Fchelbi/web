<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Mon Profil · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #F0E6D8; }
        .navbar {
            background: white; padding: 0 60px;
            display: flex; justify-content: space-between; align-items: center;
            height: 70px; box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: #4A6FA5; }
        .navbar-logo span { color: #E8895A; }
        .navbar-links { display: flex; gap: 32px; }
        .navbar-links a {
            color: #555; text-decoration: none; font-size: 14px;
            font-weight: 500; transition: color 0.2s;
        }
        .navbar-links a:hover, .navbar-links a.active { color: #4A6FA5; font-weight: 600; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-pill {
            display: flex; align-items: center; gap: 10px;
            background: #F5EFE6; padding: 8px 16px; border-radius: 30px;
        }
        .user-pill .avatar {
            width: 32px; height: 32px; background: #4A6FA5;
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; color: white; font-size: 14px; font-weight: 700;
        }
        .user-pill span { font-size: 13px; color: #2C3E50; font-weight: 600; }
        .btn-logout {
            padding: 8px 18px; background: #E8895A; color: white;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
        }
        .btn-logout:hover { background: #d4784a; }
        .back-btn {
            padding: 8px 18px; background: #4A6FA5; color: white;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
        }

        .content { padding: 40px 60px; max-width: 900px; margin: 0 auto; }
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 24px; font-weight: 700; color: #2C3E50; }
        .page-header p { font-size: 14px; color: #999; margin-top: 4px; }

        .success-msg {
            background: #d8fde8; color: #27ae60;
            padding: 14px 20px; border-radius: 10px;
            font-size: 14px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
        }
        .error-msg {
            background: #ffe0e0; color: #c0392b;
            padding: 14px 20px; border-radius: 10px;
            font-size: 14px; margin-bottom: 20px;
        }

        .grid-2 { display: grid; grid-template-columns: 1fr 2fr; gap: 24px; }

        .profile-card {
            background: white; border-radius: 16px;
            padding: 28px; text-align: center;
            box-shadow: 0 2px 15px rgba(0,0,0,0.06);
            height: fit-content;
        }
        .profile-avatar {
            width: 90px; height: 90px;
            background: linear-gradient(135deg, #4A6FA5, #E8895A);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 36px;
            margin: 0 auto 16px;
        }
        .profile-card h3 { font-size: 18px; font-weight: 700; color: #2C3E50; }
        .profile-card p { font-size: 13px; color: #999; margin-top: 4px; }
        .profile-badge {
            display: inline-block; margin-top: 10px;
            background: #d8fde8; color: #27ae60;
            padding: 4px 14px; border-radius: 20px;
            font-size: 12px; font-weight: 600;
        }
        .profile-info { margin-top: 20px; text-align: left; }
        .info-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 0; border-bottom: 1px solid #F5EFE6;
            font-size: 13px;
        }
        .info-item:last-child { border-bottom: none; }
        .info-item .lbl { color: #999; flex: 1; }
        .info-item .val { color: #2C3E50; font-weight: 600; font-size: 12px; }

        .form-card {
            background: white; border-radius: 16px;
            padding: 28px; box-shadow: 0 2px 15px rgba(0,0,0,0.06);
        }
        .form-card h3 { font-size: 16px; font-weight: 700; color: #2C3E50; margin-bottom: 20px; }
        .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .field-group { display: flex; flex-direction: column; margin-bottom: 16px; }
        .field-label {
            font-size: 11px; font-weight: 700; color: #4A6FA5;
            letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px;
        }
        input {
            padding: 12px 16px; border: 1.5px solid #E8E0D5;
            border-radius: 10px; background: #F5EFE6;
            font-size: 14px; color: #333; outline: none;
            transition: border-color 0.2s; width: 100%;
        }
        input:focus { border-color: #4A6FA5; background: white; }
        input[disabled] { opacity: 0.6; cursor: not-allowed; }
        .password-wrapper { position: relative; }
        .password-wrapper input { padding-right: 44px; }
        .toggle-pw {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%); cursor: pointer; font-size: 16px;
        }
        .divider {
            border: none; border-top: 1px solid #F0EAE0;
            margin: 20px 0;
        }
        .btn-save {
            width: 100%; padding: 14px; background: #E8895A;
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            transition: background 0.2s; margin-top: 8px;
        }
        .btn-save:hover { background: #d4784a; }
        .hint { font-size: 11px; color: #aaa; margin-top: 4px; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span></div>
    <div class="navbar-links">
        <a href="{{ path('patient_dashboard') }}">Accueil</a>
        <a href="#">Mes séances</a>
        <a href="#">Messages</a>
        <a href="#">Rapports</a>
    </div>
    <div class="navbar-right">
        <a href="{{ path('patient_dashboard') }}" class="back-btn">← Retour</a>
        <div class="user-pill">
            <div class="avatar">{{ app.user.prenom|slice(0,1)|upper }}</div>
            <span>{{ app.user.prenom }}</span>
        </div>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪</a>
    </div>
</nav>

<div class="content">
    <div class="page-header">
        <h2>👤 Mon Profil</h2>
        <p>Gérez vos informations personnelles</p>
    </div>

    {% if success %}
        <div class="success-msg">✅ {{ success }}</div>
    {% endif %}
    {% if error %}
        <div class="error-msg">❌ {{ error }}</div>
    {% endif %}

    <div class="grid-2">
        <!-- Carte profil -->
        <div class="profile-card">
            <div class="profile-avatar">🌿</div>
            <h3>{{ user.prenom }} {{ user.nom }}</h3>
            <p>{{ user.email }}</p>
            <span class="profile-badge">✅ Compte vérifié</span>
            <div class="profile-info">
                <div class="info-item">
                    <span class="lbl">📧 Email</span>
                    <span class="val">{{ user.email }}</span>
                </div>
                <div class="info-item">
                    <span class="lbl">📞 Téléphone</span>
                    <span class="val">{{ user.numTel ?? '—' }}</span>
                </div>
                <div class="info-item">
                    <span class="lbl">🌿 Rôle</span>
                    <span class="val">Patient</span>
                </div>
            </div>
        </div>

        <!-- Formulaire -->
        <div class="form-card">
            <h3>✏️ Modifier mes informations</h3>
            <form method="post" novalidate>
                <div class="row-2">
                    <div class="field-group">
                        <label class="field-label">Nom</label>
                        <input type="text" name="nom" value="{{ user.nom }}" required>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Prénom</label>
                        <input type="text" name="prenom" value="{{ user.prenom }}" required>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <input type="email" value="{{ user.email }}" disabled>
                </div>
                <div class="field-group">
                    <label class="field-label">Téléphone</label>
                    <input type="text" name="num_tel" value="{{ user.numTel }}">
                </div>

                <hr class="divider">
                <h3>🔐 Changer le mot de passe</h3>

                <div class="row-2">
                    <div class="field-group">
                        <label class="field-label">Nouveau mot de passe</label>
                        <div class="password-wrapper">
                            <input type="password" name="password" id="pw" placeholder="••••••••">
                            <span class="toggle-pw" onclick="togglePw('pw',this)">👁️</span>
                        </div>
                        <span class="hint">Laisser vide pour ne pas changer</span>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Confirmer</label>
                        <div class="password-wrapper">
                            <input type="password" name="confirm_password" id="cpw" placeholder="••••••••">
                            <span class="toggle-pw" onclick="togglePw('cpw',this)">👁️</span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-save">💾 Enregistrer les modifications</button>
            </form>
        </div>
    </div>
</div>

<script>
function togglePw(id, el) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
    el.textContent = input.type === 'password' ? '👁️' : '🙈';
}
</script>
</body>
</html>