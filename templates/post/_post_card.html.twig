<div class="post-card glassmorphism" data-post-id="{{ post.id }}">
    <div class="post-header">
        <div class="user-info">
            {% if post.user.photo %}
                <img src="{{ post.user.photo }}" alt="Avatar" class="avatar">
            {% else %}
                <div class="avatar-placeholder">{{ post.user.prenom|slice(0,1) }}{{ post.user.nom|slice(0,1) }}</div>
            {% endif %}
            <div class="user-details">
                <span class="user-name">{{ post.user.prenom }} {{ post.user.nom }}</span>
                <span class="post-date">{{ post.createdAt ? post.createdAt|date('M j, Y \\a\\t g:i A') : '' }}</span>
            </div>
        </div>
        {% if post.category %}
            <span class="category-badge">{{ post.category.name }}</span>
        {% endif %}
    </div>
    
    <h2 class="post-title" id="ptitle-{{ post.id }}">{{ post.title }}</h2>

    {% if post.photo %}
        <img src="{{ post.photo }}" alt="Post photo" class="post-image" loading="lazy">
    {% endif %}

    <p class="post-content" id="pcontent-{{ post.id }}">{{ post.content|length > 200 ? post.content|slice(0, 200) ~ '...' : post.content }}</p>

    <div class="tx-bar" style="margin-bottom:0.75rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-subtle);flex-shrink:0;"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <div class="tx-pills" id="tx-pills-{{ post.id }}">
            <button class="tx-pill" onclick="txCard({{ post.id }},'en',this)" type="button">EN</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'fr',this)" type="button">FR</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'ar',this)" type="button">AR</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'es',this)" type="button">ES</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'de',this)" type="button">DE</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'it',this)" type="button">IT</button>
            <button class="tx-pill" onclick="txCard({{ post.id }},'zh-CN',this)" type="button">ZH</button>
        </div>
        <span class="tx-badge" id="txb-{{ post.id }}"></span>
    </div>

    <div class="post-footer">
        <div class="action-buttons">
            <button class="btn btn-action like-btn {{ app.user and app.user in post.likedByUsers ? 'active' : '' }}" onclick="likePost({{ post.id }})" data-tooltip="Like">
                <i data-lucide="thumbs-up" style="width:16px;height:16px;"></i>
                <span class="like-count" id="likes-{{post.id}}">{{ post.likedByUsers|length }}</span>
            </button>
            <button class="btn btn-action dislike-btn {{ app.user and app.user in post.dislikedByUsers ? 'active' : '' }}" onclick="dislikePost({{ post.id }})" data-tooltip="Dislike">
                <i data-lucide="thumbs-down" style="width:16px;height:16px;"></i>
                <span class="dislike-count" id="dislikes-{{post.id}}">{{ post.dislikedByUsers|length }}</span>
            </button>
        </div>
        <div style="display:flex;gap:0.4rem;align-items:center;">
            {% if app.user and (app.user == post.user or is_granted('ROLE_ADMIN')) %}
            <a href="{{ path('app_post_edit', {'id': post.id}) }}" class="btn btn-icon btn-action" data-tooltip="Edit">
                <i data-lucide="pencil" style="width:16px;height:16px;"></i>
            </a>
            <form method="post" action="{{ path('app_post_delete', {'id': post.id}) }}" style="display:inline;margin:0;" onsubmit="return confirm('Delete this post?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                <button type="submit" class="btn btn-icon btn-danger" data-tooltip="Delete">
                    <i data-lucide="trash-2" style="width:16px;height:16px;"></i>
                </button>
            </form>
            {% endif %}
            <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-primary" style="gap:0.4rem;padding:0.55rem 1.2rem;margin-left:0.5rem;">
                <i data-lucide="arrow-right" style="width:16px;height:16px;"></i>
            </a>
        </div>
    </div>
</div>
