<script>
/* ── Google Translate (free endpoint — same as google-translator npm pkg) ── */
async function gtranslate(text, lang) {
    const res = await fetch(
        'https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=' +
        lang + '&dt=t&q=' + encodeURIComponent(text)
    );
    const data = await res.json();
    return data[0].map(s => s[0]).join('');
}

async function txPost(lang, btn) {
    const titleEl   = document.getElementById('show-post-title');
    const contentEl = document.getElementById('show-post-content');
    const badge     = document.getElementById('txb-post');
    const pills     = document.querySelectorAll('#tx-pills-post .tx-pill');

    if (btn.classList.contains('active')) {
        txPostRestore(); return;
    }

    if (!titleEl.dataset.orig)   titleEl.dataset.orig   = titleEl.innerText;
    if (!contentEl.dataset.orig) contentEl.dataset.orig = contentEl.innerText;

    pills.forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    badge.innerHTML = '<span class="tx-spinner"></span>';

    try {
        const [t, c] = await Promise.all([
            gtranslate(titleEl.dataset.orig, lang),
            gtranslate(contentEl.dataset.orig, lang)
        ]);
        titleEl.innerText   = t;
        contentEl.innerText = c;
        badge.innerHTML = 'Translated &middot; <a href="#" onclick="event.preventDefault();txPostRestore()">Original</a>';
    } catch(e) {
        pills.forEach(p => p.classList.remove('active'));
        badge.innerHTML = '⚠ Failed';
        setTimeout(() => { badge.innerHTML = ''; }, 3000);
    }
}

function txPostRestore() {
    const titleEl   = document.getElementById('show-post-title');
    const contentEl = document.getElementById('show-post-content');
    const badge     = document.getElementById('txb-post');
    if (titleEl   && titleEl.dataset.orig)   titleEl.innerText   = titleEl.dataset.orig;
    if (contentEl && contentEl.dataset.orig) contentEl.innerText = contentEl.dataset.orig;
    document.querySelectorAll('#tx-pills-post .tx-pill').forEach(p => p.classList.remove('active'));
    if (badge) badge.innerHTML = '';
}

async function txComment(id, lang, btn) {
    const contentEl = document.getElementById('cc-' + id);
    const badge     = document.getElementById('txcb-' + id);
    const pills     = document.querySelectorAll('#tx-pills-c' + id + ' .tx-pill-xs');
    if (!contentEl) return;

    if (btn.classList.contains('active')) {
        txCommentRestore(id); return;
    }

    if (!contentEl.dataset.orig) contentEl.dataset.orig = contentEl.innerText;
    pills.forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    badge.innerHTML = '<span class="tx-spinner"></span>';

    try {
        const translated = await gtranslate(contentEl.dataset.orig, lang);
        contentEl.innerText = translated;
        badge.innerHTML = 'Translated &middot; <a href="#" onclick="event.preventDefault();txCommentRestore(' + id + ')">Original</a>';
    } catch(e) {
        pills.forEach(p => p.classList.remove('active'));
        badge.innerHTML = '⚠ Failed';
        setTimeout(() => { badge.innerHTML = ''; }, 3000);
    }
}

function txCommentRestore(id) {
    const contentEl = document.getElementById('cc-' + id);
    const badge     = document.getElementById('txcb-' + id);
    if (contentEl && contentEl.dataset.orig) contentEl.innerText = contentEl.dataset.orig;
    document.querySelectorAll('#tx-pills-c' + id + ' .tx-pill-xs').forEach(p => p.classList.remove('active'));
    if (badge) badge.innerHTML = '';
}

function toggleReplyForm(id) {
    const el = document.getElementById('reply-form-' + id);
    if (!el) return;
    const isHidden = el.style.display === 'none' || !el.style.display;
    el.style.display = isHidden ? 'block' : 'none';
    if (isHidden) { const ta = el.querySelector('textarea'); if (ta) ta.focus(); }
}

function likePost(id) {
    const btn = event.currentTarget;
    fetch('/post/' + id + '/like', { method: 'POST' })
        .then(r => r.json()).then(data => {
            if (data.error) return alert(data.error);
            document.getElementById('likes-' + id).innerText = data.likes;
            document.getElementById('dislikes-' + id).innerText = data.dislikes;
            btn.classList.toggle('active');
            const other = btn.parentElement.querySelector('.dislike-btn');
            if (other) other.classList.remove('active');
        });
}

function dislikePost(id) {
    const btn = event.currentTarget;
    fetch('/post/' + id + '/dislike', { method: 'POST' })
        .then(r => r.json()).then(data => {
            if (data.error) return alert(data.error);
            document.getElementById('likes-' + id).innerText = data.likes;
            document.getElementById('dislikes-' + id).innerText = data.dislikes;
            btn.classList.toggle('active');
            const other = btn.parentElement.querySelector('.like-btn');
            if (other) other.classList.remove('active');
        });
}

function likeComment(id) {
    const btn = event.currentTarget;
    fetch('/post/comment/' + id + '/like', { method: 'POST' })
        .then(r => r.json()).then(data => {
            if (data.error) return alert(data.error);
            document.getElementById('comment-likes-' + id).innerText = data.likes;
            document.getElementById('comment-dislikes-' + id).innerText = data.dislikes;
            btn.classList.toggle('active');
            const reacts = btn.closest('.show-comment-reacts');
            if (reacts) { const other = reacts.querySelector('.dislike-btn'); if (other) other.classList.remove('active'); }
        });
}

function dislikeComment(id) {
    const btn = event.currentTarget;
    fetch('/post/comment/' + id + '/dislike', { method: 'POST' })
        .then(r => r.json()).then(data => {
            if (data.error) return alert(data.error);
            document.getElementById('comment-likes-' + id).innerText = data.likes;
            document.getElementById('comment-dislikes-' + id).innerText = data.dislikes;
            btn.classList.toggle('active');
            const reacts = btn.closest('.show-comment-reacts');
            if (reacts) { const other = reacts.querySelector('.like-btn'); if (other) other.classList.remove('active'); }
        });
}
</script>
