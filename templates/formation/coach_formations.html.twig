{% extends 'base.html.twig' %}
{% block title %}Coach — Mes Formations | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0a1628;--navy-mid:#132240;
    --accent:#e8734a;--accent-glow:rgba(232,115,74,.25);
    --cyan:#38bdf8;--cyan-pale:rgba(56,189,248,.1);--cyan-glow:rgba(56,189,248,.15);
    --emerald:#34d399;--emerald-pale:rgba(52,211,153,.1);
    --rose:#fb7185;--rose-pale:rgba(251,113,133,.1);
    --violet:#a78bfa;--violet-pale:rgba(167,139,250,.1);
    --surface:#f8fafc;--surface-card:#ffffff;
    --border:#e2e8f0;--border-light:#f1f5f9;
    --text-primary:#0f172a;--text-secondary:#64748b;--text-muted:#94a3b8;
    --radius:16px;--radius-sm:10px;--radius-xs:8px;
    --shadow-sm:0 1px 3px rgba(10,22,40,.06),0 1px 2px rgba(10,22,40,.04);
    --shadow-md:0 4px 16px rgba(10,22,40,.08);
    --shadow-lg:0 12px 40px rgba(10,22,40,.12);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--text-primary);-webkit-font-smoothing:antialiased}

  @keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeInScale{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:scale(1)}}
  @keyframes slideRight{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:translateX(0)}}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}

  .sidebar{position:fixed;top:0;left:0;height:100vh;width:260px;background:var(--navy);display:flex;flex-direction:column;padding:32px 24px;z-index:100;overflow:hidden}
  .sidebar::before{content:'';position:absolute;top:-80px;right:-80px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,.08),transparent);pointer-events:none}
  .logo{font-family:'Outfit',sans-serif;font-size:24px;font-weight:900;color:#fff;letter-spacing:-.5px;margin-bottom:2px}
  .logo span{background:linear-gradient(135deg,var(--accent),#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .role-badge{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,rgba(232,115,74,.2),rgba(232,115,74,.08));border:1px solid rgba(232,115,74,.2);color:var(--accent);border-radius:8px;padding:6px 14px;font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:36px}
  .nav-link{display:flex;align-items:center;gap:12px;padding:11px 16px;border-radius:var(--radius-sm);color:rgba(255,255,255,.5);font-size:14px;font-weight:500;text-decoration:none;margin-bottom:4px;transition:all .2s;position:relative}
  .nav-link::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--cyan);border-radius:0 4px 4px 0;opacity:0;transition:.2s}
  .nav-link:hover{color:rgba(255,255,255,.85);background:rgba(255,255,255,.05)}
  .nav-link.active{color:#fff;background:rgba(56,189,248,.1)}
  .nav-link.active::before{opacity:1}
  .sidebar-bottom{margin-top:auto}
  .coach-card{display:flex;align-items:center;gap:12px;padding:14px 16px;background:rgba(255,255,255,.04);border-radius:var(--radius-sm);border:1px solid rgba(255,255,255,.06)}
  .coach-avatar{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--cyan),var(--violet));display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:16px}
  .coach-name{color:#fff;font-size:13px;font-weight:600}.coach-label{color:var(--text-muted);font-size:11px}

  .main{margin-left:260px;padding:36px 44px;min-height:100vh}
  .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;animation:fadeInUp .5s ease both}
  .page-title{font-family:'Outfit',sans-serif;font-size:28px;font-weight:800;letter-spacing:-.5px}
  .page-title span{background:linear-gradient(135deg,var(--accent),#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .page-subtitle{font-size:13px;color:var(--text-muted);margin-top:4px}
  .btn-new{background:linear-gradient(135deg,var(--accent),#d4613b);color:#fff;border:none;border-radius:var(--radius-sm);padding:12px 24px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:8px;transition:all .25s;box-shadow:0 4px 16px var(--accent-glow);font-family:inherit}
  .btn-new:hover{transform:translateY(-2px);box-shadow:0 8px 24px var(--accent-glow)}

  .search-bar{background:var(--surface-card);border-radius:var(--radius);padding:16px 20px;box-shadow:var(--shadow-sm);border:1px solid var(--border-light);margin-bottom:28px;animation:fadeInUp .5s ease both;animation-delay:.15s}
  .search-wrap{position:relative}
  .search-wrap input{width:100%;padding:12px 18px 12px 46px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:inherit;outline:none;transition:all .25s;background:var(--surface);color:var(--text-primary)}
  .search-wrap input:focus{border-color:var(--cyan);box-shadow:0 0 0 3px var(--cyan-glow);background:#fff}
  .search-wrap input::placeholder{color:var(--text-muted)}
  .search-icon{position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:16px;color:var(--text-muted);pointer-events:none;transition:.2s}
  .search-wrap input:focus ~ .search-icon{color:var(--cyan)}

  .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:24px;margin-bottom:40px}
  .formation-card{background:var(--surface-card);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;transition:all .3s ease;border:1px solid var(--border-light);display:flex;flex-direction:column;animation:fadeInScale .5s ease both}
  .formation-card:nth-child(1){animation-delay:.1s}
  .formation-card:nth-child(2){animation-delay:.18s}
  .formation-card:nth-child(3){animation-delay:.26s}
  .formation-card:nth-child(4){animation-delay:.34s}
  .formation-card:nth-child(5){animation-delay:.42s}
  .formation-card:nth-child(6){animation-delay:.50s}
  .formation-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:var(--cyan)}
  .formation-card.hidden{display:none}
  .card-header{background:linear-gradient(135deg,var(--navy),var(--navy-mid));padding:24px 24px 20px;position:relative;overflow:hidden}
  .card-header::before{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,.12),transparent);pointer-events:none}
  .card-category{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.1);backdrop-filter:blur(8px);color:rgba(255,255,255,.9);border-radius:24px;padding:4px 12px;font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px;border:1px solid rgba(255,255,255,.08)}
  .card-title{color:#fff;font-family:'Outfit',sans-serif;font-size:18px;font-weight:700;line-height:1.3}
  .card-body{padding:22px 24px;flex:1;display:flex;flex-direction:column}
  .card-desc{font-size:13px;color:var(--text-muted);line-height:1.7;margin-bottom:16px;flex:1}
  .card-meta{display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap}
  .meta-pill{display:flex;align-items:center;gap:6px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-xs);padding:6px 12px;font-size:12px;font-weight:600;color:var(--text-secondary);transition:.2s}
  .meta-pill:hover{border-color:var(--cyan);color:var(--cyan)}
  .card-actions{display:flex;gap:8px}
  .btn-sm{flex:1;padding:10px;border-radius:var(--radius-xs);font-size:13px;font-weight:600;border:none;cursor:pointer;text-decoration:none;text-align:center;transition:all .2s;font-family:inherit}
  .btn-sm:hover{transform:translateY(-1px)}
  .btn-cyan{background:var(--cyan-pale);color:var(--cyan)}.btn-cyan:hover{background:var(--cyan);color:#fff}
  .btn-orange{background:rgba(232,115,74,.08);color:var(--accent)}.btn-orange:hover{background:var(--accent);color:#fff}
  .btn-purple{background:var(--violet-pale);color:var(--violet)}.btn-purple:hover{background:var(--violet);color:#fff}
  .btn-red{background:var(--rose-pale);color:var(--rose)}.btn-red:hover{background:var(--rose);color:#fff}

  .no-cards-msg{text-align:center;padding:48px;background:var(--surface-card);border-radius:var(--radius);color:var(--text-muted);display:none;grid-column:1/-1;border:1px solid var(--border-light)}

  .section-title{font-family:'Outfit',sans-serif;font-size:22px;font-weight:800;color:var(--text-primary);margin-bottom:20px;padding-top:16px;border-top:2px solid var(--border);display:flex;align-items:center;gap:10px;animation:fadeInUp .5s ease both;animation-delay:.5s}
  .patients-table{background:var(--surface-card);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;border:1px solid var(--border-light);animation:fadeInUp .5s ease both;animation-delay:.55s}
  .patients-table table{width:100%;border-collapse:collapse}
  .patients-table thead th{background:var(--navy);color:rgba(255,255,255,.7);padding:14px 20px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px}
  .patients-table tbody tr{border-bottom:1px solid var(--border-light);transition:.2s}
  .patients-table tbody tr:hover{background:linear-gradient(90deg,var(--cyan-pale),transparent)}
  .patients-table tbody td{padding:14px 20px;font-size:14px;font-weight:500}
  .score-pill{display:inline-flex;align-items:center;padding:5px 12px;border-radius:24px;font-size:11px;font-weight:700;letter-spacing:.3px}
  .score-pending{background:var(--surface);color:var(--text-muted);border:1px solid var(--border)}
  .empty-state{text-align:center;padding:48px;color:var(--text-muted)}

  .pagination{display:flex;align-items:center;justify-content:center;gap:6px;padding:24px 0 6px}
  .pg-btn{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border-radius:var(--radius-xs);font-size:14px;font-weight:600;border:1.5px solid var(--border);background:#fff;color:var(--text-secondary);text-decoration:none;transition:all .2s}
  .pg-btn:hover{border-color:var(--cyan);color:var(--cyan);transform:translateY(-1px)}
  .pg-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
  .pg-btn.disabled{opacity:.35;pointer-events:none}
  .pg-info{font-size:12px;color:var(--text-muted);margin-left:12px}

  .flash{padding:16px 22px;border-radius:var(--radius-sm);margin-bottom:20px;font-weight:600;animation:fadeInUp .4s ease both;display:flex;align-items:center;gap:10px}
  .flash-success{background:var(--emerald-pale);color:var(--emerald);border:1px solid rgba(52,211,153,.2)}

 /* KnpPaginator styling */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 0;
}
.pagination span.flex {
  display: flex;
  align-items: center;
  gap: 4px;
}
.pagination a,
.pagination span:not(.flex) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 38px;
  padding: 0 12px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  border: 1.5px solid #e2e8f0;
  background: #fff;
  color: #64748b;
  text-decoration: none;
  transition: all .2s;
}
.pagination a:hover {
  border-color: #38bdf8;
  color: #38bdf8;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(56,189,248,.15);
}
/* Current/active page */
.pagination span.current,
.pagination em {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 38px;
  padding: 0 12px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  background: #0a1628;
  color: #fff;
  border: 1.5px solid #0a1628;
  font-style: normal;
}
/* First/Last/Prev/Next arrows */
.pagination a[rel="prev"],
.pagination a[rel="next"] {
  font-size: 16px;
}
</style>

<div class="sidebar">
  <div class="logo">Echo<span>Care</span></div>
  <div class="role-badge">👨‍🏫 Coach</div>
  <a href="{{ path('app_formation_index') }}" class="nav-link active"><span>📚</span> Mes Formations</a>
  <a href="#" class="nav-link"><span>👥</span> Mes Patients</a>
  <a href="{{ path('app_feedback_dashboard') }}" class="nav-link"><span>💬</span> Sentiments</a>
  <a href="{{ path('app_statistics') }}" class="nav-link"><span>📊</span> Statistiques</a>
  <div class="sidebar-bottom">
    <div class="coach-card">
      <div class="coach-avatar">C</div>
      <div><div class="coach-name">Mon Profil</div><div class="coach-label">Coach certifié</div></div>
    </div>
  </div>
</div>

<div class="main">
  {% for message in app.flashes('success') %}<div class="flash flash-success">✅ {{ message }}</div>{% endfor %}

  <div class="topbar">
    <div>
      <div class="page-title">Mes <span>Formations</span></div>
      <div class="page-subtitle">Créez et gérez vos formations pour accompagner vos patients</div>
    </div>
    <a href="{{ path('app_formation_new') }}" class="btn-new">＋ Créer une Formation</a>
  </div>

  {% if formations|length > 0 %}
  <div class="search-bar">
    <div class="search-wrap">
      <input type="text" id="coachSearch" placeholder="Rechercher par titre ou catégorie…">
      <span class="search-icon">🔍</span>
    </div>
  </div>

  <div class="cards-grid" id="cardsGrid">
    {% for formation in formations %}
    <div class="formation-card" data-title="{{ formation.title|lower }}" data-cat="{{ formation.category ? formation.category|lower : '' }}">
      <div class="card-header" {% if formation.videoThumbnail %}style="background-image:linear-gradient(135deg,rgba(10,22,40,.85),rgba(19,34,64,.85)),url('{{ formation.videoThumbnail }}');background-size:cover;background-position:center"{% endif %}>
        {% if formation.category is not null %}<div class="card-category">{{ formation.category }}</div>{% endif %}
        <div class="card-title">{{ formation.title }}</div>
      </div>
      <div class="card-body">
        <div class="card-desc">{{ formation.description|slice(0,100) }}{% if formation.description|length > 100 %}…{% endif %}</div>
        <div class="card-meta">
          <div class="meta-pill">🎥 {% if formation.videoUrl is not null %}Vidéo ajoutée{% else %}Sans vidéo{% endif %}</div>
          <div class="meta-pill">👥 {{ (participations[formation.id] ?? [])|length }} patients</div>
        </div>
        <div class="card-actions">
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-sm btn-cyan">Voir</a>
          <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn-sm btn-orange">Modifier</a>
          <a href="{{ path('app_formation_quiz', {'id': formation.id}) }}" class="btn-sm btn-purple">Quiz</a>
          <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" onsubmit="return confirm('Supprimer ?')" style="flex:1">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
            <button class="btn-sm btn-red" style="width:100%">✕</button>
          </form>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="no-cards-msg" id="noCardsMsg">Aucune formation ne correspond à votre recherche.</div>

  <div class="pagination">
    {{ knp_pagination_render(formations) }}
  </div>

  <div class="section-title">👥 Patients Inscrits & Résultats</div>
  <div class="patients-table">
    <table>
      <thead><tr><th>Formation</th><th>Patient</th><th>Date Inscription</th><th>Score Quiz</th><th>Résultat</th></tr></thead>
      <tbody>
        {% set hasAny = false %}
        {% for formation in formations %}
          {% set formationParts = participations[formation.id] ?? [] %}
          {% if formationParts|length > 0 %}
            {% set hasAny = true %}
            {% for participation in formationParts %}
            <tr>
              <td><strong>{{ formation.title }}</strong></td>
              <td>Patient #{{ participation.getUser_id().getId_user() }}</td>
              <td>{{ participation.getDate_inscription() is not null ? participation.getDate_inscription()|date('d/m/Y') : '—' }}</td>
              <td><span class="score-pill score-pending">—</span></td>
              <td><span class="score-pill score-pending">En attente</span></td>
            </tr>
            {% endfor %}
          {% endif %}
        {% endfor %}
        {% if not hasAny %}<tr><td colspan="5" class="empty-state">Aucun patient inscrit pour l'instant</td></tr>{% endif %}
      </tbody>
    </table>
  </div>

  {% else %}
  <div style="text-align:center;padding:72px 40px;background:var(--surface-card);border-radius:var(--radius);box-shadow:var(--shadow-sm);border:1px solid var(--border-light);animation:fadeInUp .6s ease both">
    <div style="font-size:64px;margin-bottom:20px;animation:float 3s ease-in-out infinite">📭</div>
    <div style="font-family:Outfit;font-size:22px;font-weight:800;color:var(--text-primary);margin-bottom:8px">Aucune formation créée</div>
    <div style="color:var(--text-muted);margin-bottom:28px;font-size:15px">Commencez par créer votre première formation pour vos patients</div>
    <a href="{{ path('app_formation_new') }}" class="btn-new" style="display:inline-flex">＋ Créer maintenant</a>
  </div>
  {% endif %}
</div>

<script>
const s=document.getElementById('coachSearch');
if(s){s.addEventListener('input',function(){const q=this.value.toLowerCase().trim();let v=0;document.querySelectorAll('#cardsGrid .formation-card').forEach(c=>{const m=!q||(c.dataset.title||'').includes(q)||(c.dataset.cat||'').includes(q);c.classList.toggle('hidden',!m);if(m)v++;});const msg=document.getElementById('noCardsMsg');if(msg)msg.style.display=v===0?'block':'none';});}
</script>
{% endblock %}