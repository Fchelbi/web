{% extends 'base.html.twig' %}
{% block title %}Coach — Mes Formations | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--radius:14px;--shadow-sm:0 2px 8px rgba(15,42,74,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700)}
  .sidebar{position:fixed;top:0;left:0;height:100vh;width:240px;background:linear-gradient(160deg,#1a4a7a,var(--blue-dark));display:flex;flex-direction:column;padding:28px 20px;z-index:100}
  .logo{font-size:22px;font-weight:800;color:#fff;margin-bottom:4px}.logo span{color:var(--orange)}
  .role-badge{background:rgba(244,132,95,.15);color:var(--orange);border-radius:8px;padding:6px 12px;font-size:12px;font-weight:700;display:inline-block;margin-bottom:32px}
  .nav-link{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;color:rgba(255,255,255,.65);font-size:14px;font-weight:500;text-decoration:none;margin-bottom:4px;transition:.2s}
  .nav-link:hover,.nav-link.active{background:rgba(255,255,255,.12);color:#fff}
  .nav-link.active{background:var(--blue-light)}
  .sidebar-bottom{margin-top:auto}
  .coach-info{display:flex;align-items:center;gap:10px}
  .coach-avatar{width:40px;height:40px;border-radius:50%;background:var(--orange);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px}
  .coach-name{color:#fff;font-weight:600;font-size:14px}.coach-label{color:var(--gray-400);font-size:12px}
  .main{margin-left:240px;padding:36px 40px}
  .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
  .page-title{font-size:26px;font-weight:800;color:var(--blue-dark)}.page-title span{color:var(--orange)}
  .btn-new{background:linear-gradient(135deg,var(--orange),#e06d47);color:#fff;border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(244,132,95,.4);transition:.2s}
  .btn-new:hover{transform:translateY(-2px)}
  /* ---- Search bar ---- */
  .search-bar{background:#fff;border-radius:var(--radius);padding:14px 20px;box-shadow:var(--shadow-sm);display:flex;gap:12px;margin-bottom:24px}
  .search-wrap{position:relative;flex:1}
  .search-wrap input{width:100%;padding:10px 14px 10px 40px;border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-family:inherit;outline:none;transition:.2s}
  .search-wrap input:focus{border-color:var(--blue-light)}
  .search-wrap::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%)}
  /* ---- Cards ---- */
  .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;margin-bottom:40px}
  .formation-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;transition:.2s}
  .formation-card:hover{transform:translateY(-4px);box-shadow:0 8px 28px rgba(15,42,74,.14)}
  .formation-card.hidden{display:none}
  .card-header{background:linear-gradient(135deg,var(--blue-dark),#1a4a7a);padding:20px 22px}
  .card-category{background:rgba(255,255,255,.15);color:rgba(255,255,255,.9);border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;display:inline-block;margin-bottom:8px}
  .card-title{color:#fff;font-size:17px;font-weight:700;line-height:1.3}
  .card-body{padding:18px 22px}
  .card-desc{font-size:13px;color:var(--gray-400);line-height:1.6;margin-bottom:14px}
  .card-meta{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap}
  .meta-pill{display:flex;align-items:center;gap:5px;background:var(--gray-100);border-radius:8px;padding:5px 10px;font-size:12px;font-weight:500}
  .card-actions{display:flex;gap:8px}
  .btn-sm{flex:1;padding:9px;border-radius:9px;font-size:13px;font-weight:600;border:none;cursor:pointer;text-decoration:none;text-align:center;transition:.15s}
  .btn-blue{background:var(--blue-pale);color:var(--blue-light)}.btn-blue:hover{background:var(--blue-light);color:#fff}
  .btn-orange{background:var(--orange-soft);color:var(--orange)}.btn-orange:hover{background:var(--orange);color:#fff}
  .btn-purple{background:#f0f4ff;color:#6366f1}.btn-purple:hover{background:#6366f1;color:#fff}
  .btn-red{background:#fff0f0;color:#ef4444}.btn-red:hover{background:#ef4444;color:#fff}
  /* ---- Patients table ---- */
  .section-title{font-size:20px;font-weight:800;color:var(--blue-dark);margin-bottom:20px;padding-top:10px;border-top:2px solid var(--gray-200)}
  .patients-table{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden}
  .patients-table table{width:100%;border-collapse:collapse}
  .patients-table thead th{background:var(--blue-dark);color:rgba(255,255,255,.75);padding:12px 18px;text-align:left;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px}
  .patients-table tbody tr{border-bottom:1px solid var(--gray-200)}
  .patients-table tbody tr:hover{background:var(--gray-100)}
  .patients-table tbody td{padding:13px 18px;font-size:14px}
  .score-pending{display:inline-block;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:700;background:var(--gray-200);color:var(--gray-400)}
  .empty-state{text-align:center;padding:40px;color:var(--gray-400)}
  /* ---- Pagination ---- */
  .pagination{display:flex;align-items:center;justify-content:center;gap:8px;padding:22px 0 6px}
  .pg-btn{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;font-size:14px;font-weight:600;border:1.5px solid var(--gray-200);background:#fff;color:var(--gray-700);text-decoration:none;transition:.15s}
  .pg-btn:hover{border-color:var(--blue-light);color:var(--blue-light)}
  .pg-btn.active{background:var(--blue-light);color:#fff;border-color:var(--blue-light)}
  .pg-btn.disabled{opacity:.4;pointer-events:none}
  .pg-info{font-size:13px;color:var(--gray-400);margin-left:8px}
  .no-cards-msg{text-align:center;padding:40px;background:#fff;border-radius:var(--radius);color:var(--gray-400);display:none}
</style>

<div class="sidebar">
  <div class="logo">Echo<span>Care</span></div>
  <div class="role-badge">👨‍🏫 Coach</div>
  <a href="{{ path('app_formation_index') }}" class="nav-link active">📚 Mes Formations</a>
  <a href="#" class="nav-link">👥 Mes Patients</a>
  <a href="#" class="nav-link">📊 Statistiques</a>
  <div class="sidebar-bottom">
    <div class="coach-info">
      <div class="coach-avatar">C</div>
      <div><div class="coach-name">Mon Profil</div><div class="coach-label">Coach</div></div>
    </div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div class="page-title">Mes <span>Formations</span></div>
    <a href="{{ path('app_formation_new') }}" class="btn-new">＋ Créer une Formation</a>
  </div>

  {% if formations|length > 0 %}

  {# ---- Live search bar ---- #}
  <div class="search-bar">
    <div class="search-wrap">
      <input type="text" id="coachSearch" placeholder="Rechercher par titre ou catégorie…">
    </div>
  </div>

  <div class="cards-grid" id="cardsGrid">
    {% for formation in formations %}
    <div class="formation-card"
         data-title="{{ formation.title|lower }}"
         data-cat="{{ formation.category ? formation.category|lower : '' }}">
      <div class="card-header">
        {# Use 'is not null' — avoid the 'defined' test on object properties #}
        {% if formation.category is not null %}
          <div class="card-category">{{ formation.category }}</div>
        {% endif %}
        <div class="card-title">{{ formation.title }}</div>
      </div>
      <div class="card-body">
        <div class="card-desc">{{ formation.description|slice(0,100) }}{% if formation.description|length > 100 %}…{% endif %}</div>
        <div class="card-meta">
          <div class="meta-pill">🎥 {% if formation.videoUrl is not null %}Vidéo ajoutée{% else %}Sans vidéo{% endif %}</div>
          {#
            participations[formation.id] may be undefined on the first page visit if a
            formation has zero enrollments — use the default filter to avoid errors.
          #}
          <div class="meta-pill">👥 {{ (participations[formation.id] ?? [])|length }} patients inscrits</div>
        </div>
        <div class="card-actions">
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-sm btn-blue">Voir</a>
          <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn-sm btn-orange">Modifier</a>
          <a href="{{ path('app_formation_quiz', {'id': formation.id}) }}" class="btn-sm btn-purple">Quiz</a>
          <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" onsubmit="return confirm('Supprimer ?')" style="flex:1">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
            <button class="btn-sm btn-red" style="width:100%">✕</button>
          </form>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="no-cards-msg" id="noCardsMsg">Aucune formation ne correspond à votre recherche.</div>

  {# ---- Pagination ---- #}
  {% if totalPages > 1 %}
  <div class="pagination">
    <a href="{{ path('app_formation_index', {'page': max(1, page-1)}) }}"
       class="pg-btn {% if page <= 1 %}disabled{% endif %}">‹</a>
    {% for p in 1..totalPages %}
      {% if p == 1 or p == totalPages or (p >= page - 2 and p <= page + 2) %}
        <a href="{{ path('app_formation_index', {'page': p}) }}"
           class="pg-btn {% if p == page %}active{% endif %}">{{ p }}</a>
      {% elseif p == page - 3 or p == page + 3 %}
        <span class="pg-btn" style="border:none;background:none;cursor:default">…</span>
      {% endif %}
    {% endfor %}
    <a href="{{ path('app_formation_index', {'page': min(totalPages, page+1)}) }}"
       class="pg-btn {% if page >= totalPages %}disabled{% endif %}">›</a>
    <span class="pg-info">Page {{ page }} / {{ totalPages }} — {{ total }} formations</span>
  </div>
  {% endif %}

  {# ---- Patients enrolled ---- #}
  <div class="section-title">👥 Patients Inscrits &amp; Résultats Quiz</div>
  <div class="patients-table">
    <table>
      <thead>
        <tr>
          <th>Formation</th>
          <th>Patient</th>
          <th>Date Inscription</th>
          <th>Score Quiz</th>
          <th>Résultat</th>
        </tr>
      </thead>
      <tbody>
        {% set hasAny = false %}
        {% for formation in formations %}
          {% set formationParts = participations[formation.id] ?? [] %}
          {% if formationParts|length > 0 %}
            {% set hasAny = true %}
            {% for participation in formationParts %}
            <tr>
              <td><strong>{{ formation.title }}</strong></td>
              <td>Patient #{{ participation.getUser_id().getId_user() }}</td>
              <td>{{ participation.getDate_inscription() is not null ? participation.getDate_inscription()|date('d/m/Y') : '—' }}</td>
              <td><span class="score-pending">—</span></td>
              <td><span class="score-pending">En attente</span></td>
            </tr>
            {% endfor %}
          {% endif %}
        {% endfor %}
        {% if not hasAny %}
        <tr><td colspan="5" class="empty-state">Aucun patient inscrit pour l'instant</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  {% else %}
  <div style="text-align:center;padding:60px;background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm)">
    <div style="font-size:56px;margin-bottom:16px">📭</div>
    <div style="font-size:20px;font-weight:700;color:var(--blue-dark);margin-bottom:8px">Aucune formation créée</div>
    <div style="color:var(--gray-400);margin-bottom:24px">Commencez par créer votre première formation</div>
    <a href="{{ path('app_formation_new') }}" class="btn-new" style="display:inline-flex">＋ Créer maintenant</a>
  </div>
  {% endif %}
</div>

<script>
// ---- Live search on cards ----
const coachSearch = document.getElementById('coachSearch');
if (coachSearch) {
  coachSearch.addEventListener('input', function () {
    const s = this.value.toLowerCase().trim();
    let visible = 0;
    document.querySelectorAll('#cardsGrid .formation-card').forEach(card => {
      const match = !s ||
        (card.dataset.title || '').includes(s) ||
        (card.dataset.cat  || '').includes(s);
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });
    const msg = document.getElementById('noCardsMsg');
    if (msg) msg.style.display = visible === 0 ? 'block' : 'none';
  });
}
</script>
{% endblock %}
