{% extends 'base.html.twig' %}
{% block title %}Quiz — {{ formation.title }} | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--emerald:#34d399;--emerald-pale:rgba(52,211,153,.1);--red:#ef4444;--red-pale:rgba(239,68,68,.1);--violet:#a78bfa;--violet-pale:rgba(167,139,250,.1);--radius:14px;--shadow-sm:0 2px 8px rgba(15,42,74,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700);padding:40px 20px}
  .page-wrap{max-width:860px;margin:0 auto}
  .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--blue-light);font-size:14px;font-weight:600;text-decoration:none;margin-bottom:24px;transition:.15s}
  .back-link:hover{opacity:.75}
  .card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:24px}
  .card-header{background:linear-gradient(135deg,var(--blue-dark),#1a4a7a);padding:24px 28px}
  .card-title{font-size:22px;font-weight:800;color:#fff;margin-bottom:6px}
  .card-sub{font-size:13px;color:rgba(255,255,255,.6)}
  .card-body{padding:28px}

  .options-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px}
  @media(max-width:640px){.options-grid{grid-template-columns:1fr}}
  .option-card{border-radius:12px;padding:24px;text-align:center;transition:all .25s}
  .option-card:hover{transform:translateY(-3px)}
  .option-manual{background:linear-gradient(135deg,rgba(45,125,210,.06),rgba(45,125,210,.02));border:1.5px solid rgba(45,125,210,.15)}
  .option-ai{background:linear-gradient(135deg,var(--violet-pale),rgba(167,139,250,.03));border:1.5px solid rgba(167,139,250,.2)}
  .option-icon{font-size:36px;margin-bottom:10px}
  .option-title{font-size:16px;font-weight:800;color:var(--blue-dark);margin-bottom:6px}
  .option-desc{font-size:12px;color:var(--gray-400);margin-bottom:16px;line-height:1.5}

  .btn-manual{background:linear-gradient(135deg,var(--blue-light),#1a5a9e);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all .25s;box-shadow:0 4px 12px rgba(45,125,210,.25);font-family:inherit}
  .btn-manual:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(45,125,210,.35)}
  .btn-ai{background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:14px;font-weight:700;cursor:pointer;transition:all .25s;box-shadow:0 4px 16px rgba(139,92,246,.3);font-family:inherit;display:inline-flex;align-items:center;gap:8px}
  .btn-ai:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(139,92,246,.4)}
  .btn-ai:disabled{opacity:.6;cursor:not-allowed;transform:none}
  .ai-warning{font-size:11px;color:var(--gray-400);margin-top:10px}

  .quiz-actions{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px}
  .btn-action{border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;transition:.2s;font-family:inherit;display:inline-flex;align-items:center;gap:6px}
  .btn-edit{background:var(--orange-soft);color:var(--orange)}.btn-edit:hover{background:var(--orange);color:#fff}
  .btn-preview{background:var(--blue-pale);color:var(--blue-light)}.btn-preview:hover{background:var(--blue-light);color:#fff}
  .btn-delete{background:var(--red-pale);color:var(--red)}.btn-delete:hover{background:var(--red);color:#fff}

  .question-card{background:var(--gray-100);border-radius:12px;padding:20px 24px;margin-bottom:16px;border:1px solid var(--gray-200)}
  .q-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .q-number{background:var(--blue-pale);color:var(--blue-light);border-radius:8px;padding:4px 12px;font-size:12px;font-weight:700}
  .q-points{font-size:12px;color:var(--gray-400);font-weight:600}
  .q-text{font-size:15px;font-weight:600;color:var(--blue-dark);margin-bottom:14px;line-height:1.5}
  .answers-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .answer-item{padding:10px 14px;border-radius:8px;font-size:13px;font-weight:500;display:flex;align-items:center;gap:8px}
  .answer-correct{background:var(--emerald-pale);color:var(--emerald);border:1px solid rgba(52,211,153,.2)}
  .answer-wrong{background:var(--gray-100);color:var(--gray-400);border:1px solid var(--gray-200)}

  .empty-state{text-align:center;padding:48px;color:var(--gray-400)}
  .empty-state .emoji{font-size:48px;margin-bottom:16px}
  .flash{padding:14px 20px;border-radius:10px;margin-bottom:20px;font-weight:600;font-size:14px;display:flex;align-items:center;gap:8px}
  .flash-success{background:var(--emerald-pale);color:var(--emerald);border:1px solid rgba(52,211,153,.2)}
  .flash-error{background:var(--red-pale);color:var(--red);border:1px solid rgba(239,68,68,.15)}

  .stats-row{display:flex;gap:16px;margin-bottom:24px}
  .stat-box{flex:1;background:#fff;border-radius:12px;padding:18px;text-align:center;box-shadow:var(--shadow-sm)}
  .stat-val{font-size:28px;font-weight:800;color:var(--blue-dark)}
  .stat-lbl{font-size:11px;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;margin-top:4px;font-weight:600}
  .divider{display:flex;align-items:center;gap:14px;margin:24px 0;color:var(--gray-400);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px}
  .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--gray-200)}
</style>

<div class="page-wrap">
  <a href="{{ path('app_formation_index') }}" class="back-link">← Retour aux formations</a>

  {% for message in app.flashes('success') %}<div class="flash flash-success">✅ {{ message }}</div>{% endfor %}
  {% for message in app.flashes('error') %}<div class="flash flash-error">❌ {{ message }}</div>{% endfor %}

  <div class="card">
    <div class="card-header">
      <div class="card-title">📝 Quiz — {{ formation.title }}</div>
      <div class="card-sub">Gérez les questions du quiz de cette formation</div>
    </div>
    <div class="card-body">

      <div class="options-grid">

        {# Option 1: Manual CRUD #}
        <div class="option-card option-manual">
          <div class="option-icon">✏️</div>
          <div class="option-title">Créer Manuellement</div>
          <div class="option-desc">Ajoutez vos propres questions et réponses une par une</div>
          {# FIX: app_quiz_edit handles both create and edit (see QuizController) #}
          {% if quiz is not null %}
            <a href="{{ path('app_quiz_edit', {'id': formation.id}) }}" class="btn-manual">✏️ Modifier le Quiz</a>
          {% else %}
            <a href="{{ path('app_quiz_new', {'id': formation.id}) }}" class="btn-manual">➕ Créer un Quiz</a>
          {% endif %}
        </div>

        {# Option 2: AI Generator #}
        <div class="option-card option-ai">
          <div class="option-icon">🤖</div>
          <div class="option-title">Générer avec l'IA</div>
          <div class="option-desc">5 questions auto-générées à partir du contenu de la formation</div>
          <form method="post" action="{{ path('app_formation_quiz_generate', {'id': formation.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('generate_quiz' ~ formation.id) }}">
            <button type="submit" class="btn-ai"
              onclick="this.disabled=true;this.innerHTML='⏳ Génération…';this.form.submit();">
              🧠 Générer avec IA
            </button>
          </form>
          <div class="ai-warning">⚠️ Remplacera les questions existantes</div>
        </div>

      </div>

      {% if quiz is not null %}

        {# FIX: was app_quiz_delete_quiz — correct name is app_quiz_delete #}
        <div class="quiz-actions">
          <a href="{{ path('app_quiz_edit', {'id': formation.id}) }}" class="btn-action btn-edit">✏️ Modifier</a>
          <a href="{{ path('app_quiz_preview', {'id': formation.id}) }}" class="btn-action btn-preview">👁️ Aperçu</a>
          <form method="post" action="{{ path('app_quiz_delete', {'id': formation.id}) }}"
                onsubmit="return confirm('Supprimer ce quiz et toutes ses questions ?')"
                style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_quiz_' ~ quiz.id) }}">
            <button type="submit" class="btn-action btn-delete">🗑️ Supprimer Quiz</button>
          </form>
        </div>

        {% if quiz.questions|length > 0 %}
          <div class="stats-row">
            <div class="stat-box">
              <div class="stat-val">{{ quiz.questions|length }}</div>
              <div class="stat-lbl">Questions</div>
            </div>
            <div class="stat-box">
              <div class="stat-val">{{ quiz.passingScore }}%</div>
              <div class="stat-lbl">Score minimum</div>
            </div>
            <div class="stat-box">
              {% set totalPts = 0 %}
              {% for q in quiz.questions %}{% set totalPts = totalPts + q.points %}{% endfor %}
              <div class="stat-val">{{ totalPts }}</div>
              <div class="stat-lbl">Points total</div>
            </div>
          </div>
        {% endif %}

        <div class="divider">Questions du Quiz</div>

        {% if quiz.questions|length > 0 %}
          {% for question in quiz.questions %}
            <div class="question-card">
              <div class="q-header">
                <span class="q-number">Question {{ loop.index }}</span>
                <span class="q-points">{{ question.points }} pt{{ question.points > 1 ? 's' : '' }}</span>
              </div>
              <div class="q-text">{{ question.questionText }}</div>
              <div class="answers-grid">
                {% for reponse in question.reponses %}
                  <div class="answer-item {{ reponse.isCorrect ? 'answer-correct' : 'answer-wrong' }}">
                    {{ reponse.isCorrect ? '✅' : '○' }} {{ reponse.optionText }}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-state">
            <div class="emoji">📭</div>
            <p>Le quiz existe mais n'a pas encore de questions.<br>Utilisez l'une des options ci-dessus.</p>
          </div>
        {% endif %}

      {% else %}
        <div class="empty-state">
          <div class="emoji">📭</div>
          <p>Aucun quiz pour cette formation.<br>Créez-en un manuellement ou générez-le avec l'IA ci-dessus.</p>
        </div>
      {% endif %}

    </div>
  </div>
</div>
{% endblock %}
