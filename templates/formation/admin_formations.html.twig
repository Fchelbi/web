{% extends 'base.html.twig' %}
{% block title %}Admin — Formations{% endblock %}
{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-dark:   #0f2a4a;
    --blue-mid:    #1a4a7a;
    --blue-light:  #2d7dd2;
    --blue-pale:   #e8f2ff;
    --orange:      #f4845f;
    --orange-soft: #fff3ef;
    --white:       #ffffff;
    --gray-100:    #f7f9fc;
    --gray-200:    #eef2f7;
    --gray-400:    #94a3b8;
    --gray-700:    #374151;
    --shadow-sm:   0 2px 8px rgba(15,42,74,0.08);
    --shadow-md:   0 4px 20px rgba(15,42,74,0.12);
    --radius:      14px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--gray-100); color: var(--gray-700); }

  /* SIDEBAR */
  .sidebar {
    position: fixed; top: 0; left: 0; height: 100vh; width: 240px;
    background: var(--blue-dark);
    display: flex; flex-direction: column;
    padding: 28px 20px;
    box-shadow: 4px 0 24px rgba(0,0,0,0.15);
    z-index: 100;
  }
  .sidebar-logo {
    font-size: 22px; font-weight: 800; color: var(--white);
    letter-spacing: -0.5px; margin-bottom: 8px;
  }
  .sidebar-logo span { color: var(--orange); }
  .sidebar-subtitle { font-size: 11px; color: var(--gray-400); margin-bottom: 36px; text-transform: uppercase; letter-spacing: 1px; }
  .sidebar-label { font-size: 10px; color: var(--gray-400); text-transform: uppercase; letter-spacing: 1.2px; margin-bottom: 10px; margin-top: 20px; }
  .sidebar-link {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: 10px;
    color: rgba(255,255,255,0.65); font-size: 14px; font-weight: 500;
    text-decoration: none; margin-bottom: 4px;
    transition: all 0.2s;
  }
  .sidebar-link:hover, .sidebar-link.active {
    background: rgba(255,255,255,0.1); color: var(--white);
  }
  .sidebar-link.active { background: var(--blue-light); color: var(--white); }
  .sidebar-icon { font-size: 18px; width: 22px; text-align: center; }
  .sidebar-bottom { margin-top: auto; }
  .admin-badge {
    background: rgba(244,132,95,0.2); color: var(--orange);
    border-radius: 8px; padding: 10px 14px;
    font-size: 13px; font-weight: 600;
    display: flex; align-items: center; gap: 8px;
  }

  /* MAIN */
  .main { margin-left: 240px; padding: 36px 40px; min-height: 100vh; }

  /* TOPBAR */
  .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
  .page-title { font-size: 26px; font-weight: 800; color: var(--blue-dark); }
  .page-title span { color: var(--blue-light); }
  .btn-new {
    background: var(--orange); color: var(--white);
    border: none; border-radius: 10px;
    padding: 11px 22px; font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    display: flex; align-items: center; gap: 8px;
    transition: all 0.2s; box-shadow: 0 4px 12px rgba(244,132,95,0.35);
  }
  .btn-new:hover { background: #e06d47; transform: translateY(-1px); }

  /* STATS */
  .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px; }
  .stat-card {
    background: var(--white); border-radius: var(--radius);
    padding: 22px 24px; box-shadow: var(--shadow-sm);
    display: flex; align-items: center; gap: 16px;
  }
  .stat-icon {
    width: 50px; height: 50px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
  }
  .stat-icon.blue { background: var(--blue-pale); }
  .stat-icon.orange { background: var(--orange-soft); }
  .stat-icon.green { background: #e8f8f0; }
  .stat-value { font-size: 28px; font-weight: 800; color: var(--blue-dark); }
  .stat-label { font-size: 13px; color: var(--gray-400); font-weight: 500; }

  /* SEARCH & FILTER */
  .toolbar {
    background: var(--white); border-radius: var(--radius);
    padding: 18px 24px; box-shadow: var(--shadow-sm);
    display: flex; gap: 14px; align-items: center;
    margin-bottom: 24px;
  }
  .search-wrap { position: relative; flex: 1; }
  .search-wrap input {
    width: 100%; padding: 10px 14px 10px 40px;
    border: 1.5px solid var(--gray-200); border-radius: 10px;
    font-size: 14px; font-family: inherit; color: var(--gray-700);
    outline: none; transition: border 0.2s;
  }
  .search-wrap input:focus { border-color: var(--blue-light); }
  .search-wrap::before { content: '🔍'; position: absolute; left: 12px; top: 50%; transform: translateY(-50%); font-size: 14px; }
  .filter-select {
    padding: 10px 14px; border: 1.5px solid var(--gray-200); border-radius: 10px;
    font-size: 14px; font-family: inherit; color: var(--gray-700);
    outline: none; cursor: pointer; background: var(--white);
  }
  .btn-pdf {
    background: var(--blue-pale); color: var(--blue-light);
    border: none; border-radius: 10px;
    padding: 10px 18px; font-size: 13px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    display: flex; align-items: center; gap: 6px;
    transition: all 0.2s;
  }
  .btn-pdf:hover { background: var(--blue-light); color: var(--white); }

  /* TABLE */
  .table-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; }
  .table-card table { width: 100%; border-collapse: collapse; }
  .table-card thead th {
    background: var(--blue-dark); color: rgba(255,255,255,0.75);
    padding: 14px 20px; text-align: left;
    font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px;
  }
  .table-card tbody tr { border-bottom: 1px solid var(--gray-200); transition: background 0.15s; }
  .table-card tbody tr:hover { background: var(--gray-100); }
  .table-card tbody td { padding: 15px 20px; font-size: 14px; }
  .badge {
    display: inline-block; padding: 4px 10px; border-radius: 20px;
    font-size: 12px; font-weight: 600;
  }
  .badge-blue { background: var(--blue-pale); color: var(--blue-light); }
  .badge-orange { background: var(--orange-soft); color: var(--orange); }
  .badge-green { background: #e8f8f0; color: #2ecc71; }
  .actions { display: flex; gap: 8px; align-items: center; }
  .btn-show { background: var(--blue-pale); color: var(--blue-light); border: none; border-radius: 8px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; }
  .btn-edit { background: #fff8e1; color: #f59e0b; border: none; border-radius: 8px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; }
  .btn-delete { background: #fff0f0; color: #ef4444; border: none; border-radius: 8px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; }
  .empty-row td { text-align: center; padding: 40px; color: var(--gray-400); font-size: 15px; }
</style>
</head>
<body>

<div class="sidebar">
  <div class="sidebar-logo">Health<span>Connect</span></div>
  <div class="sidebar-subtitle">Admin Panel</div>
  <div class="sidebar-label">Gestion</div>
  <a href="#" class="sidebar-link active"><span class="sidebar-icon">📚</span> Formations</a>
  <a href="#" class="sidebar-link"><span class="sidebar-icon">👥</span> Utilisateurs</a>
  <a href="#" class="sidebar-link"><span class="sidebar-icon">📝</span> Quiz</a>
  <a href="#" class="sidebar-link"><span class="sidebar-icon">📊</span> Rapports</a>
  <div class="sidebar-label">Système</div>
  <a href="#" class="sidebar-link"><span class="sidebar-icon">⚙️</span> Paramètres</a>
  <div class="sidebar-bottom">
    <div class="admin-badge">👤 Administrateur</div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div>
      <div class="page-title">Gestion des <span>Formations</span></div>
    </div>
    <a href="{{ path('app_formation_new') }}" class="btn-new">＋ Nouvelle Formation</a>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon blue">📚</div>
      <div>
        <div class="stat-value">{{ formations|length }}</div>
        <div class="stat-label">Total Formations</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon orange">🎥</div>
      <div>
        <div class="stat-value">{{ formations|filter(f => f.videoUrl is not null)|length }}</div>
        <div class="stat-label">Avec Vidéo</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green">✅</div>
      <div>
        <div class="stat-value">{{ formations|length }}</div>
        <div class="stat-label">Formations Actives</div>
      </div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher une formation..." id="searchInput" onkeyup="filterTable()">
    </div>
    <select class="filter-select" id="categoryFilter" onchange="filterTable()">
      <option value="">Toutes les catégories</option>
      {% for formation in formations %}
        {% if formation.category %}
          <option value="{{ formation.category }}">{{ formation.category }}</option>
        {% endif %}
      {% endfor %}
    </select>
    <a href="#" class="btn-pdf">📄 Exporter PDF</a>
  </div>

  <div class="table-card">
    <table id="formationTable">
      <thead>
        <tr>
          <th>#</th>
          <th>Titre</th>
          <th>Description</th>
          <th>Catégorie</th>
          <th>Coach</th>
          <th>Vidéo</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for formation in formations %}
        <tr>
          <td>{{ formation.id }}</td>
          <td><strong>{{ formation.title }}</strong></td>
          <td>{{ formation.description|slice(0, 60) }}{% if formation.description|length > 60 %}...{% endif %}</td>
          <td>
            {% if formation.category %}
              <span class="badge badge-blue">{{ formation.category }}</span>
            {% else %}
              <span class="badge badge-orange">Non défini</span>
            {% endif %}
          </td>
          <td>Coach #{{ formation.coachId }}</td>
          <td>
            {% if formation.videoUrl %}
              <span class="badge badge-green">✓ Oui</span>
            {% else %}
              <span class="badge badge-orange">✗ Non</span>
            {% endif %}
          </td>
          <td>
            <div class="actions">
              <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-show">Voir</a>
              <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn-edit">Modifier</a>
              <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" onsubmit="return confirm('Supprimer cette formation ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                <button class="btn-delete">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr class="empty-row"><td colspan="7">Aucune formation trouvée</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<script>
function filterTable() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const category = document.getElementById('categoryFilter').value.toLowerCase();
  const rows = document.querySelectorAll('#formationTable tbody tr');
  rows.forEach(row => {
    const title = row.cells[1]?.textContent.toLowerCase() || '';
    const cat = row.cells[3]?.textContent.toLowerCase() || '';
    const matchSearch = title.includes(search);
    const matchCat = category === '' || cat.includes(category);
    row.style.display = matchSearch && matchCat ? '' : 'none';
  });
}
</script>
</body>
</html>
{% endblock %}
