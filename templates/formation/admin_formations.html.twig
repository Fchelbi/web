{% extends 'base.html.twig' %}
{% block title %}Admin — Formations | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-dark:#0f2a4a;--blue-mid:#1a4a7a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;
    --orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;
    --gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;
    --shadow-sm:0 2px 8px rgba(15,42,74,.08);--radius:14px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700)}
  .sidebar{position:fixed;top:0;left:0;height:100vh;width:240px;background:var(--blue-dark);display:flex;flex-direction:column;padding:28px 20px;z-index:100}
  .logo{font-size:22px;font-weight:800;color:var(--white);margin-bottom:4px}.logo span{color:var(--orange)}
  .logo-sub{font-size:11px;color:var(--gray-400);text-transform:uppercase;letter-spacing:1px;margin-bottom:32px}
  .nav-label{font-size:10px;color:var(--gray-400);text-transform:uppercase;letter-spacing:1.2px;margin:20px 0 8px}
  .nav-link{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;color:rgba(255,255,255,.65);font-size:14px;font-weight:500;text-decoration:none;margin-bottom:4px;transition:.2s}
  .nav-link:hover,.nav-link.active{background:rgba(255,255,255,.1);color:var(--white)}
  .nav-link.active{background:var(--blue-light)}
  .sidebar-bottom{margin-top:auto}
  .admin-badge{background:rgba(244,132,95,.2);color:var(--orange);border-radius:8px;padding:10px 14px;font-size:13px;font-weight:600}
  .main{margin-left:240px;padding:36px 40px}
  .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}
  .page-title{font-size:26px;font-weight:800;color:var(--blue-dark)}.page-title span{color:var(--blue-light)}
  .btn-new{background:var(--orange);color:var(--white);border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:8px;transition:.2s;box-shadow:0 4px 12px rgba(244,132,95,.35)}
  .btn-new:hover{background:#e06d47;transform:translateY(-1px)}
  .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:28px}
  .stat-card{background:var(--white);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:16px}
  .stat-icon{width:50px;height:50px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px}
  .si-blue{background:var(--blue-pale)}.si-orange{background:var(--orange-soft)}.si-green{background:#e8f8f0}
  .stat-value{font-size:28px;font-weight:800;color:var(--blue-dark)}.stat-label{font-size:13px;color:var(--gray-400)}
  .toolbar{background:var(--white);border-radius:var(--radius);padding:18px 24px;box-shadow:var(--shadow-sm);display:flex;gap:14px;align-items:center;margin-bottom:24px;flex-wrap:wrap}
  .search-wrap{position:relative;flex:1;min-width:200px}
  .search-wrap input{width:100%;padding:10px 14px 10px 40px;border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-family:inherit;outline:none;transition:.2s}
  .search-wrap input:focus{border-color:var(--blue-light)}
  .search-wrap::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%)}
  .filter-select{padding:10px 14px;border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-family:inherit;color:var(--gray-700);outline:none;background:var(--white);cursor:pointer}
  .btn-pdf{background:var(--blue-pale);color:var(--blue-light);border:none;border-radius:10px;padding:10px 18px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:6px;transition:.2s}
  .btn-pdf:hover{background:var(--blue-light);color:var(--white)}
  .table-card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden}
  table{width:100%;border-collapse:collapse}
  thead th{background:var(--blue-dark);color:rgba(255,255,255,.75);padding:14px 20px;text-align:left;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.8px}
  tbody tr{border-bottom:1px solid var(--gray-200);transition:.15s}
  tbody tr:hover{background:var(--gray-100)}
  tbody td{padding:15px 20px;font-size:14px}
  .badge{display:inline-block;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600}
  .badge-blue{background:var(--blue-pale);color:var(--blue-light)}
  .badge-orange{background:var(--orange-soft);color:var(--orange)}
  .badge-green{background:#e8f8f0;color:#27ae60}
  .actions{display:flex;gap:8px;align-items:center}
  .btn-show{background:var(--blue-pale);color:var(--blue-light);border:none;border-radius:8px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none}
  .btn-edit{background:#fff8e1;color:#f59e0b;border:none;border-radius:8px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer;text-decoration:none}
  .btn-del{background:#fff0f0;color:#ef4444;border:none;border-radius:8px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer}
</style>

<div class="sidebar">
  <div class="logo">Echo<span>Care</span></div>
  <div class="logo-sub">Admin Panel</div>
  <div class="nav-label">Gestion</div>
  <a href="{{ path('app_formation_index') }}" class="nav-link active">📚 Formations</a>
  <a href="#" class="nav-link">👥 Utilisateurs</a>
  <a href="#" class="nav-link">📊 Rapports</a>
  <div class="sidebar-bottom">
    <div class="admin-badge">👤 Administrateur</div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <div class="page-title">Gestion des <span>Formations</span></div>
    <a href="{{ path('app_formation_new') }}" class="btn-new">＋ Nouvelle Formation</a>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon si-blue">📚</div>
      <div><div class="stat-value">{{ formations|length }}</div><div class="stat-label">Total Formations</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon si-orange">🎥</div>
      <div><div class="stat-value">{{ formations|filter(f => f.videoUrl is not null)|length }}</div><div class="stat-label">Avec Vidéo</div></div>
    </div>
    <div class="stat-card">
      <div class="stat-icon si-green">✅</div>
      <div><div class="stat-value">{{ formations|length }}</div><div class="stat-label">Formations Actives</div></div>
    </div>
  </div>

  <div class="toolbar">
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher une formation..." id="searchInput" onkeyup="filterTable()">
    </div>
    <select class="filter-select" id="catFilter" onchange="filterTable()">
      <option value="">Toutes les catégories</option>
      {% set cats = [] %}
      {% for f in formations %}
        {% if f.category and f.category not in cats %}
          {% set cats = cats|merge([f.category]) %}
          <option value="{{ f.category }}">{{ f.category }}</option>
        {% endif %}
      {% endfor %}
    </select>
    <a href="{{ path('app_formation_index') }}?pdf=1" class="btn-pdf" id="pdfBtn">📄 Exporter PDF</a>
  </div>

  <div class="table-card">
    <table id="formationTable">
      <thead>
        <tr>
          <th>Titre</th>
          <th>Description</th>
          <th>Catégorie</th>
          <th>Vidéo</th>
          <th>Coach</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for formation in formations %}
        <tr data-title="{{ formation.title|lower }}" data-cat="{{ formation.category|lower }}">
          <td><strong>{{ formation.title }}</strong></td>
          <td>{{ formation.description|slice(0,60) }}{% if formation.description|length > 60 %}...{% endif %}</td>
          <td>
            {% if formation.category %}
              <span class="badge badge-blue">{{ formation.category }}</span>
            {% else %}<span class="badge badge-orange">—</span>{% endif %}
          </td>
          <td>
            {% if formation.videoUrl %}
              <span class="badge badge-green">✓ Oui</span>
            {% else %}<span class="badge badge-orange">✗ Non</span>{% endif %}
          </td>
          <td>{{ formation.coachId ?? '—' }}</td>
          <td>
            <div class="actions">
              <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-show">Voir</a>
              <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn-edit">Modifier</a>
              <form method="post" action="{{ path('app_formation_delete', {'id': formation.id}) }}" onsubmit="return confirm('Supprimer cette formation ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                <button class="btn-del">Supprimer</button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--gray-400)">Aucune formation trouvée</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
<script>
function filterTable() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const cat = document.getElementById('catFilter').value.toLowerCase();
  document.querySelectorAll('#formationTable tbody tr[data-title]').forEach(row => {
    const title = row.dataset.title || '';
    const rowCat = row.dataset.cat || '';
    row.style.display = (title.includes(search) && (cat === '' || rowCat === cat)) ? '' : 'none';
  });
}

document.getElementById('pdfBtn').addEventListener('click', function(e) {
  e.preventDefault();
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();
  doc.setFontSize(16);
  doc.text('EchoCare - Liste des Formations', 14, 15);
  const rows = [];
  document.querySelectorAll('#formationTable tbody tr[data-title]').forEach(row => {
    if (row.style.display !== 'none') {
      const cells = row.querySelectorAll('td');
      rows.push([
        cells[0]?.innerText || '',
        cells[1]?.innerText || '',
        cells[2]?.innerText || '',
        cells[3]?.innerText || '',
        cells[4]?.innerText || '',
      ]);
    }
  });
  doc.autoTable({
    head: [['Titre', 'Description', 'Catégorie', 'Vidéo', 'Coach']],
    body: rows,
    startY: 25,
    styles: { fontSize: 10 },
    headStyles: { fillColor: [15, 42, 74] }
  });
  doc.save('formations-echocare.pdf');
});
</script>
{% endblock %}
