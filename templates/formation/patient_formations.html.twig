{% extends 'base.html.twig' %}
{% block title %}Formations Disponibles{% endblock %}
{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-dark:  #0f2a4a;
    --blue-light: #2d7dd2;
    --blue-pale:  #e8f2ff;
    --orange:     #f4845f;
    --orange-soft:#fff3ef;
    --white:      #ffffff;
    --gray-100:   #f7f9fc;
    --gray-200:   #eef2f7;
    --gray-400:   #94a3b8;
    --gray-700:   #374151;
    --radius:     16px;
    --shadow-sm:  0 2px 8px rgba(15,42,74,0.08);
    --shadow-md:  0 6px 24px rgba(15,42,74,0.12);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--gray-100); color: var(--gray-700); }

  /* NAV */
  nav {
    background: var(--white); box-shadow: var(--shadow-sm);
    padding: 0 40px; display: flex; align-items: center;
    justify-content: space-between; height: 64px; position: sticky; top: 0; z-index: 100;
  }
  .nav-logo { font-size: 20px; font-weight: 800; color: var(--blue-dark); }
  .nav-logo span { color: var(--orange); }
  .nav-links { display: flex; gap: 6px; }
  .nav-link {
    padding: 8px 16px; border-radius: 8px;
    color: var(--gray-700); font-size: 14px; font-weight: 500;
    text-decoration: none; transition: all 0.15s;
  }
  .nav-link:hover { background: var(--gray-100); }
  .nav-link.active { background: var(--blue-pale); color: var(--blue-light); font-weight: 600; }
  .nav-user {
    display: flex; align-items: center; gap: 10px;
  }
  .user-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-light), var(--blue-dark));
    color: var(--white); display: flex; align-items: center;
    justify-content: center; font-weight: 700; font-size: 14px;
  }
  .user-name { font-size: 14px; font-weight: 600; color: var(--blue-dark); }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--blue-dark) 0%, #1e4d8c 60%, #2d7dd2 100%);
    padding: 56px 40px; position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; top: -60px; right: -60px;
    width: 300px; height: 300px; border-radius: 50%;
    background: rgba(244,132,95,0.12);
  }
  .hero::after {
    content: ''; position: absolute; bottom: -80px; left: 30%;
    width: 200px; height: 200px; border-radius: 50%;
    background: rgba(255,255,255,0.05);
  }
  .hero-content { max-width: 600px; position: relative; z-index: 1; }
  .hero-tag {
    background: rgba(244,132,95,0.2); color: var(--orange);
    border-radius: 20px; padding: 5px 14px; font-size: 12px; font-weight: 700;
    display: inline-block; margin-bottom: 14px; letter-spacing: 0.5px;
  }
  .hero-title { font-size: 36px; font-weight: 800; color: var(--white); line-height: 1.2; margin-bottom: 12px; }
  .hero-title span { color: var(--orange); }
  .hero-sub { color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.6; }

  /* MAIN */
  .container { max-width: 1200px; margin: 0 auto; padding: 36px 40px; }

  /* FILTERS */
  .filters-bar {
    background: var(--white); border-radius: var(--radius);
    padding: 18px 24px; box-shadow: var(--shadow-sm);
    display: flex; gap: 12px; align-items: center; margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .search-box { position: relative; flex: 1; min-width: 200px; }
  .search-box input {
    width: 100%; padding: 10px 14px 10px 40px;
    border: 1.5px solid var(--gray-200); border-radius: 10px;
    font-size: 14px; font-family: inherit; outline: none; transition: border 0.2s;
  }
  .search-box input:focus { border-color: var(--blue-light); }
  .search-box::before { content: '🔍'; position: absolute; left: 12px; top: 50%; transform: translateY(-50%); }
  .filter-btn {
    padding: 10px 18px; border-radius: 10px; border: 1.5px solid var(--gray-200);
    background: var(--white); font-size: 13px; font-weight: 600;
    cursor: pointer; color: var(--gray-700); transition: all 0.15s; font-family: inherit;
  }
  .filter-btn:hover, .filter-btn.active { background: var(--blue-light); color: var(--white); border-color: var(--blue-light); }

  /* SECTION TITLE */
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
  .section-title { font-size: 20px; font-weight: 800; color: var(--blue-dark); }
  .section-count { background: var(--blue-pale); color: var(--blue-light); border-radius: 20px; padding: 3px 12px; font-size: 13px; font-weight: 700; }

  /* CARDS */
  .formations-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }
  .formation-card {
    background: var(--white); border-radius: var(--radius);
    box-shadow: var(--shadow-sm); overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column;
  }
  .formation-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); }
  .card-video-thumb {
    height: 160px;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue-light));
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .card-video-thumb::before {
    content: '▶'; font-size: 40px; color: rgba(255,255,255,0.8);
    width: 64px; height: 64px; background: rgba(255,255,255,0.15);
    border-radius: 50%; display: flex; align-items: center;
    justify-content: center; backdrop-filter: blur(4px);
  }
  .card-no-video {
    height: 160px;
    background: var(--gray-200);
    display: flex; align-items: center; justify-content: center;
    font-size: 48px;
  }
  .category-ribbon {
    position: absolute; top: 12px; left: 12px;
    background: rgba(0,0,0,0.4); color: var(--white);
    border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600;
    backdrop-filter: blur(4px);
  }
  .card-body { padding: 20px 22px; flex: 1; display: flex; flex-direction: column; }
  .card-title { font-size: 17px; font-weight: 700; color: var(--blue-dark); margin-bottom: 8px; line-height: 1.3; }
  .card-desc { font-size: 13px; color: var(--gray-400); line-height: 1.6; flex: 1; margin-bottom: 16px; }
  .card-footer { display: flex; gap: 10px; align-items: center; }
  .btn-enroll {
    flex: 1; background: linear-gradient(135deg, var(--blue-light), var(--blue-dark));
    color: var(--white); border: none; border-radius: 10px;
    padding: 11px; font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none; text-align: center;
    transition: all 0.2s; box-shadow: 0 4px 12px rgba(45,125,210,0.3);
  }
  .btn-enroll:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(45,125,210,0.4); }
  .btn-enrolled {
    flex: 1; background: #e8f8f0; color: #2ecc71;
    border: none; border-radius: 10px;
    padding: 11px; font-size: 14px; font-weight: 700; text-align: center;
  }
  .btn-view {
    background: var(--gray-100); color: var(--gray-700);
    border: none; border-radius: 10px;
    padding: 11px 16px; font-size: 13px; font-weight: 600;
    cursor: pointer; text-decoration: none; text-align: center;
    transition: background 0.15s;
  }
  .btn-view:hover { background: var(--gray-200); }

  /* MY FORMATIONS */
  .my-section { margin-top: 48px; }
  .my-formations-list { display: flex; flex-direction: column; gap: 12px; }
  .my-formation-row {
    background: var(--white); border-radius: var(--radius);
    padding: 18px 22px; box-shadow: var(--shadow-sm);
    display: flex; align-items: center; gap: 16px;
    transition: transform 0.15s;
  }
  .my-formation-row:hover { transform: translateX(4px); }
  .my-icon {
    width: 46px; height: 46px; border-radius: 12px;
    background: var(--blue-pale); color: var(--blue-light);
    display: flex; align-items: center; justify-content: center; font-size: 20px;
    flex-shrink: 0;
  }
  .my-title { font-size: 15px; font-weight: 700; color: var(--blue-dark); }
  .my-category { font-size: 12px; color: var(--gray-400); margin-top: 2px; }
  .my-actions { margin-left: auto; display: flex; gap: 8px; }
  .btn-continue {
    background: var(--orange-soft); color: var(--orange);
    border: none; border-radius: 8px; padding: 8px 16px;
    font-size: 13px; font-weight: 700; cursor: pointer;
    text-decoration: none; transition: all 0.15s;
  }
  .btn-continue:hover { background: var(--orange); color: var(--white); }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Health<span>Connect</span></div>
  <div class="nav-links">
    <a href="#" class="nav-link active">📚 Formations</a>
    <a href="#" class="nav-link">💬 Messages</a>
    <a href="#" class="nav-link">📊 Mon Progrès</a>
  </div>
  <div class="nav-user">
    <div class="user-avatar">P</div>
    <div class="user-name">Mon Profil</div>
  </div>
</nav>

<div class="hero">
  <div class="hero-content">
    <div class="hero-tag">🎯 Formations Disponibles</div>
    <div class="hero-title">Développez vos <span>compétences</span> santé</div>
    <div class="hero-sub">Découvrez des formations créées par nos coachs experts et progressez à votre rythme.</div>
  </div>
</div>

<div class="container">

  <div class="filters-bar">
    <div class="search-box">
      <input type="text" placeholder="Rechercher une formation..." id="searchInput" onkeyup="filterCards()">
    </div>
    <button class="filter-btn active" onclick="filterBy('', this)">Toutes</button>
    {% for formation in formations %}
      {% if formation.category %}
        <button class="filter-btn" onclick="filterBy('{{ formation.category }}', this)">{{ formation.category }}</button>
      {% endif %}
    {% endfor %}
  </div>

  <div class="section-header">
    <div class="section-title">Toutes les Formations</div>
    <div class="section-count">{{ formations|length }} formations</div>
  </div>

  <div class="formations-grid" id="formationsGrid">
    {% for formation in formations %}
    <div class="formation-card" data-category="{{ formation.category }}" data-title="{{ formation.title|lower }}">
      {% if formation.videoUrl %}
        <div class="card-video-thumb">
          {% if formation.category %}<div class="category-ribbon">{{ formation.category }}</div>{% endif %}
        </div>
      {% else %}
        <div class="card-no-video">📚</div>
      {% endif %}
      <div class="card-body">
        <div class="card-title">{{ formation.title }}</div>
        <div class="card-desc">
          {{ formation.description|slice(0, 120) }}{% if formation.description|length > 120 %}...{% endif %}
        </div>
        <div class="card-footer">
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-enroll">S'inscrire</a>
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-view">Voir</a>
        </div>
      </div>
    </div>
    {% else %}
    <p style="color:var(--gray-400); grid-column: 1/-1; text-align:center; padding: 40px">Aucune formation disponible pour le moment.</p>
    {% endfor %}
  </div>

  <!-- MY ENROLLED FORMATIONS -->
  <div class="my-section">
    <div class="section-header">
      <div class="section-title">Mes Formations Inscrites</div>
    </div>
    <div class="my-formations-list">
      <div class="my-formation-row">
        <div class="my-icon">📚</div>
        <div>
          <div class="my-title">Vos inscriptions apparaîtront ici</div>
          <div class="my-category">Inscrivez-vous à une formation ci-dessus</div>
        </div>
        <div class="my-actions">
          <a href="#" class="btn-continue">Continuer →</a>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
function filterCards() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  document.querySelectorAll('.formation-card').forEach(card => {
    const title = card.dataset.title || '';
    card.style.display = title.includes(search) ? '' : 'none';
  });
}
function filterBy(category, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.formation-card').forEach(card => {
    card.style.display = (category === '' || card.dataset.category === category) ? '' : 'none';
  });
}
</script>
</body>
</html>
{% endblock %}
