{% extends 'base.html.twig' %}
{% block title %}Formations | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--radius:16px;--shadow-sm:0 2px 8px rgba(15,42,74,.08);--shadow-md:0 6px 24px rgba(15,42,74,.12)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700)}
  nav{background:#fff;box-shadow:var(--shadow-sm);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:64px;position:sticky;top:0;z-index:100}
  .nav-logo{font-size:20px;font-weight:800;color:var(--blue-dark)}.nav-logo span{color:var(--orange)}
  .nav-links{display:flex;gap:6px}
  .nav-link{padding:8px 16px;border-radius:8px;color:var(--gray-700);font-size:14px;font-weight:500;text-decoration:none;transition:.15s}
  .nav-link:hover{background:var(--gray-100)}.nav-link.active{background:var(--blue-pale);color:var(--blue-light);font-weight:600}
  .nav-user{display:flex;align-items:center;gap:10px}
  .user-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--blue-light),var(--blue-dark));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px}
  .hero{background:linear-gradient(135deg,var(--blue-dark) 0%,#1e4d8c 60%,#2d7dd2 100%);padding:48px 40px;position:relative;overflow:hidden}
  .hero::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;border-radius:50%;background:rgba(244,132,95,.12)}
  .hero-tag{background:rgba(244,132,95,.2);color:var(--orange);border-radius:20px;padding:5px 14px;font-size:12px;font-weight:700;display:inline-block;margin-bottom:14px}
  .hero-title{font-size:32px;font-weight:800;color:#fff;line-height:1.2;margin-bottom:10px}.hero-title span{color:var(--orange)}
  .hero-sub{color:rgba(255,255,255,.7);font-size:15px}
  .container{max-width:1200px;margin:0 auto;padding:36px 40px}
  .filters-bar{background:#fff;border-radius:var(--radius);padding:18px 24px;box-shadow:var(--shadow-sm);display:flex;gap:12px;align-items:center;margin-bottom:28px;flex-wrap:wrap}
  .search-box{position:relative;flex:1;min-width:200px}
  .search-box input{width:100%;padding:10px 14px 10px 40px;border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-family:inherit;outline:none;transition:.2s}
  .search-box input:focus{border-color:var(--blue-light)}
  .search-box::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%)}
  .filter-btn{padding:9px 16px;border-radius:10px;border:1.5px solid var(--gray-200);background:#fff;font-size:13px;font-weight:600;cursor:pointer;color:var(--gray-700);transition:.15s;font-family:inherit}
  .filter-btn:hover,.filter-btn.active{background:var(--blue-light);color:#fff;border-color:var(--blue-light)}
  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
  .section-title{font-size:20px;font-weight:800;color:var(--blue-dark)}
  .section-count{background:var(--blue-pale);color:var(--blue-light);border-radius:20px;padding:3px 12px;font-size:13px;font-weight:700}
  .formations-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px}
  .formation-card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;transition:.2s;display:flex;flex-direction:column}
  .formation-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-md)}
  .formation-card.hidden{display:none}
  .card-thumb{height:150px;background:linear-gradient(135deg,var(--blue-dark),var(--blue-light));display:flex;align-items:center;justify-content:center;position:relative;font-size:44px}
  .card-thumb.enrolled{background:linear-gradient(135deg,#1a7a4a,#27ae60)}
  .cat-ribbon{position:absolute;top:10px;left:10px;background:rgba(0,0,0,.4);color:#fff;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;backdrop-filter:blur(4px)}
  .enrolled-ribbon{position:absolute;top:10px;right:10px;background:rgba(39,174,96,.9);color:#fff;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700}
  .card-body{padding:18px 20px;flex:1;display:flex;flex-direction:column}
  .card-title{font-size:16px;font-weight:700;color:var(--blue-dark);margin-bottom:6px}
  .card-coach{font-size:12px;color:var(--gray-400);margin-bottom:10px;display:flex;align-items:center;gap:5px}
  .card-desc{font-size:13px;color:var(--gray-400);line-height:1.6;flex:1;margin-bottom:14px}
  .card-footer{display:flex;gap:8px}
  .btn-enroll{flex:1;background:linear-gradient(135deg,var(--blue-light),var(--blue-dark));color:#fff;border:none;border-radius:10px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;text-align:center;transition:.2s;box-shadow:0 4px 12px rgba(45,125,210,.3)}
  .btn-enroll:hover{transform:translateY(-1px)}
  .btn-enrolled{flex:1;background:#e8f8f0;color:#27ae60;border:none;border-radius:10px;padding:10px;font-size:13px;font-weight:700;text-align:center}
  .btn-view{background:var(--gray-100);color:var(--gray-700);border:none;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;text-align:center;transition:.15s}
  .btn-view:hover{background:var(--gray-200)}
  .my-section{margin-top:48px}
  .my-list{display:flex;flex-direction:column;gap:12px}
  .my-row{background:#fff;border-radius:var(--radius);padding:18px 22px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:16px;transition:.15s}
  .my-row:hover{transform:translateX(4px)}
  .my-icon{width:46px;height:46px;border-radius:12px;background:var(--blue-pale);color:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
  .my-title{font-size:15px;font-weight:700;color:var(--blue-dark)}
  .my-coach{font-size:12px;color:var(--gray-400);margin-top:2px}
  .my-actions{margin-left:auto;display:flex;gap:8px}
  .btn-continue{background:var(--orange-soft);color:var(--orange);border:none;border-radius:8px;padding:8px 16px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;transition:.15s}
  .btn-continue:hover{background:var(--orange);color:#fff}
  .flash{padding:14px 20px;border-radius:10px;margin-bottom:20px;font-weight:600}
  .flash-success{background:#e8f8f0;color:#27ae60}
  .flash-info{background:var(--blue-pale);color:var(--blue-light)}
  .no-cards-msg{text-align:center;padding:40px;background:#fff;border-radius:var(--radius);color:var(--gray-400);display:none;grid-column:1/-1}
  /* ---- Pagination ---- */
  .pagination{display:flex;align-items:center;justify-content:center;gap:8px;padding:22px 0 6px}
  .pg-btn{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:9px;font-size:14px;font-weight:600;border:1.5px solid var(--gray-200);background:#fff;color:var(--gray-700);text-decoration:none;transition:.15s}
  .pg-btn:hover{border-color:var(--blue-light);color:var(--blue-light)}
  .pg-btn.active{background:var(--blue-light);color:#fff;border-color:var(--blue-light)}
  .pg-btn.disabled{opacity:.4;pointer-events:none}
  .pg-info{font-size:13px;color:var(--gray-400);margin-left:8px}
</style>

<nav>
  <div class="nav-logo">Echo<span>Care</span></div>
  <div class="nav-links">
    <a href="{{ path('app_formation_index') }}" class="nav-link active">📚 Formations</a>
    <a href="#" class="nav-link">💬 Messages</a>
    <a href="#" class="nav-link">📊 Mon Progrès</a>
  </div>
  <div class="nav-user">
    <div class="user-avatar">P</div>
    <span style="font-size:14px;font-weight:600;color:var(--blue-dark)">Mon Profil</span>
  </div>
</nav>

<div class="hero">
  <div class="hero-tag">🎯 Formations Disponibles</div>
  <div class="hero-title">Développez vos <span>compétences</span> santé</div>
  <div class="hero-sub">Découvrez des formations créées par nos coachs experts.</div>
</div>

<div class="container">
  {% for message in app.flashes('success') %}
    <div class="flash flash-success">✅ {{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('info') %}
    <div class="flash flash-info">ℹ️ {{ message }}</div>
  {% endfor %}

  <div class="filters-bar">
    <div class="search-box">
      {# Live search: filters cards instantly without page reload #}
      <input type="text" placeholder="Rechercher une formation…" id="searchInput">
    </div>
    <button class="filter-btn active" onclick="filterBy('', this)" id="btnAll">Toutes</button>
    {% set cats = [] %}
    {% for f in formations %}
      {% if f.category is not null and f.category not in cats %}
        {% set cats = cats|merge([f.category]) %}
        <button class="filter-btn" onclick="filterBy('{{ f.category|lower }}', this)">{{ f.category }}</button>
      {% endif %}
    {% endfor %}
  </div>

  {# ---- All formations ---- #}
  <div class="section-header">
    <div class="section-title">Toutes les Formations</div>
    <div class="section-count" id="visibleCount">{{ formations|length }} formations</div>
  </div>

  <div class="formations-grid" id="formationsGrid">
    {% for formation in formations %}
    {% set isEnrolled = formation.id in enrolledIds %}
    <div class="formation-card"
         data-cat="{{ formation.category is not null ? formation.category|lower : '' }}"
         data-title="{{ formation.title|lower }}"
         data-desc="{{ formation.description|lower }}">
      <div class="card-thumb {{ isEnrolled ? 'enrolled' : '' }}">
        📚
        {% if formation.category is not null %}
          <div class="cat-ribbon">{{ formation.category }}</div>
        {% endif %}
        {% if isEnrolled %}<div class="enrolled-ribbon">✓ Inscrit</div>{% endif %}
      </div>
      <div class="card-body">
        <div class="card-title">{{ formation.title }}</div>
        <div class="card-coach">
          👨‍🏫 Coach :
          {% if formation.coachId is not null and coachMap[formation.coachId] is defined %}
            {{ coachMap[formation.coachId] }}
          {% else %}EchoCare{% endif %}
        </div>
        <div class="card-desc">{{ formation.description|slice(0,110) }}{% if formation.description|length > 110 %}…{% endif %}</div>
        <div class="card-footer">
          {% if isEnrolled %}
            <div class="btn-enrolled">✓ Déjà inscrit</div>
          {% else %}
            {#
              Pass CSRF token — the enroll action will receive the User entity
              correctly because we fixed the controller to pass $patientUser (the entity)
              instead of a raw int.
            #}
            <form method="post" action="{{ path('app_formation_enroll', {'id': formation.id}) }}" style="flex:1">
              <input type="hidden" name="_token" value="{{ csrf_token('enroll' ~ formation.id) }}">
              <button type="submit" class="btn-enroll" style="width:100%">S'inscrire</button>
            </form>
          {% endif %}
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-view">Voir</a>
        </div>
      </div>
    </div>
    {% else %}
    <p style="color:var(--gray-400);grid-column:1/-1;text-align:center;padding:40px">Aucune formation disponible.</p>
    {% endfor %}

    {# Shown by JS when search yields no results #}
    <div class="no-cards-msg" id="noCardsMsg">Aucune formation ne correspond à votre recherche.</div>
  </div>

  {# ---- Pagination ---- #}
  {% if totalPages > 1 %}
  <div class="pagination">
    <a href="{{ path('app_formation_index', {'page': max(1, page-1)}) }}"
       class="pg-btn {% if page <= 1 %}disabled{% endif %}">‹</a>
    {% for p in 1..totalPages %}
      {% if p == 1 or p == totalPages or (p >= page - 2 and p <= page + 2) %}
        <a href="{{ path('app_formation_index', {'page': p}) }}"
           class="pg-btn {% if p == page %}active{% endif %}">{{ p }}</a>
      {% elseif p == page - 3 or p == page + 3 %}
        <span class="pg-btn" style="border:none;background:none;cursor:default">…</span>
      {% endif %}
    {% endfor %}
    <a href="{{ path('app_formation_index', {'page': min(totalPages, page+1)}) }}"
       class="pg-btn {% if page >= totalPages %}disabled{% endif %}">›</a>
    <span class="pg-info">Page {{ page }} / {{ totalPages }}</span>
  </div>
  {% endif %}

  {# ---- My enrolled formations ---- #}
  <div class="my-section">
    <div class="section-header">
      <div class="section-title">📌 Mes Formations Inscrites</div>
      <div class="section-count">{{ enrolledIds|length }} inscriptions</div>
    </div>
    <div class="my-list">
      {% for formation in formations %}
        {% if formation.id in enrolledIds %}
          <div class="my-row">
            <div class="my-icon">📚</div>
            <div>
              <div class="my-title">{{ formation.title }}</div>
              <div class="my-coach">
                Coach :
                {% if formation.coachId is not null and coachMap[formation.coachId] is defined %}
                  {{ coachMap[formation.coachId] }}
                {% else %}EchoCare{% endif %}
              </div>
            </div>
            <div class="my-actions">
              <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-continue">Continuer →</a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      {% if enrolledIds|length == 0 %}
        <div style="text-align:center;padding:30px;background:#fff;border-radius:var(--radius);color:var(--gray-400)">
          Vous n'êtes inscrit à aucune formation. Inscrivez-vous ci-dessus !
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
// ---- Shared state ----
let activeSearch = '';
let activeCat    = '';

function applyFilters() {
  let visible = 0;
  document.querySelectorAll('#formationsGrid .formation-card').forEach(card => {
    const matchSearch = !activeSearch ||
      (card.dataset.title || '').includes(activeSearch) ||
      (card.dataset.desc  || '').includes(activeSearch);
    const matchCat = !activeCat || (card.dataset.cat || '') === activeCat;
    const show = matchSearch && matchCat;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  const msg = document.getElementById('noCardsMsg');
  if (msg) msg.style.display = visible === 0 ? 'block' : 'none';
  const cnt = document.getElementById('visibleCount');
  if (cnt) cnt.textContent = visible + ' formation' + (visible !== 1 ? 's' : '');
}

// ---- Live search ----
document.getElementById('searchInput').addEventListener('input', function () {
  activeSearch = this.value.toLowerCase().trim();
  applyFilters();
});

// ---- Category filter buttons ----
function filterBy(cat, btn) {
  activeCat = cat.toLowerCase();
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}
</script>
{% endblock %}
