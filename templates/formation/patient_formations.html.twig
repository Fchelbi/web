{% extends 'base.html.twig' %}
{% block title %}Formations | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0a1628;--navy-mid:#132240;
    --accent:#e8734a;--accent-glow:rgba(232,115,74,.25);
    --cyan:#38bdf8;--cyan-pale:rgba(56,189,248,.08);--cyan-glow:rgba(56,189,248,.15);
    --emerald:#34d399;--emerald-pale:rgba(52,211,153,.08);
    --violet:#a78bfa;
    --surface:#f8fafc;--surface-card:#ffffff;
    --border:#e2e8f0;--border-light:#f1f5f9;
    --text-primary:#0f172a;--text-secondary:#64748b;--text-muted:#94a3b8;
    --radius:16px;--radius-sm:10px;--radius-xs:8px;
    --shadow-sm:0 1px 3px rgba(10,22,40,.06);
    --shadow-md:0 4px 16px rgba(10,22,40,.08);
    --shadow-lg:0 12px 40px rgba(10,22,40,.12);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--text-primary);-webkit-font-smoothing:antialiased}

  @keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeInScale{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
  @keyframes slideDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
  @keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

  /* Navbar */
  nav{background:var(--surface-card);border-bottom:1px solid var(--border-light);padding:0 44px;display:flex;align-items:center;justify-content:space-between;height:68px;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px);background:rgba(255,255,255,.85)}
  .nav-logo{font-family:'Outfit',sans-serif;font-size:22px;font-weight:900;color:var(--text-primary);letter-spacing:-.5px}
  .nav-logo span{background:linear-gradient(135deg,var(--accent),#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .nav-links{display:flex;gap:4px}
  .nav-link{padding:9px 18px;border-radius:var(--radius-xs);color:var(--text-secondary);font-size:14px;font-weight:500;text-decoration:none;transition:all .2s}
  .nav-link:hover{background:var(--surface);color:var(--text-primary)}
  .nav-link.active{background:var(--cyan-pale);color:var(--cyan);font-weight:600}
  .nav-user{display:flex;align-items:center;gap:10px}
  .user-avatar{width:38px;height:38px;border-radius:12px;background:linear-gradient(135deg,var(--cyan),var(--violet));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px}

  /* Hero */
  .hero{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 50%,#1b3a6a 100%);padding:56px 44px;position:relative;overflow:hidden}
  .hero::before{content:'';position:absolute;top:-100px;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(232,115,74,.1),transparent);pointer-events:none}
  .hero::after{content:'';position:absolute;bottom:-80px;left:20%;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,.06),transparent);pointer-events:none}
  .hero-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(232,115,74,.15);border:1px solid rgba(232,115,74,.2);color:var(--accent);border-radius:24px;padding:6px 16px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:18px;animation:fadeInUp .5s ease both}
  .hero-title{font-family:'Outfit',sans-serif;font-size:36px;font-weight:900;color:#fff;line-height:1.15;margin-bottom:12px;letter-spacing:-.5px;animation:fadeInUp .5s ease both;animation-delay:.1s}
  .hero-title span{background:linear-gradient(135deg,var(--accent),#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
  .hero-sub{color:rgba(255,255,255,.6);font-size:16px;line-height:1.6;max-width:500px;animation:fadeInUp .5s ease both;animation-delay:.2s}

  .container{max-width:1200px;margin:0 auto;padding:40px 44px}

  /* Filters */
  .filters-bar{background:var(--surface-card);border-radius:var(--radius);padding:18px 24px;box-shadow:var(--shadow-sm);display:flex;gap:12px;align-items:center;margin-bottom:32px;flex-wrap:wrap;border:1px solid var(--border-light);animation:fadeInUp .5s ease both;animation-delay:.25s}
  .search-box{position:relative;flex:1;min-width:220px}
  .search-box input{width:100%;padding:11px 18px 11px 46px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-family:inherit;outline:none;transition:all .25s;background:var(--surface);color:var(--text-primary)}
  .search-box input:focus{border-color:var(--cyan);box-shadow:0 0 0 3px var(--cyan-glow);background:#fff}
  .search-box input::placeholder{color:var(--text-muted)}
  .search-box::before{content:'🔍';position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:14px;pointer-events:none}
  .filter-btn{padding:10px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:#fff;font-size:13px;font-weight:600;cursor:pointer;color:var(--text-secondary);transition:all .2s;font-family:inherit}
  .filter-btn:hover{border-color:var(--cyan);color:var(--cyan);transform:translateY(-1px)}
  .filter-btn.active{background:var(--navy);color:#fff;border-color:var(--navy);box-shadow:0 4px 12px rgba(10,22,40,.2)}

  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;animation:fadeInUp .5s ease both;animation-delay:.3s}
  .section-title{font-family:'Outfit',sans-serif;font-size:22px;font-weight:800;color:var(--text-primary)}
  .section-count{background:var(--cyan-pale);color:var(--cyan);border-radius:24px;padding:4px 14px;font-size:12px;font-weight:700;border:1px solid rgba(56,189,248,.15)}

  /* Formation cards */
  .formations-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px}
  .formation-card{background:var(--surface-card);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;transition:all .3s ease;display:flex;flex-direction:column;border:1px solid var(--border-light);animation:fadeInScale .5s ease both}
  .formation-card:nth-child(1){animation-delay:.1s}
  .formation-card:nth-child(2){animation-delay:.17s}
  .formation-card:nth-child(3){animation-delay:.24s}
  .formation-card:nth-child(4){animation-delay:.31s}
  .formation-card:nth-child(5){animation-delay:.38s}
  .formation-card:nth-child(6){animation-delay:.45s}
  .formation-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:var(--cyan)}
  .formation-card.hidden{display:none}
  .card-thumb{height:160px;display:flex;align-items:center;justify-content:center;position:relative;font-size:48px;overflow:hidden}
  .card-thumb.default{background:linear-gradient(135deg,var(--navy),var(--navy-mid))}
  .card-thumb.default::before{content:'';position:absolute;top:-40px;right:-40px;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,.15),transparent);pointer-events:none}
  .card-thumb.enrolled{background:linear-gradient(135deg,#0f4a2e,#1a7a4a)}
  .card-thumb.enrolled::before{content:'';position:absolute;top:-40px;right:-40px;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(52,211,153,.2),transparent);pointer-events:none}
  .cat-ribbon{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.4);backdrop-filter:blur(8px);color:#fff;border-radius:24px;padding:4px 12px;font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;border:1px solid rgba(255,255,255,.1)}
  .enrolled-ribbon{position:absolute;top:12px;right:12px;background:rgba(52,211,153,.9);color:#fff;border-radius:24px;padding:4px 12px;font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase}
  .card-body{padding:22px 24px;flex:1;display:flex;flex-direction:column}
  .card-title{font-family:'Outfit',sans-serif;font-size:17px;font-weight:700;color:var(--text-primary);margin-bottom:6px;line-height:1.3}
  .card-coach{font-size:12px;color:var(--text-muted);margin-bottom:12px;display:flex;align-items:center;gap:6px;font-weight:500}
  .card-desc{font-size:13px;color:var(--text-muted);line-height:1.7;flex:1;margin-bottom:16px}
  .card-footer{display:flex;gap:8px}
  .btn-enroll{flex:1;background:linear-gradient(135deg,var(--cyan),#0ea5e9);color:#fff;border:none;border-radius:var(--radius-sm);padding:11px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;text-align:center;transition:all .25s;box-shadow:0 4px 12px var(--cyan-glow);font-family:inherit}
  .btn-enroll:hover{transform:translateY(-2px);box-shadow:0 8px 20px var(--cyan-glow)}
  .btn-enrolled{flex:1;background:var(--emerald-pale);color:var(--emerald);border:1px solid rgba(52,211,153,.15);border-radius:var(--radius-sm);padding:11px;font-size:13px;font-weight:700;text-align:center}
  .btn-view{background:var(--surface);color:var(--text-secondary);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:11px 16px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;text-align:center;transition:all .2s;font-family:inherit}
  .btn-view:hover{border-color:var(--navy);color:var(--navy);background:#fff}

  /* My enrollments section */
  .my-section{margin-top:52px;animation:fadeInUp .5s ease both;animation-delay:.5s}
  .my-list{display:flex;flex-direction:column;gap:12px}
  .my-row{background:var(--surface-card);border-radius:var(--radius);padding:20px 24px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:18px;transition:all .25s;border:1px solid var(--border-light);animation:fadeInUp .4s ease both}
  .my-row:nth-child(1){animation-delay:.55s}
  .my-row:nth-child(2){animation-delay:.6s}
  .my-row:nth-child(3){animation-delay:.65s}
  .my-row:hover{transform:translateX(6px);border-color:var(--cyan);box-shadow:var(--shadow-md)}
  .my-icon{width:50px;height:50px;border-radius:14px;background:linear-gradient(135deg,var(--cyan-pale),rgba(167,139,250,.08));border:1px solid var(--border-light);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
  .my-title{font-family:'Outfit',sans-serif;font-size:16px;font-weight:700;color:var(--text-primary)}
  .my-coach{font-size:12px;color:var(--text-muted);margin-top:3px}
  .my-actions{margin-left:auto;display:flex;gap:8px}
  .btn-continue{background:linear-gradient(135deg,var(--accent),#d4613b);color:#fff;border:none;border-radius:var(--radius-xs);padding:9px 20px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;transition:all .2s;box-shadow:0 4px 12px var(--accent-glow);font-family:inherit}
  .btn-continue:hover{transform:translateY(-2px);box-shadow:0 8px 20px var(--accent-glow)}

  .flash{padding:16px 22px;border-radius:var(--radius-sm);margin-bottom:20px;font-weight:600;animation:slideDown .4s ease both;display:flex;align-items:center;gap:10px}
  .flash-success{background:var(--emerald-pale);color:var(--emerald);border:1px solid rgba(52,211,153,.2)}
  .flash-info{background:var(--cyan-pale);color:var(--cyan);border:1px solid rgba(56,189,248,.15)}
  .no-cards-msg{text-align:center;padding:48px;background:var(--surface-card);border-radius:var(--radius);color:var(--text-muted);display:none;grid-column:1/-1;border:1px solid var(--border-light)}

  .pagination{display:flex;align-items:center;justify-content:center;gap:6px;padding:24px 0 6px}
  .pg-btn{display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border-radius:var(--radius-xs);font-size:14px;font-weight:600;border:1.5px solid var(--border);background:#fff;color:var(--text-secondary);text-decoration:none;transition:all .2s}
  .pg-btn:hover{border-color:var(--cyan);color:var(--cyan);transform:translateY(-1px)}
  .pg-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
  .pg-btn.disabled{opacity:.35;pointer-events:none}
  .pg-info{font-size:12px;color:var(--text-muted);margin-left:12px}

  /* KnpPaginator styling */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 0;
}
.pagination span.flex {
  display: flex;
  align-items: center;
  gap: 4px;
}
.pagination a,
.pagination span:not(.flex) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 38px;
  padding: 0 12px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  border: 1.5px solid #e2e8f0;
  background: #fff;
  color: #64748b;
  text-decoration: none;
  transition: all .2s;
}
.pagination a:hover {
  border-color: #38bdf8;
  color: #38bdf8;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(56,189,248,.15);
}
/* Current/active page */
.pagination span.current,
.pagination em {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 38px;
  padding: 0 12px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  background: #0a1628;
  color: #fff;
  border: 1.5px solid #0a1628;
  font-style: normal;
}
/* First/Last/Prev/Next arrows */
.pagination a[rel="prev"],
.pagination a[rel="next"] {
  font-size: 16px;
}
</style>

<nav>
  <div class="nav-logo">Echo<span>Care</span></div>
  <div class="nav-links">
    <a href="{{ path('app_formation_index') }}" class="nav-link active">📚 Formations</a>
    <a href="#" class="nav-link">💬 Messages</a>
    <a href="#" class="nav-link">📊 Mon Progrès</a>
  </div>
  <div class="nav-user">
    <div class="user-avatar">P</div>
    <span style="font-size:14px;font-weight:600">Mon Profil</span>
  </div>
</nav>

<div class="hero">
  <div class="hero-tag">🎯 Formations Disponibles</div>
  <div class="hero-title">Développez vos<br><span>compétences</span> santé</div>
  <div class="hero-sub">Découvrez des formations créées par nos coachs experts pour améliorer votre bien-être au quotidien.</div>
</div>

{# ---- Weather Health Widget ---- #}
{% if weather is defined and weather is not null %}
<div style="max-width:1200px;margin:-20px auto 0;padding:0 44px;position:relative;z-index:10">
  <div style="background:linear-gradient(135deg,#0f2a4a,#1a4a7a);border-radius:16px;padding:22px 28px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;box-shadow:0 8px 32px rgba(10,22,40,.2)">
    <img src="{{ weather.icon }}" alt="" style="width:56px;height:56px">
    <div>
      <div style="color:#fff;font-family:Outfit;font-size:28px;font-weight:800">{{ weather.temp }}°C</div>
      <div style="color:rgba(255,255,255,.6);font-size:12px">{{ weather.city }} — {{ weather.condition }}</div>
    </div>
    <div style="display:flex;gap:16px;margin-left:12px">
      <div style="text-align:center"><div style="color:var(--cyan);font-size:16px;font-weight:700">{{ weather.humidity }}%</div><div style="color:rgba(255,255,255,.4);font-size:10px;text-transform:uppercase">Humidité</div></div>
      <div style="text-align:center"><div style="color:var(--accent);font-size:16px;font-weight:700">{{ weather.wind }} km/h</div><div style="color:rgba(255,255,255,.4);font-size:10px;text-transform:uppercase">Vent</div></div>
      <div style="text-align:center"><div style="color:#fbbf24;font-size:16px;font-weight:700">{{ weather.uv }}</div><div style="color:rgba(255,255,255,.4);font-size:10px;text-transform:uppercase">UV</div></div>
    </div>
    <div style="flex:1;min-width:200px;background:rgba(255,255,255,.08);border-radius:12px;padding:14px 18px;margin-left:auto;border:1px solid rgba(255,255,255,.06)">
      <div style="color:#34d399;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">💡 Conseil Santé</div>
      <div style="color:rgba(255,255,255,.8);font-size:13px;line-height:1.5">{{ weather.healthTip }}</div>
    </div>
  </div>
</div>
{% endif %}

<div class="container">
  {% for message in app.flashes('success') %}<div class="flash flash-success">✅ {{ message }}</div>{% endfor %}
  {% for message in app.flashes('info') %}<div class="flash flash-info">ℹ️ {{ message }}</div>{% endfor %}

  <div class="filters-bar">
    <div class="search-box">
      <input type="text" placeholder="Rechercher une formation…" id="searchInput">
    </div>
    <button class="filter-btn active" onclick="filterBy('',this)" id="btnAll">Toutes</button>
    <button class="filter-btn" onclick="filterBy('nutrition',this)">Nutrition</button>
    <button class="filter-btn" onclick="filterBy('sport & fitness',this)">Sport & Fitness</button>
    <button class="filter-btn" onclick="filterBy('santé mentale',this)">Santé Mentale</button>
    <button class="filter-btn" onclick="filterBy('méditation',this)">Méditation</button>
    <button class="filter-btn" onclick="filterBy('gestion du stress',this)">Gestion du Stress</button>
    <button class="filter-btn" onclick="filterBy('autre',this)">Autre</button>
  </div>

  {# ---- AI Recommendations ---- #}
  {% if recommendations is defined and recommendations|length > 0 %}
  <div style="margin-bottom:36px;animation:fadeInUp .5s ease both;animation-delay:.2s">
    <div class="section-header">
      <div class="section-title">🎯 Recommandé pour vous</div>
      <div class="section-count">{{ recommendations|length }} suggestions</div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px">
      {% for rec in recommendations %}
      <div style="background:linear-gradient(135deg,rgba(56,189,248,.06),rgba(167,139,250,.06));border:1.5px solid rgba(56,189,248,.15);border-radius:var(--radius);padding:20px;transition:all .25s;position:relative;overflow:hidden" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(56,189,248,.15)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
        <div style="position:absolute;top:10px;right:10px;background:rgba(56,189,248,.1);color:var(--cyan);border-radius:20px;padding:3px 10px;font-size:10px;font-weight:700;letter-spacing:.5px">IA</div>
        {% if rec.videoThumbnail %}
          <img src="{{ rec.videoThumbnail }}" style="width:100%;height:100px;object-fit:cover;border-radius:8px;margin-bottom:12px">
        {% endif %}
        {% if rec.category %}<div style="font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px">{{ rec.category }}</div>{% endif %}
        <div style="font-family:Outfit;font-size:15px;font-weight:700;color:var(--text-primary);margin-bottom:6px">{{ rec.title }}</div>
        <div style="font-size:12px;color:var(--text-muted);line-height:1.6;margin-bottom:14px">{{ rec.description|slice(0,80) }}{% if rec.description|length > 80 %}…{% endif %}</div>
        <div style="display:flex;gap:8px">
          <form method="post" action="{{ path('app_formation_enroll', {'id': rec.id}) }}" style="flex:1">
            <input type="hidden" name="_token" value="{{ csrf_token('enroll' ~ rec.id) }}">
            <button type="submit" style="width:100%;background:linear-gradient(135deg,var(--cyan),#0ea5e9);color:#fff;border:none;border-radius:8px;padding:9px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit">S'inscrire</button>
          </form>
          <a href="{{ path('app_formation_show', {'id': rec.id}) }}" style="padding:9px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;color:var(--text-secondary)">Voir</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="section-header">
    <div class="section-title">Toutes les Formations</div>
    <div class="section-count" id="visibleCount">{{ formations.getTotalItemCount }} formations</div>
  </div>

  <div class="formations-grid" id="formationsGrid">
    {% for formation in formations %}
    {% set isEnrolled = formation.id in enrolledIds %}
    <div class="formation-card" data-cat="{{ formation.category is not null ? formation.category|lower : '' }}" data-title="{{ formation.title|lower }}" data-desc="{{ formation.description|lower }}">
      <div class="card-thumb {{ isEnrolled ? 'enrolled' : 'default' }}" {% if formation.videoThumbnail %}style="background-image:url('{{ formation.videoThumbnail }}');background-size:cover;background-position:center;font-size:0"{% endif %}>
        {% if not formation.videoThumbnail %}📚{% endif %}
        {% if formation.videoDuration %}
          <div style="position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.75);color:#fff;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700">⏱️ {{ formation.videoDuration }}</div>
        {% endif %}
        {% if formation.category is not null %}<div class="cat-ribbon">{{ formation.category }}</div>{% endif %}
        {% if isEnrolled %}<div class="enrolled-ribbon">✓ Inscrit</div>{% endif %}
      </div>
      <div class="card-body">
        <div class="card-title">{{ formation.title }}</div>
        <div class="card-coach">👨‍🏫 Coach : {% if formation.coachId is not null and coachMap[formation.coachId] is defined %}{{ coachMap[formation.coachId] }}{% else %}EchoCare{% endif %}</div>
        <div class="card-desc">{{ formation.description|slice(0,110) }}{% if formation.description|length > 110 %}…{% endif %}</div>
        <div class="card-footer">
          {% if isEnrolled %}
            <div class="btn-enrolled">✓ Déjà inscrit</div>
          {% else %}
            <form method="post" action="{{ path('app_formation_enroll', {'id': formation.id}) }}" style="flex:1">
              <input type="hidden" name="_token" value="{{ csrf_token('enroll' ~ formation.id) }}">
              <button type="submit" class="btn-enroll" style="width:100%">S'inscrire</button>
            </form>
          {% endif %}
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-view">Voir</a>
        </div>
      </div>
    </div>
    {% else %}
    <p style="color:var(--text-muted);grid-column:1/-1;text-align:center;padding:48px">Aucune formation disponible.</p>
    {% endfor %}
    <div class="no-cards-msg" id="noCardsMsg">Aucune formation ne correspond à votre recherche.</div>
  </div>

  <div class="pagination">
    {{ knp_pagination_render(formations) }}
  </div>

  <div class="my-section">
    <div class="section-header">
      <div class="section-title">📌 Mes Formations Inscrites</div>
      <div class="section-count">{{ enrolledIds|length }} inscriptions</div>
    </div>
    <div class="my-list">
      {% for formation in formations %}
        {% if formation.id in enrolledIds %}
          <div class="my-row">
            <div class="my-icon">📚</div>
            <div>
              <div class="my-title">{{ formation.title }}</div>
              <div class="my-coach">Coach : {% if formation.coachId is not null and coachMap[formation.coachId] is defined %}{{ coachMap[formation.coachId] }}{% else %}EchoCare{% endif %}</div>
            </div>
            <div class="my-actions">
              <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-continue">Continuer →</a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      {% if enrolledIds|length == 0 %}
        <div style="text-align:center;padding:36px;background:var(--surface-card);border-radius:var(--radius);color:var(--text-muted);border:1px solid var(--border-light)">Vous n'êtes inscrit à aucune formation. Inscrivez-vous ci-dessus !</div>
      {% endif %}
    </div>
  </div>
</div>

<script>
let activeSearch='',activeCat='';
function applyFilters(){let v=0;document.querySelectorAll('#formationsGrid .formation-card').forEach(c=>{const mS=!activeSearch||(c.dataset.title||'').includes(activeSearch)||(c.dataset.desc||'').includes(activeSearch);const mC=!activeCat||(c.dataset.cat||'')===activeCat;const show=mS&&mC;c.classList.toggle('hidden',!show);if(show)v++;});const msg=document.getElementById('noCardsMsg');if(msg)msg.style.display=v===0?'block':'none';const cnt=document.getElementById('visibleCount');if(cnt)cnt.textContent=v+' formation'+(v!==1?'s':'');}
document.getElementById('searchInput').addEventListener('input',function(){activeSearch=this.value.toLowerCase().trim();applyFilters();});
function filterBy(cat,btn){activeCat=cat.toLowerCase();document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');applyFilters();}
</script>
{% endblock %}