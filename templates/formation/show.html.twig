      {# ---- Translate Button ---- #}
<div style="margin-bottom:24px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
  <span style="font-size:11px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px">🌐 Traduire :</span>
  <button type="button" onclick="translateFormation('en')" class="translate-btn" style="background:rgba(56,189,248,.08);color:#38bdf8;border:1px solid rgba(56,189,248,.15);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s">🇬🇧 English</button>
  <button type="button" onclick="translateFormation('ar')" class="translate-btn" style="background:rgba(232,115,74,.08);color:#e8734a;border:1px solid rgba(232,115,74,.15);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s">🇸🇦 العربية</button>
  <button type="button" onclick="translateFormation('es')" class="translate-btn" style="background:rgba(52,211,153,.08);color:#34d399;border:1px solid rgba(52,211,153,.15);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s">🇪🇸 Español</button>
  <button type="button" onclick="translateFormation('tr')" class="translate-btn" style="background:rgba(167,139,250,.08);color:#a78bfa;border:1px solid rgba(167,139,250,.15);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s">🇹🇷 Türkçe</button>
  <button type="button" onclick="showOriginal()" class="translate-btn" style="background:rgba(148,163,184,.08);color:#94a3b8;border:1px solid rgba(148,163,184,.15);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:.2s">🇫🇷 Original</button>
</div>

{# Translated content area (hidden by default) #}
<div id="translatedContent" style="display:none;background:rgba(56,189,248,.04);border:1.5px solid rgba(56,189,248,.12);border-radius:12px;padding:18px 22px;margin-bottom:24px;animation:fadeIn .3s ease">
  <div style="font-size:11px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px" id="transLangLabel">🌐 Traduction</div>
  <div id="transTitle" style="font-size:18px;font-weight:700;color:var(--blue-dark);margin-bottom:8px"></div>
  <div id="transDesc" style="font-size:14px;color:var(--gray-700);line-height:1.7"></div>
</div>

<style>
.translate-btn:hover { transform:translateY(-1px); opacity:.85; }
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
</style>

<script>
var originalTitle = '{{ formation.title|e("js") }}';
var originalDesc  = '{{ (formation.description ?? "")|e("js") }}';
var formationId   = {{ formation.id }};

function translateFormation(lang) {
  var box = document.getElementById('translatedContent');
  var label = document.getElementById('transLangLabel');
  var tTitle = document.getElementById('transTitle');
  var tDesc = document.getElementById('transDesc');

  box.style.display = 'block';
  tTitle.textContent = '⏳ Traduction en cours…';
  tDesc.textContent = '';

  var langNames = {en:'English',ar:'العربية',es:'Español',de:'Deutsch',it:'Italiano',tr:'Türkçe'};
  label.textContent = '🌐 Traduction en ' + (langNames[lang] || lang);

  var xhr = new XMLHttpRequest();
  xhr.open('GET', '/formation/' + formationId + '/translate?lang=' + lang);
  xhr.onload = function() {
    if (xhr.status === 200) {
      var data = JSON.parse(xhr.responseText);
      tTitle.textContent = data.title || '—';
      tDesc.textContent = data.description || '—';
      // For Arabic, set RTL direction
      if (lang === 'ar') {
        tTitle.style.direction = 'rtl';
        tDesc.style.direction = 'rtl';
      } else {
        tTitle.style.direction = 'ltr';
        tDesc.style.direction = 'ltr';
      }
    } else {
      tTitle.textContent = '❌ Erreur de traduction';
    }
  };
  xhr.send();
}

function showOriginal() {
  document.getElementById('translatedContent').style.display = 'none';
}
</script>

