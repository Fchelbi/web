{% extends 'base.html.twig' %}
{% block title %}{{ formation.title }} | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--radius:14px;--shadow-sm:0 2px 8px rgba(15,42,74,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700);padding:40px 20px}
  .page-wrap{max-width:860px;margin:0 auto}
  .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--blue-light);font-size:14px;font-weight:600;text-decoration:none;margin-bottom:24px;transition:.15s}
  .back-link:hover{opacity:.75}
  .card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:24px}
  .card-header{background:linear-gradient(135deg,var(--blue-dark),#1a4a7a);padding:28px 32px}
  .card-badge{display:inline-block;background:rgba(255,255,255,.15);color:rgba(255,255,255,.9);border-radius:20px;padding:3px 12px;font-size:12px;font-weight:600;margin-bottom:10px}
  .card-title{font-size:26px;font-weight:800;color:#fff;margin-bottom:8px}
  .card-meta-row{display:flex;gap:16px;flex-wrap:wrap}
  .meta-item{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.7);font-size:13px}
  .card-body{padding:28px 32px}
  .section-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--gray-400);margin-bottom:10px}
  .desc-text{font-size:15px;line-height:1.8;color:var(--gray-700);margin-bottom:28px}
  /* ---- Embedded video ---- */
  .video-wrap{border-radius:12px;overflow:hidden;background:#000;position:relative;padding-top:56.25%;margin-bottom:28px}
  .video-wrap iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}
  .no-video{background:var(--gray-100);border-radius:12px;padding:32px;text-align:center;color:var(--gray-400);margin-bottom:28px}
  /* ---- Quiz section ---- */
  .quiz-card{background:var(--blue-pale);border-radius:var(--radius);padding:22px 26px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
  .quiz-title{font-size:16px;font-weight:700;color:var(--blue-dark);margin-bottom:4px}
  .quiz-sub{font-size:13px;color:var(--gray-400)}
  .btn-quiz{background:var(--blue-light);color:#fff;border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;transition:.2s;box-shadow:0 4px 12px rgba(45,125,210,.3)}
  .btn-quiz:hover{background:var(--blue-dark)}
  /* ---- Actions row (edit / back only — NO delete under video) ---- */
  .actions-row{display:flex;gap:10px;flex-wrap:wrap}
  .btn-edit{background:var(--orange-soft);color:var(--orange);border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;transition:.2s}
  .btn-edit:hover{background:var(--orange);color:#fff}
  .btn-back{background:var(--gray-100);color:var(--gray-700);border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;transition:.2s}
  .btn-back:hover{background:var(--gray-200)}
</style>

<div class="page-wrap">
  <a href="{{ path('app_formation_index') }}" class="back-link">← Retour aux formations</a>

  {# ---- Formation header ---- #}
  <div class="card">
    <div class="card-header">
      {% if formation.category is not null %}
        <div class="card-badge">{{ formation.category }}</div>
      {% endif %}
      <div class="card-title">{{ formation.title }}</div>
      <div class="card-meta-row">
        <div class="meta-item">👨‍🏫 {{ coachName }}</div>
        {% if formation.videoUrl is not null %}
          <div class="meta-item">🎥 Vidéo disponible</div>
        {% endif %}
        {% if quiz is not null %}
          <div class="meta-item">📝 Quiz disponible</div>
        {% endif %}
      </div>
    </div>

    <div class="card-body">

      {# ---- Description ---- #}
      {% if formation.description %}
        <div class="section-label">Description</div>
        <div class="desc-text">{{ formation.description }}</div>
      {% endif %}

      {# ---- Embedded video — no edit/delete buttons here ---- #}
      {% if embedUrl is not null and embedUrl is not empty %}
        <div class="section-label">Vidéo de formation</div>
        <div class="video-wrap">
          <iframe
            src="{{ embedUrl }}"
            title="{{ formation.title }}"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
          </iframe>
        </div>
      {% else %}
        <div class="no-video">🎬 Aucune vidéo disponible pour cette formation</div>
      {% endif %}

      {# ---- Quiz ---- #}
      <div class="quiz-card">
        {% if quiz is not null %}
          <div>
            <div class="quiz-title">📝 {{ quiz.title ?? 'Quiz de la formation' }}</div>
            <div class="quiz-sub">Testez vos connaissances sur cette formation</div>
          </div>
          <a href="{{ path('app_formation_quiz', {'id': formation.id}) }}" class="btn-quiz">Passer le Quiz →</a>
        {% else %}
          <div>
            <div class="quiz-title">📝 Aucun quiz disponible</div>
            <div class="quiz-sub">Un quiz sera bientôt ajouté à cette formation</div>
          </div>
        {% endif %}
      </div>

    </div>
  </div>

  {# ---- Page-level actions: edit & back ONLY (delete is in the list, not here) ---- #}
  <div class="actions-row">
    <a href="{{ path('app_formation_index') }}" class="btn-back">← Liste</a>
    <a href="{{ path('app_formation_edit', {'id': formation.id}) }}" class="btn-edit">✏️ Modifier</a>
  </div>
</div>
{% endblock %}
