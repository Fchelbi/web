<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0D1B2A;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; padding: 30px 0;
        }
        .container {
            display: flex; width: 860px; min-height: 600px;
            border-radius: 24px; overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,0.5);
        }
        .left-panel {
            background: linear-gradient(160deg, #162232 0%, #0D1B2A 100%);
            width: 40%; padding: 50px 35px;
            display: flex; flex-direction: column;
            justify-content: space-between; color: white;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .logo-area { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 16px; }
        .logo-icon {
            width: 80px; height: 80px;
            background: rgba(232,137,90,0.15);
            border: 2px solid rgba(232,137,90,0.3);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 36px;
        }
        .logo-area h1 { font-size: 28px; font-weight: 700; color: white; }
        .logo-area h1 span { color: #E8895A; }
        .logo-area p { font-size: 13px; color: #8899AA; letter-spacing: 1px; }
        .features { display: flex; flex-direction: column; gap: 20px; }
        .feature-item { border-left: 3px solid #E8895A; padding-left: 14px; }
        .feature-item h3 { font-size: 14px; font-weight: 600; color: white; }
        .feature-item p { font-size: 12px; color: #8899AA; margin-top: 2px; }
        .version { text-align: center; font-size: 11px; color: #4A5568; }
        .right-panel {
            background: #162232; width: 60%; padding: 40px 45px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .dots { display: flex; gap: 6px; margin-bottom: 24px; }
        .dot { width: 28px; height: 4px; border-radius: 2px; }
        .dot:nth-child(1) { background: #E8895A; }
        .dot:nth-child(2) { background: rgba(232,137,90,0.4); }
        .dot:nth-child(3) { background: rgba(232,137,90,0.2); }
        .right-panel h2 { font-size: 26px; font-weight: 700; color: white; margin-bottom: 4px; }
        .right-panel .subtitle { font-size: 13px; color: #8899AA; margin-bottom: 24px; }
        .server-error {
            background: rgba(231,76,60,0.15); color: #e74c3c;
            border: 1px solid rgba(231,76,60,0.3);
            padding: 12px 16px; border-radius: 10px;
            margin-bottom: 16px; font-size: 13px; text-align: center;
        }
        .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .field-group { display: flex; flex-direction: column; margin-bottom: 16px; }
        .field-label {
            font-size: 11px; font-weight: 700; color: #8899AA;
            letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px;
        }
        input, select {
            padding: 12px 16px;
            border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 10px; background: rgba(255,255,255,0.05);
            font-size: 14px; color: white; outline: none;
            transition: border-color 0.2s; width: 100%;
        }
        input::placeholder { color: #4A5568; }
        select option { background: #162232; color: white; }
        input:focus, select:focus { border-color: #E8895A; background: rgba(232,137,90,0.05); }
        input.error { border-color: #e74c3c; }
        .password-wrapper { position: relative; }
        .password-wrapper input { padding-right: 44px; }
        .toggle-pw {
            position: absolute; right: 14px; top: 50%;
            transform: translateY(-50%); cursor: pointer; font-size: 16px;
        }
        .strength-bar { height: 4px; border-radius: 2px; background: rgba(255,255,255,0.1); margin-top: 6px; overflow: hidden; }
        .strength-fill { height: 100%; width: 0%; border-radius: 2px; transition: width 0.3s, background 0.3s; }
        .strength-text { font-size: 11px; color: #8899AA; margin-top: 4px; }
        .error-msg { font-size: 11px; color: #e74c3c; margin-top: 4px; display: none; }
        .btn-signup {
            width: 100%; padding: 14px; background: #E8895A;
            color: white; border: none; border-radius: 10px;
            font-size: 15px; font-weight: 600; cursor: pointer;
            transition: all 0.2s; margin-top: 6px;
        }
        .btn-signup:hover { background: #d4784a; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(232,137,90,0.3); }
        .separator {
            text-align: center; color: #4A5568; font-size: 13px;
            margin: 14px 0; position: relative;
        }
        .separator::before, .separator::after {
            content: ''; position: absolute; top: 50%;
            width: 42%; height: 1px; background: rgba(255,255,255,0.06);
        }
        .separator::before { left: 0; }
        .separator::after { right: 0; }
        .btn-login {
            width: 100%; padding: 13px; background: transparent;
            color: #E8895A; border: 1.5px solid rgba(232,137,90,0.4);
            border-radius: 10px; font-size: 14px; font-weight: 600;
            text-decoration: none; display: block; text-align: center;
            transition: all 0.2s;
        }
        .btn-login:hover { background: rgba(232,137,90,0.1); border-color: #E8895A; }
    </style>
</head>
<body>
<div class="container">
    <div class="left-panel">
        <div class="logo-area">
            <div class="logo-icon">🧠</div>
            <div>
                <h1>Echo<span>Care</span></h1>
                <p>Psychologie · Bien-etre</p>
            </div>
        </div>
        <div class="features">
            <div class="feature-item">
                <h3>Rejoignez-nous</h3>
                <p>Creez votre espace personnel</p>
            </div>
            <div class="feature-item">
                <h3>3 profils disponibles</h3>
                <p>Admin · Coach · Patient</p>
            </div>
            <div class="feature-item">
                <h3>100% securise</h3>
                <p>Vos donnees sont protegees</p>
            </div>
        </div>
        <div class="version">EchoCare v2.0</div>
    </div>

    <div class="right-panel">
        <div class="dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>
        <h2>Creer un compte</h2>
        <p class="subtitle">Remplissez les informations ci-dessous</p>

        {% if error is defined and error %}
            <div class="server-error">❌ {{ error }}</div>
        {% endif %}

        <form method="post" id="signupForm" novalidate>
            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Nom</label>
                    <input type="text" name="nom" id="nom" placeholder="Votre nom" required>
                    <span class="error-msg" id="nom-error">Min 2 caracteres</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Prenom</label>
                    <input type="text" name="prenom" id="prenom" placeholder="Votre prenom" required>
                    <span class="error-msg" id="prenom-error">Min 2 caracteres</span>
                </div>
            </div>
            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <input type="email" name="email" id="email" placeholder="vous@exemple.com" required>
                    <span class="error-msg" id="email-error">Email invalide</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Telephone</label>
                    <input type="text" name="num_tel" id="num_tel" placeholder="Ex: 22 000 000">
                    <span class="error-msg" id="tel-error">8 chiffres requis</span>
                </div>
            </div>
            <div class="row-2">
                <div class="field-group">
                    <label class="field-label">Mot de passe</label>
                    <div class="password-wrapper">
                        <input type="password" name="password" id="password" placeholder="••••••••" required>
                        <span class="toggle-pw" onclick="togglePw('password', this)">👁️</span>
                    </div>
                    <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
                    <span class="strength-text" id="strength-text"></span>
                    <span class="error-msg" id="pw-error">Min 8 car. majuscule, chiffre, symbole</span>
                </div>
                <div class="field-group">
                    <label class="field-label">Confirmer</label>
                    <div class="password-wrapper">
                        <input type="password" name="confirm_password" id="confirm_password" placeholder="••••••••" required>
                        <span class="toggle-pw" onclick="togglePw('confirm_password', this)">👁️</span>
                    </div>
                    <span class="error-msg" id="confirm-error">Mots de passe differents</span>
                </div>
            </div>
            <div class="field-group">
                <label class="field-label">Role</label>
                <select name="role" id="role" required>
                    <option value="">-- Choisir un role --</option>
                    <option value="Patient">🌿 Patient</option>
                    <option value="Coach">🏋️ Coach</option>
                    <option value="Admin">👑 Admin</option>
                </select>
                <span class="error-msg" id="role-error">Veuillez choisir un role</span>
            </div>
            <button type="submit" class="btn-signup">S'inscrire</button>
        </form>

        <div class="separator">ou</div>
        <a href="{{ path('app_login') }}" class="btn-login">Deja un compte ? Se connecter</a>
    </div>
</div>

<script>
    function togglePw(id, el) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        el.textContent = input.type === 'password' ? '👁️' : '🙈';
    }
    document.getElementById('password').addEventListener('input', function () {
        const val = this.value;
        const fill = document.getElementById('strength-fill');
        const text = document.getElementById('strength-text');
        let score = 0;
        if (val.length >= 8) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        const levels = [
            { w: '0%', c: 'transparent', t: '' },
            { w: '25%', c: '#e74c3c', t: '🔴 Tres faible' },
            { w: '50%', c: '#e67e22', t: '🟠 Faible' },
            { w: '75%', c: '#f1c40f', t: '🟡 Moyen' },
            { w: '100%', c: '#2ecc71', t: '🟢 Fort' },
        ];
        fill.style.width = levels[score].w;
        fill.style.background = levels[score].c;
        text.textContent = levels[score].t;
    });
    document.getElementById('signupForm').addEventListener('submit', function (e) {
        let valid = true;
        const nom = document.getElementById('nom');
        const prenom = document.getElementById('prenom');
        const email = document.getElementById('email');
        const tel = document.getElementById('num_tel');
        const pw = document.getElementById('password');
        const cpw = document.getElementById('confirm_password');
        const role = document.getElementById('role');
        const show = (id) => { document.getElementById(id).style.display = 'block'; };
        const hide = (id) => { document.getElementById(id).style.display = 'none'; };
        if (nom.value.trim().length < 2) { nom.classList.add('error'); show('nom-error'); valid = false; } else { nom.classList.remove('error'); hide('nom-error'); }
        if (prenom.value.trim().length < 2) { prenom.classList.add('error'); show('prenom-error'); valid = false; } else { prenom.classList.remove('error'); hide('prenom-error'); }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) { email.classList.add('error'); show('email-error'); valid = false; } else { email.classList.remove('error'); hide('email-error'); }
        if (tel.value && !/^\d{8}$/.test(tel.value.replace(/\s/g, ''))) { tel.classList.add('error'); show('tel-error'); valid = false; } else { tel.classList.remove('error'); hide('tel-error'); }
        if (!/^(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/.test(pw.value)) { pw.classList.add('error'); show('pw-error'); valid = false; } else { pw.classList.remove('error'); hide('pw-error'); }
        if (pw.value !== cpw.value) { cpw.classList.add('error'); show('confirm-error'); valid = false; } else { cpw.classList.remove('error'); hide('confirm-error'); }
        if (!role.value) { role.classList.add('error'); show('role-error'); valid = false; } else { role.classList.remove('error'); hide('role-error'); }
        if (!valid) e.preventDefault();
    });
</script>
</body>
</html>