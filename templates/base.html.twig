<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Community Platform — Professional networking and content sharing">
        <title>{% block title %}Community{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🔮</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/css/style.css?v=2">
        <link rel="stylesheet" href="/css/ai-chatbot.css?v=10">
        <script src="https://unpkg.com/lucide@latest"></script>
        
        <!-- PACE.js for Lazy-Loading Progress Bar -->
        <script src="https://cdn.jsdelivr.net/npm/pace-js@latest/pace.min.js"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pace-js@latest/pace-theme-default/tmpl/pace-theme-minimal.css">
        
        <style>
            /* Custom Pace UI & Smooth Page Transitions */
            body { animation: smoothPageLoad 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards; }
            @keyframes smoothPageLoad {
                from { opacity: 0; transform: translateY(8px); }
                to { opacity: 1; transform: translateY(0); }
            }
            /* Calming Page Transition Overlay */
            #page-transition-curtain {
                position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
                z-index: 999999; pointer-events: none;
                background-color: #0d1321;
                background-image: url('/images/autumn-transition.png');
                background-repeat: no-repeat; background-position: center center;
                background-size: cover; 
                transform: translate(-100%, 100%); opacity: 0; visibility: hidden;
                display: flex; flex-direction: column; align-items: center; justify-content: center;
                box-shadow: 0 0 50px rgba(0,0,0,0.15);
            }
            #page-transition-curtain::after {
                content: ''; position: absolute; top:0; left:0; width:100%; height:100%;
                background: linear-gradient(135deg, rgba(15,22,35,0.7) 0%, rgba(126,200,227,0.2) 100%);
                z-index: 1;
            }
            .transition-content {
                position: relative; z-index: 2; text-align: center; color: white;
                font-family: 'Inter', sans-serif;
            }
            .transition-logo {
                font-size: 2rem; font-weight: 600; letter-spacing: 1px; margin: 0;
                text-shadow: 0 4px 15px rgba(0,0,0,0.3);
            }
            .transition-subtitle {
                font-size: 1.1rem; font-weight: 400; color: #cbd5e0; margin-top: 12px;
                letter-spacing: 0.5px; opacity: 0.9;
            }
        </style>

        {% block javascripts %}{% endblock %}
    </head>
    <body>
        <!-- ================================================================
             AI POST ASSISTANT — Floating Widget (Dark Theme)
             ================================================================ -->
        <div class="aicb-widget">
            <!-- Trigger bubble -->
            <button id="aicb-trigger" class="aicb-trigger" onclick="toggleAIChatbot()" aria-label="Open AI Post Assistant">
                <span class="aicb-trigger-icon">✦</span>
            </button>

            <!-- Panel -->
            <div id="aicb-panel" class="aicb-panel" style="display:none;" role="dialog" aria-label="AI Post Assistant" data-api-key="{{ gemini_api_key }}">
                <!-- Header -->
                <div class="aicb-header">
                    <div class="aicb-header-left">
                        <div class="aicb-header-orb">✦</div>
                        <div>
                            <p class="aicb-header-title">EchoCare AI</p>
                            <p class="aicb-header-status">Ready to assist</p>
                        </div>
                    </div>
                    <button class="aicb-btn-close" onclick="toggleAIChatbot()" aria-label="Close Assistant">×</button>
                </div>

                <!-- ── FORM STATE ── -->
                <div id="aicb-form" class="aicb-body">
                    <p class="aicb-welcome">What would you like to share today?</p>

                    <!-- Prompt -->
                    <div class="aicb-input-wrapper">
                        <textarea id="aicb-prompt" class="aicb-textarea" placeholder="e.g. Tips for morning anxiety…" rows="3"></textarea>
                    </div>

                    <button class="aicb-btn-generate" onclick="generateAICBPost()">
                        Generate Support Post
                        <span class="aicb-sparkle">✦</span>
                    </button>
                </div>

                <!-- ── LOADING STATE ── -->
                <div id="aicb-loading" class="aicb-body aicb-body-center" style="display:none; flex-direction:column;">
                    <div class="aicb-spinner">
                        <div class="aicb-ring aicb-ring-1"></div>
                        <div class="aicb-ring aicb-ring-2"></div>
                        <div class="aicb-ring aicb-ring-3"></div>
                        <div class="aicb-core"></div>
                    </div>
                    <p class="aicb-loading-title">Drafting your post…</p>
                    <div class="aicb-progress">
                        <div class="aicb-progress-bar"></div>
                    </div>
                    <p class="aicb-loading-hint">This usually takes just a few seconds</p>
                </div>

                <!-- ── ERROR STATE ── -->
                <div id="aicb-result" class="aicb-result-wrap" style="display:none; flex-direction:column; padding: 20px; text-align: center;">
                    <p id="aicb-error-text" style="color: #e8895a; font-size: 0.88rem; margin-bottom: 20px;"></p>
                    <div class="aicb-result-actions">
                        <button class="aicb-btn-back" onclick="resetAICBForm()" style="width: 100%; justify-content: center;">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M19 12H5M12 5l-7 7 7 7"/>
                            </svg>
                            Go Back
                        </button>
                    </div>
                </div>
            </div><!-- /panel -->
        </div><!-- /aicb-widget -->

        <div id="page-transition-curtain">
            <div class="transition-content">
                <h2 class="transition-logo">EchoCare</h2>
                <p class="transition-subtitle">Take a deep breath...</p>
            </div>
        </div>

        {% block body %}{% endblock %}



        <script>
            // --- Calming Page Transition Logic ---
            document.addEventListener('DOMContentLoaded', () => {
                const curtain = document.getElementById('page-transition-curtain');
                if (curtain) {
                    // Immediately ensure curtain is hidden on page load
                    curtain.style.transition = 'opacity 0.4s ease';
                    curtain.style.opacity = '0';
                    setTimeout(() => {
                        curtain.style.visibility = 'hidden';
                        curtain.style.transition = 'none';
                        curtain.style.transform = 'translate(-100%, 100%)';
                    }, 450);
                }

                // Intercept navigation links for elegant slow slide IN
                document.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', (e) => {
                        const href = link.getAttribute('href');
                        if (href && href.startsWith('/') && !href.startsWith('#') && !e.ctrlKey && !e.metaKey && link.target !== '_blank' && !link.hasAttribute('data-bs-toggle') && !link.closest('.no-transition')) {
                            e.preventDefault();
                            
                            // Reset offscreen to bottom-left
                            curtain.style.transition = 'none';
                            curtain.style.visibility = 'visible';
                            curtain.style.opacity = '1';
                            curtain.style.transform = 'translate(-100%, 100%)';
                            void curtain.offsetWidth; // Force reflow
                            
                            // Smooth, calming diagonal slide in
                            curtain.style.transition = 'transform 1s cubic-bezier(0.25, 1, 0.5, 1)';
                            curtain.style.transform = 'translate(0, 0)';
                            
                            setTimeout(() => { window.location.href = href; }, 950); 
                        }
                    });
                });
            });
            
            // Handle browser Back/Forward (BfCache)
            window.addEventListener('pageshow', (e) => {
                if(e.persisted) {
                    const curtain = document.getElementById('page-transition-curtain');
                    curtain.style.transition = 'opacity 1s ease';
                    curtain.style.opacity = '0';
                    setTimeout(() => { curtain.style.visibility = 'hidden'; curtain.style.transform = 'translate(-100%, 100%)'; }, 1000);
                }
            });

            // Initialize Lucide icons
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof lucide !== 'undefined') {
                    lucide.createIcons();
                }

                // FIX: Aggressively remove layout-breaking extension elements
                const cleanupExtensions = () => {
                    const selectors = ['chatgpt-sidebar', '#chatgpt-sidebar', '.chatgpt-sidebar', '[data-rendered="true"][data-gpts-theme]'];
                    selectors.forEach(sel => {
                        document.querySelectorAll(sel).forEach(el => el.remove());
                    });
                };
                cleanupExtensions();
                const observer = new MutationObserver(cleanupExtensions);
                observer.observe(document.body, { childList: true, subtree: true });
            });
        </script>

        <script src="/js/ai-chatbot.js?v=15" defer></script>
    </body>
</html>
