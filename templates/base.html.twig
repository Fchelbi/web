<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Consultations en ligne{% endblock %}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
        <style>
            :root {
                --ec-blue: #4A6FA5;
                --ec-blue-dark: #2C4F7C;
                --ec-orange: #E8895A;
                --ec-orange-dark: #D4784A;
                --ec-beige: #F0E6D8;
                --ec-surface: #FFFFFF;
                --ec-surface-soft: #F5EFE6;
                --ec-border: #E8E0D5;
                --ec-text: #2C3E50;
                --ec-muted: #7A7A7A;
            }

            body {
                background: var(--ec-beige);
                color: var(--ec-text);
                font-family: 'Segoe UI', sans-serif;
            }

            .app-navbar {
                background: var(--ec-surface);
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            .navbar-brand {
                font-weight: 700;
                color: var(--ec-blue) !important;
                font-size: 1.5rem;
            }

            .navbar-brand span {
                color: var(--ec-orange);
            }

            .navbar-nav .nav-link {
                color: #555;
                font-weight: 500;
                position: relative;
                padding-left: 0.85rem;
                padding-right: 0.85rem;
            }

            .navbar-nav .nav-link:hover,
            .navbar-nav .nav-link:focus {
                color: var(--ec-blue);
            }

            .navbar-nav .nav-link::after {
                content: '';
                position: absolute;
                left: 0.85rem;
                right: 0.85rem;
                bottom: 0.35rem;
                height: 2px;
                background: var(--ec-orange);
                transform: scaleX(0);
                transform-origin: left;
                transition: transform 0.2s ease;
            }

            .navbar-nav .nav-link:hover::after,
            .navbar-nav .nav-link:focus::after {
                transform: scaleX(1);
            }

            .page-shell {
                padding-top: 2rem;
                padding-bottom: 2rem;
            }

            .page-card {
                border: 0;
                border-radius: 16px;
                box-shadow: 0 2px 15px rgba(0, 0, 0, 0.06);
                background: var(--ec-surface);
            }

            .btn-primary,
            .btn-primary:focus {
                background: var(--ec-orange);
                border-color: var(--ec-orange);
                color: #fff;
                box-shadow: 0 4px 12px rgba(232, 137, 90, 0.25);
            }

            .btn-primary:hover {
                background: var(--ec-orange-dark);
                border-color: var(--ec-orange-dark);
            }

            .btn-outline-primary {
                color: var(--ec-blue);
                border-color: var(--ec-blue);
            }

            .btn-outline-primary:hover {
                background: var(--ec-blue);
                border-color: var(--ec-blue);
            }

            .btn-outline-dark {
                color: var(--ec-blue-dark);
                border-color: var(--ec-border);
                background: var(--ec-surface);
            }

            .btn-outline-dark:hover,
            .btn-outline-secondary:hover {
                background: var(--ec-blue);
                border-color: var(--ec-blue);
                color: #fff;
            }

            .btn-dark {
                background: var(--ec-blue);
                border-color: var(--ec-blue);
            }

            .btn-dark:hover {
                background: var(--ec-blue-dark);
                border-color: var(--ec-blue-dark);
            }

            .table {
                margin-bottom: 0;
            }

            .table thead.table-light th {
                background: var(--ec-blue);
                color: #fff;
                border-bottom: 0;
                font-size: 0.85rem;
                font-weight: 600;
                padding-top: 0.95rem;
                padding-bottom: 0.95rem;
            }

            .table tbody td {
                vertical-align: middle;
                border-color: #F0EAE0;
                color: #333;
            }

            .table tbody tr:hover {
                background: #FDF8F3;
            }

            .form-control,
            .form-select {
                border: 1.5px solid var(--ec-border);
                border-radius: 10px;
                background: #fff;
                padding-top: 0.75rem;
                padding-bottom: 0.75rem;
            }

            .form-control:focus,
            .form-select:focus {
                border-color: var(--ec-blue);
                box-shadow: 0 0 0 0.2rem rgba(74, 111, 165, 0.15);
            }

            .text-muted,
            .form-text {
                color: var(--ec-muted) !important;
            }

            .badge {
                border-radius: 999px;
                padding: 0.45rem 0.8rem;
                font-weight: 600;
            }

            .alert-success {
                background: #d8fde8;
                border-color: #b6f4d1;
                color: #217a4c;
            }

            .alert-danger {
                background: #fde1dc;
                border-color: #f6c3bb;
                color: #a33c2c;
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand" href="{{ path('consultation_list') }}">Echo<span>Care</span></a>
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" href="{{ path('consultation_list') }}">Patient</a>
                    <a class="nav-link" href="{{ path('psychologue_list') }}">Nos psychologues</a>
                    <a class="nav-link" href="{{ path('psy_consultations') }}">Psychologue</a>
                </div>
            </div>
        </nav>

        <main class="container page-shell">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
