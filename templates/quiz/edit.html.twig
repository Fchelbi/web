{% extends 'base.html.twig' %}
{% block title %}{{ isNew ? 'Créer' : 'Modifier' }} le Quiz — {{ formation.title }} | EchoCare{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bd:#0f2a4a;--bl:#2d7dd2;--bp:#e8f2ff;
  --or:#f4845f;--os:#fff3ef;
  --wh:#fff;--g1:#f7f9fc;--g2:#eef2f7;--g4:#94a3b8;--g7:#374151;
  --rd:#ef4444;--rs:#fef2f2;--gn:#27ae60;--gs:#e8f8f0;
  --pu:#6366f1;--ps:#f0f4ff;
  --r:12px;--sh:0 2px 10px rgba(15,42,74,.09)
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--g1);color:var(--g7)}

/* Layout */
.layout{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
.sidebar{background:var(--bd);padding:26px 18px;display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.logo{font-size:20px;font-weight:800;color:#fff;margin-bottom:3px}.logo span{color:var(--or)}
.logo-sub{font-size:10px;color:var(--g4);text-transform:uppercase;letter-spacing:1px;margin-bottom:28px}
.nav-link{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:9px;color:rgba(255,255,255,.6);font-size:13px;font-weight:500;text-decoration:none;margin-bottom:3px;transition:.15s}
.nav-link:hover{background:rgba(255,255,255,.08);color:#fff}
.nav-link.active{background:var(--bl);color:#fff}
.sidebar-foot{margin-top:auto;background:rgba(244,132,95,.13);border-radius:9px;padding:11px 13px;color:var(--or);font-size:12px;font-weight:700}

.main{padding:34px 42px}
.back-link{display:inline-flex;align-items:center;gap:5px;color:var(--bl);font-size:13px;font-weight:600;text-decoration:none;margin-bottom:20px}
.back-link:hover{opacity:.7}

/* Page header */
.ph{background:linear-gradient(135deg,var(--bd),#1a4a7a);border-radius:var(--r);padding:22px 26px;margin-bottom:20px}
.ph-sub{font-size:11px;color:rgba(255,255,255,.5);margin-bottom:3px}
.ph-title{font-size:20px;font-weight:800;color:#fff}

/* Flash */
.flash{border-radius:9px;padding:11px 15px;margin-bottom:10px;font-size:13px;font-weight:600;display:flex;gap:8px}
.flash-err{background:var(--rs);color:var(--rd);border-left:3px solid var(--rd)}
.flash-ok{background:var(--gs);color:var(--gn);border-left:3px solid var(--gn)}

/* Cards */
.card{background:var(--wh);border-radius:var(--r);box-shadow:var(--sh);padding:22px 26px;margin-bottom:18px}
.card-head{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.6px;color:var(--bd);margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid var(--g2)}

/* Fields */
.row2{display:grid;grid-template-columns:1fr 160px;gap:14px}
.fld{margin-bottom:14px}
.flabel{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--bd);margin-bottom:5px}
.finput{width:100%;padding:9px 12px;border:1.5px solid var(--g2);border-radius:9px;font-size:13px;font-family:inherit;color:var(--g7);outline:none;transition:.2s;background:var(--wh)}
.finput:focus{border-color:var(--bl);box-shadow:0 0 0 3px rgba(45,125,210,.08)}
.finput.err{border-color:var(--rd);background:#fff8f8}
textarea.finput{resize:vertical;min-height:64px}
.ferr{color:var(--rd);font-size:11px;margin-top:3px;font-weight:600}
.fhint{color:var(--g4);font-size:11px;margin-top:3px}

/* Question card */
.qcard{background:var(--g1);border:1.5px solid var(--g2);border-radius:var(--r);padding:18px 20px;margin-bottom:12px}
.qcard-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.qbadge{font-size:11px;font-weight:800;text-transform:uppercase;color:var(--bl);background:var(--bp);border-radius:20px;padding:3px 10px}
.btn-rmq{background:var(--rs);color:var(--rd);border:none;border-radius:7px;padding:4px 10px;font-size:11px;font-weight:700;cursor:pointer;transition:.15s}
.btn-rmq:hover{background:var(--rd);color:#fff}

/* Answer section */
.ans-section{margin-top:12px;padding-top:12px;border-top:1px solid var(--g2)}
.ans-head{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--g4);margin-bottom:8px}
.ans-row{display:grid;grid-template-columns:1fr auto auto;align-items:center;gap:8px;background:var(--wh);border:1.5px solid var(--g2);border-radius:8px;padding:7px 10px;margin-bottom:5px;transition:.15s}
.ans-row:focus-within{border-color:var(--bl)}
.ans-row input[type=text]{border:none;background:transparent;font-size:13px;font-family:inherit;color:var(--g7);outline:none;width:100%}
.chk-wrap{display:flex;align-items:center;gap:4px;white-space:nowrap}
.chk-wrap span{font-size:11px;font-weight:600;color:var(--g4)}
.chk-wrap input[type=checkbox]{width:14px;height:14px;accent-color:var(--gn);cursor:pointer}
.btn-rma{background:none;border:none;color:var(--g4);font-size:15px;cursor:pointer;padding:0 2px;transition:.15s;line-height:1}
.btn-rma:hover{color:var(--rd)}
.btn-add-ans{display:inline-flex;align-items:center;gap:4px;background:none;border:1.5px dashed var(--g4);border-radius:7px;padding:5px 10px;font-size:11px;font-weight:600;color:var(--g4);cursor:pointer;transition:.15s;margin-top:3px}
.btn-add-ans:hover{border-color:var(--bl);color:var(--bl);background:var(--bp)}

/* Add question */
.btn-addq{width:100%;background:var(--wh);border:2px dashed var(--bl);border-radius:var(--r);padding:13px;font-size:13px;font-weight:700;color:var(--bl);cursor:pointer;margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:6px;transition:.15s}
.btn-addq:hover{background:var(--bp);border-style:solid}

/* Submit */
.submit-row{display:flex;gap:10px}
.btn-save{flex:1;background:var(--or);color:#fff;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:700;cursor:pointer;transition:.2s;box-shadow:0 4px 12px rgba(244,132,95,.28)}
.btn-save:hover{background:#e06d47;transform:translateY(-1px)}
.btn-back2{background:var(--g2);color:var(--g7);border:none;border-radius:10px;padding:12px 20px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:flex;align-items:center;transition:.15s}
.btn-back2:hover{background:var(--g4);color:#fff}
</style>

<div class="layout">

  <div class="sidebar">
    <div class="logo">Echo<span>Care</span></div>
    <div class="logo-sub">Quiz Builder</div>
    <a href="{{ path('app_formation_index') }}" class="nav-link">📚 Formations</a>
    <a href="{{ path('app_quiz_manage', {'id': formation.id}) }}" class="nav-link active">📝 Quiz</a>
    <div class="sidebar-foot">{{ isNew ? '➕ Nouveau quiz' : '✏️ Modification' }}</div>
  </div>

  <div class="main">
    <a href="{{ path('app_quiz_manage', {'id': formation.id}) }}" class="back-link">← Retour</a>

    <div class="ph">
      <div class="ph-sub">📚 {{ formation.title }}</div>
      <div class="ph-title">{{ isNew ? '➕ Créer un Quiz' : '✏️ Modifier le Quiz' }}</div>
    </div>

    {# ── Flash messages — errors are now always visible ── #}
    {% for m in app.flashes('error') %}
      <div class="flash flash-err">{{ m }}</div>
    {% endfor %}
    {% for m in app.flashes('success') %}
      <div class="flash flash-ok">{{ m }}</div>
    {% endfor %}

    {{ form_start(form, {'attr': {'id':'quiz-form','novalidate':'novalidate'}}) }}

    {# ── Section 1: Quiz info ── #}
    <div class="card">
      <div class="card-head">📋 Informations générales</div>
      <div class="row2">
        <div class="fld">
          <label class="flabel" for="{{ form.title.vars.id }}">
            Titre <span style="color:var(--rd)">*</span>
          </label>
          {{ form_widget(form.title, {'attr': {
            'class': 'finput' ~ (form.title.vars.errors|length > 0 ? ' err' : ''),
            'placeholder': 'Ex : Quiz sur la nutrition'
          }}) }}
          {% if form.title.vars.errors|length > 0 %}
            <div class="ferr">⚠️ {{ form_errors(form.title) }}</div>
          {% endif %}
        </div>
        <div class="fld">
          <label class="flabel" for="{{ form.passing_score.vars.id }}">
            Score min. (%) <span style="color:var(--rd)">*</span>
          </label>
          {{ form_widget(form.passing_score, {'attr': {
            'class': 'finput' ~ (form.passing_score.vars.errors|length > 0 ? ' err' : ''),
            'min': 0, 'max': 100
          }}) }}
          {% if form.passing_score.vars.errors|length > 0 %}
            <div class="ferr">⚠️ {{ form_errors(form.passing_score) }}</div>
          {% endif %}
          <div class="fhint">0 – 100. Défaut : 60</div>
        </div>
      </div>
    </div>

    {# ── Section 2: Questions ── #}
    <div id="questions-list">
      {% for qIdx, question in form.questions %}
        <div class="qcard" data-q-index="{{ qIdx }}">
          <div class="qcard-top">
            <span class="qbadge">Question {{ loop.index }}</span>
            <button type="button" class="btn-rmq" onclick="removeQuestion(this)">✕ Supprimer</button>
          </div>
          <div class="fld">
            <label class="flabel">Énoncé <span style="color:var(--rd)">*</span></label>
            {{ form_widget(question.questionText, {'attr': {
              'class': 'finput' ~ (question.questionText.vars.errors|length > 0 ? ' err' : ''),
              'placeholder': 'Ex : Quel est le rôle de l\'insuline ?',
              'rows': 2
            }}) }}
            {% if question.questionText.vars.errors|length > 0 %}
              <div class="ferr">⚠️ {{ form_errors(question.questionText) }}</div>
            {% endif %}
          </div>
          <div class="fld" style="max-width:110px">
            <label class="flabel">Points</label>
            {{ form_widget(question.points, {'attr': {'class':'finput','min':1,'max':100}}) }}
          </div>
          <div class="ans-section" data-q-index="{{ qIdx }}">
            <div class="ans-head">Réponses <span style="color:var(--rd)">*</span> — cochez la/les bonne(s)</div>
            <div class="ans-rows">
              {% for reponse in question.reponses %}
                <div class="ans-row">
                  {{ form_widget(reponse.optionText, {'attr': {'placeholder':'Texte de la réponse…'}}) }}
                  <div class="chk-wrap">
                    <span>✓</span>
                    {{ form_widget(reponse.isCorrect) }}
                  </div>
                  <button type="button" class="btn-rma" onclick="removeAnswer(this)" title="Supprimer">✕</button>
                </div>
              {% endfor %}
            </div>
            <button type="button" class="btn-add-ans" onclick="addAnswer(this, {{ qIdx }})">
              ＋ Réponse
            </button>
          </div>
        </div>
      {% endfor %}
    </div>

    <button type="button" class="btn-addq" onclick="addQuestion()">＋ Ajouter une Question</button>

    <div class="submit-row">
      <a href="{{ path('app_quiz_manage', {'id': formation.id}) }}" class="btn-back2">Annuler</a>
      <button type="submit" class="btn-save">💾 Sauvegarder le Quiz</button>
    </div>

    {#
      PROTOTYPE STORAGE
      ─────────────────
      We store the QUESTION prototype once.
      The inner reponses CollectionType renders its OWN data-prototype
      attribute on the reponses <div id="..._reponses">.
      JS replaces __name__ for the question level WITHOUT touching
      data-prototype attributes, so the inner prototype stays intact
      for addAnswer() to use independently.
    #}
    {% set q_proto = form_widget(form.questions.vars.prototype) %}
    <div id="q-proto"
         data-prototype="{{ q_proto|e('html_attr') }}"
         data-count="{{ form.questions|length }}"
         style="display:none"></div>

    {{ form_end(form) }}
  </div>
</div>

<script>
// ── Counters ──────────────────────────────────────────────
const qProtoEl = document.getElementById('q-proto');
let qCount = parseInt(qProtoEl.dataset.count, 10);
const rCounts = {};
document.querySelectorAll('#questions-list .qcard').forEach((c,i) => {
    rCounts[i] = c.querySelectorAll('.ans-row').length;
});

// ── ADD QUESTION ──────────────────────────────────────────
// KEY FIX: we deep-clone the prototype DOM and replace __name__
// in ALL attributes and text EXCEPT data-prototype attributes.
// This preserves the inner reponses prototype untouched.
function addQuestion() {
    const wrapper = document.createElement('div');
    wrapper.innerHTML = qProtoEl.dataset.prototype;
    deepReplace(wrapper, '__name__', String(qCount));

    rCounts[qCount] = 0;

    const card = document.createElement('div');
    card.className = 'qcard';
    card.dataset.qIndex = qCount;

    card.innerHTML = `
      <div class="qcard-top">
        <span class="qbadge">Question</span>
        <button type="button" class="btn-rmq" onclick="removeQuestion(this)">✕ Supprimer</button>
      </div>`;

    Array.from(wrapper.childNodes).forEach(n => card.appendChild(n));

    // Find the reponses container and decorate it
    const repContainer = card.querySelector('[id*="_reponses"]');
    if (repContainer) {
        repContainer.classList.add('ans-section');
        repContainer.dataset.qIndex = qCount;

        // Wrap existing children in .ans-rows if needed
        if (!repContainer.querySelector('.ans-rows')) {
            const rowsDiv = document.createElement('div');
            rowsDiv.className = 'ans-rows';
            while (repContainer.firstChild) rowsDiv.appendChild(repContainer.firstChild);
            repContainer.appendChild(rowsDiv);
        }

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.className = 'btn-add-ans';
        addBtn.setAttribute('onclick', `addAnswer(this, ${qCount})`);
        addBtn.textContent = '＋ Réponse';
        repContainer.appendChild(addBtn);
    }

    document.getElementById('questions-list').appendChild(card);
    qCount++;
}

// Replaces placeholder in all attrs & text nodes, SKIPPING data-prototype
function deepReplace(node, ph, val) {
    if (node.nodeType === 3) { // text node
        node.textContent = node.textContent.replaceAll(ph, val);
        return;
    }
    if (node.nodeType === 1) { // element
        Array.from(node.attributes).forEach(a => {
            if (a.name !== 'data-prototype')
                a.value = a.value.replaceAll(ph, val);
        });
        Array.from(node.childNodes).forEach(c => deepReplace(c, ph, val));
    }
}

// ── REMOVE QUESTION ───────────────────────────────────────
function removeQuestion(btn) {
    if (confirm('Supprimer cette question ?'))
        btn.closest('.qcard').remove();
}

// ── ADD ANSWER ────────────────────────────────────────────
function addAnswer(btn, qIdx) {
    // Find the container that holds data-prototype for reponses
    const container = btn.closest('.ans-section') || btn.closest('[data-q-index]');
    if (!container) return;

    // The reponses CollectionType sets data-prototype on the div
    // whose id ends with "_reponses"
    const protoEl = container.id && container.dataset.prototype
        ? container
        : container.querySelector('[data-prototype]');

    if (!protoEl || !protoEl.dataset.prototype) {
        console.warn('No reponse prototype found for question', qIdx);
        return;
    }

    if (rCounts[qIdx] === undefined)
        rCounts[qIdx] = container.querySelectorAll('.ans-row').length;

    let html = protoEl.dataset.prototype;
    html = html.replaceAll('__name__label__', rCounts[qIdx]);
    html = html.replaceAll('__name__', rCounts[qIdx]);

    const row = document.createElement('div');
    row.className = 'ans-row';
    row.innerHTML = html;

    // Style text input
    row.querySelectorAll('input[type=text]').forEach(i =>
        i.setAttribute('placeholder', 'Texte de la réponse…'));

    // Wrap checkbox in chk-wrap
    const cb = row.querySelector('input[type=checkbox]');
    if (cb) {
        const cw = document.createElement('div');
        cw.className = 'chk-wrap';
        cw.innerHTML = '<span>✓</span>';
        cb.parentNode.insertBefore(cw, cb);
        cw.appendChild(cb);
    }

    // Remove button
    const rmBtn = document.createElement('button');
    rmBtn.type = 'button';
    rmBtn.className = 'btn-rma';
    rmBtn.setAttribute('onclick', 'removeAnswer(this)');
    rmBtn.title = 'Supprimer';
    rmBtn.textContent = '✕';
    row.appendChild(rmBtn);

    const rowsDiv = container.querySelector('.ans-rows') || container;
    rowsDiv.insertBefore(row, btn);

    rCounts[qIdx]++;
}

// ── REMOVE ANSWER ─────────────────────────────────────────
function removeAnswer(btn) {
    btn.closest('.ans-row').remove();
}
</script>
{% endblock %}
