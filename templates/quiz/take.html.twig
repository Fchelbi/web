{% extends 'base.html.twig' %}
{% block title %}Quiz — {{ formation.title }} | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--radius:14px;--shadow-sm:0 2px 8px rgba(15,42,74,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700);padding:40px 20px}
  .page-wrap{max-width:760px;margin:0 auto}
  .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--blue-light);font-size:14px;font-weight:600;text-decoration:none;margin-bottom:24px}
  .card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:24px}
  .card-header{background:linear-gradient(135deg,var(--blue-dark),#1a4a7a);padding:28px 30px}
  .card-header small{color:rgba(255,255,255,.6);font-size:13px;display:block;margin-bottom:4px}
  .card-title{font-size:24px;font-weight:800;color:#fff}
  .card-body{padding:30px}
  .progress-bar{background:var(--gray-200);border-radius:20px;height:8px;margin-bottom:24px;overflow:hidden}
  .progress-fill{height:100%;background:var(--blue-light);border-radius:20px;transition:width .3s}
  .progress-text{font-size:12px;color:var(--gray-400);text-align:right;margin-bottom:10px}
  .question-block{border:1.5px solid var(--gray-200);border-radius:12px;padding:24px;margin-bottom:20px;transition:.2s}
  .question-block.answered{border-color:var(--blue-light);background:rgba(45,125,210,.02)}
  .q-number{font-size:12px;font-weight:700;color:var(--blue-light);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px}
  .q-text{font-size:16px;font-weight:700;color:var(--blue-dark);margin-bottom:16px;line-height:1.5}
  .option-label{display:flex;align-items:center;gap:12px;padding:12px 16px;border:1.5px solid var(--gray-200);border-radius:10px;margin-bottom:8px;cursor:pointer;transition:.15s;font-size:14px}
  .option-label:hover{border-color:var(--blue-light);background:var(--blue-pale)}
  .option-label input{accent-color:var(--blue-light);width:18px;height:18px;cursor:pointer}
  .option-label.selected{border-color:var(--blue-light);background:var(--blue-pale);font-weight:600}
  .form-actions{display:flex;gap:12px;padding-top:20px;border-top:1px solid var(--gray-200)}
  .btn-submit{flex:1;background:linear-gradient(135deg,var(--orange),#e06d47);color:#fff;border:none;border-radius:10px;padding:14px;font-size:16px;font-weight:700;cursor:pointer;transition:.2s;box-shadow:0 4px 14px rgba(244,132,95,.4)}
  .btn-submit:hover{transform:translateY(-2px)}
  .btn-cancel{background:var(--gray-100);color:var(--gray-700);border:none;border-radius:10px;padding:14px 22px;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;text-align:center;transition:.2s}
  .btn-cancel:hover{background:var(--gray-200)}
</style>

<div class="page-wrap">
  <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="back-link">← Retour à la formation</a>

  <div class="card">
    <div class="card-header">
      <small>📚 {{ formation.title }}</small>
      <div class="card-title">📝 {{ quiz.title }}</div>
    </div>
    <div class="card-body">
      <div class="progress-text" id="progressText">0 / {{ quiz.questions|length }} répondues</div>
      <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

      <form method="post" action="{{ path('app_quiz_submit', {'id': formation.id}) }}" id="quizForm">
        {% for question in quiz.questions %}
          <div class="question-block" id="qblock_{{ question.id }}">
            <div class="q-number">Question {{ loop.index }} — {{ question.points }} pt{{ question.points > 1 ? 's' : '' }}</div>
            <div class="q-text">{{ question.questionText }}</div>

            {% for reponse in question.reponses %}
              <label class="option-label" id="opt_{{ reponse.id }}">
                <input type="radio"
                       name="question_{{ question.id }}"
                       value="{{ reponse.id }}"
                       onchange="markAnswered({{ question.id }}, {{ reponse.id }})">
                {{ reponse.optionText }}
              </label>
            {% endfor %}
          </div>
        {% endfor %}

        <div class="form-actions">
          <a href="{{ path('app_formation_show', {'id': formation.id}) }}" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn-submit" id="submitBtn">📩 Soumettre le Quiz</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const totalQuestions = {{ quiz.questions|length }};
let answered = new Set();

function markAnswered(qId, rId) {
  answered.add(qId);
  // Highlight the question block
  const block = document.getElementById('qblock_' + qId);
  if (block) block.classList.add('answered');

  // Highlight selected option
  block.querySelectorAll('.option-label').forEach(l => l.classList.remove('selected'));
  document.getElementById('opt_' + rId).classList.add('selected');

  // Update progress
  const pct = Math.round((answered.size / totalQuestions) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressText').textContent = answered.size + ' / ' + totalQuestions + ' répondues';
}

document.getElementById('quizForm').addEventListener('submit', function(e) {
  if (answered.size < totalQuestions) {
    e.preventDefault();
    alert('Veuillez répondre à toutes les questions avant de soumettre.');
  }
});
</script>
{% endblock %}
