{% extends 'base.html.twig' %}
{% block title %}Aperçu Quiz — {{ formation.title }} | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--blue-dark:#0f2a4a;--blue-light:#2d7dd2;--blue-pale:#e8f2ff;--orange:#f4845f;--orange-soft:#fff3ef;--white:#fff;--gray-100:#f7f9fc;--gray-200:#eef2f7;--gray-400:#94a3b8;--gray-700:#374151;--radius:14px;--shadow-sm:0 2px 8px rgba(15,42,74,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--gray-100);color:var(--gray-700);padding:40px 20px}
  .page-wrap{max-width:760px;margin:0 auto}
  .back-link{display:inline-flex;align-items:center;gap:6px;color:var(--blue-light);font-size:14px;font-weight:600;text-decoration:none;margin-bottom:24px}
  .card{background:#fff;border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:24px}
  .card-header{background:linear-gradient(135deg,var(--blue-dark),#1a4a7a);padding:24px 30px}
  .card-header small{color:rgba(255,255,255,.6);font-size:13px}
  .card-title{font-size:22px;font-weight:800;color:#fff;margin-top:4px}
  .card-body{padding:30px}
  .info-row{display:flex;gap:20px;margin-bottom:24px;flex-wrap:wrap}
  .info-pill{background:var(--blue-pale);color:var(--blue-light);border-radius:10px;padding:10px 16px;font-size:13px;font-weight:600}
  .question-card{background:var(--gray-100);border-radius:12px;padding:20px;margin-bottom:16px}
  .q-title{font-size:15px;font-weight:700;color:var(--blue-dark);margin-bottom:12px}
  .q-points{font-size:12px;color:var(--gray-400);font-weight:600;margin-left:8px}
  .answer-item{display:flex;align-items:center;gap:10px;padding:8px 14px;border-radius:8px;margin-bottom:6px;font-size:14px}
  .answer-correct{background:#e8f8f0;color:#27ae60;font-weight:600}
  .answer-wrong{background:#fff;color:var(--gray-700)}
  .dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .dot-green{background:#27ae60}
  .dot-gray{background:var(--gray-400)}
  .actions-row{display:flex;gap:10px;flex-wrap:wrap}
  .btn{border:none;border-radius:10px;padding:11px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;transition:.2s;display:inline-flex;align-items:center;gap:6px}
  .btn-primary{background:var(--orange);color:#fff}.btn-primary:hover{background:#e06d47}
  .btn-secondary{background:var(--gray-100);color:var(--gray-700)}.btn-secondary:hover{background:var(--gray-200)}
</style>

<div class="page-wrap">
  <a href="{{ path('app_formation_quiz', {'id': formation.id}) }}" class="back-link">← Retour</a>

  <div class="card">
    <div class="card-header">
      <small>📚 {{ formation.title }}</small>
      <div class="card-title">👁️ Aperçu : {{ quiz.title }}</div>
    </div>
    <div class="card-body">
      <div class="info-row">
        <div class="info-pill">📝 {{ quiz.questions|length }} question{{ quiz.questions|length > 1 ? 's' : '' }}</div>
        <div class="info-pill">🎯 Score de passage : {{ quiz.passingScore }}%</div>
        {% set totalPts = 0 %}
        {% for q in quiz.questions %}{% set totalPts = totalPts + q.points %}{% endfor %}
        <div class="info-pill">⭐ Total : {{ totalPts }} point{{ totalPts > 1 ? 's' : '' }}</div>
      </div>

      {% for question in quiz.questions %}
        <div class="question-card">
          <div class="q-title">
            {{ loop.index }}. {{ question.questionText }}
            <span class="q-points">({{ question.points }} pt{{ question.points > 1 ? 's' : '' }})</span>
          </div>
          {% for reponse in question.reponses %}
            <div class="answer-item {{ reponse.isCorrect ? 'answer-correct' : 'answer-wrong' }}">
              <span class="dot {{ reponse.isCorrect ? 'dot-green' : 'dot-gray' }}"></span>
              {{ reponse.optionText }}
              {% if reponse.isCorrect %} ✓{% endif %}
            </div>
          {% endfor %}
        </div>
      {% endfor %}

      <div class="actions-row">
        <a href="{{ path('app_quiz_edit', {'id': formation.id}) }}" class="btn btn-primary">✏️ Modifier</a>
        <a href="{{ path('app_formation_quiz', {'id': formation.id}) }}" class="btn btn-secondary">← Gestion Quiz</a>
      </div>
    </div>
  </div>
</div>
{% endblock %}
