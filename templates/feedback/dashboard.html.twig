{% extends 'base.html.twig' %}
{% block title %}Sentiment Dashboard | EchoCare{% endblock %}
{% block body %}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{--navy:#0a1628;--accent:#e8734a;--cyan:#38bdf8;--emerald:#34d399;--rose:#fb7185;--amber:#fbbf24;--surface:#f8fafc;--surface-card:#fff;--border:#e2e8f0;--border-light:#f1f5f9;--text-primary:#0f172a;--text-secondary:#64748b;--text-muted:#94a3b8;--radius:16px;--radius-sm:10px;--shadow-sm:0 1px 3px rgba(10,22,40,.06);--shadow-md:0 4px 16px rgba(10,22,40,.08)}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--text-primary)}
  .container{max-width:1000px;margin:0 auto;padding:40px 24px}
  .page-title{font-family:'Outfit',sans-serif;font-size:28px;font-weight:800;margin-bottom:8px}
  .page-title span{color:var(--cyan)}
  .page-sub{font-size:13px;color:var(--text-muted);margin-bottom:32px}

  .overview-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:36px}
  .ov-card{background:var(--surface-card);border-radius:var(--radius);padding:22px;text-align:center;box-shadow:var(--shadow-sm);border:1px solid var(--border-light)}
  .ov-val{font-family:'Outfit',sans-serif;font-size:32px;font-weight:800}
  .ov-lbl{font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-top:4px;font-weight:600}
  .ov-green .ov-val{color:var(--emerald)}.ov-red .ov-val{color:var(--rose)}.ov-amber .ov-val{color:var(--amber)}.ov-blue .ov-val{color:var(--cyan)}

  .formation-block{background:var(--surface-card);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:20px;border:1px solid var(--border-light)}
  .fb-header{background:var(--navy);color:#fff;padding:18px 24px;display:flex;align-items:center;justify-content:space-between}
  .fb-title{font-family:'Outfit',sans-serif;font-size:17px;font-weight:700}
  .fb-pills{display:flex;gap:8px}
  .pill{border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700}
  .pill-green{background:rgba(52,211,153,.15);color:var(--emerald)}
  .pill-red{background:rgba(251,113,133,.15);color:var(--rose)}
  .pill-amber{background:rgba(251,191,36,.15);color:var(--amber)}
  .fb-body{padding:20px 24px}
  .fb-item{padding:14px 0;border-bottom:1px solid var(--border-light);display:flex;gap:14px;align-items:flex-start}
  .fb-item:last-child{border-bottom:none}
  .sent-badge{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
  .sent-positive{background:rgba(52,211,153,.1)}
  .sent-negative{background:rgba(251,113,133,.1)}
  .sent-neutral{background:rgba(251,191,36,.1)}
  .fb-comment{font-size:14px;color:var(--text-primary);line-height:1.6;margin-bottom:4px}
  .fb-meta{font-size:12px;color:var(--text-muted);display:flex;gap:12px}
  .fb-stars{color:var(--amber)}
  .confidence-bar{width:60px;height:6px;border-radius:3px;background:var(--border-light);overflow:hidden;display:inline-block;vertical-align:middle;margin-left:4px}
  .confidence-fill{height:100%;border-radius:3px;background:var(--cyan)}
  .empty-fb{text-align:center;padding:36px;color:var(--text-muted)}
</style>

<div class="container">
  <div class="page-title">📊 Tableau de Bord <span>Sentiments</span></div>
  <div class="page-sub">Analyse IA des feedbacks patients sur vos formations</div>

  <div class="overview-grid">
    <div class="ov-card ov-blue"><div class="ov-val">{{ totalFeedbacks }}</div><div class="ov-lbl">Total Avis</div></div>
    <div class="ov-card ov-green"><div class="ov-val">{{ totalPositive }}</div><div class="ov-lbl">😊 Positifs</div></div>
    <div class="ov-card ov-red"><div class="ov-val">{{ totalNegative }}</div><div class="ov-lbl">😞 Négatifs</div></div>
    <div class="ov-card ov-amber"><div class="ov-val">{{ totalNeutral }}</div><div class="ov-lbl">😐 Neutres</div></div>
  </div>

  {% for item in dashboardData %}
  <div class="formation-block">
    <div class="fb-header">
      <div class="fb-title">{{ item.formation.title }}</div>
      <div class="fb-pills">
        <span class="pill pill-green">😊 {{ item.positive }}</span>
        <span class="pill pill-red">😞 {{ item.negative }}</span>
        <span class="pill pill-amber">😐 {{ item.neutral }}</span>
      </div>
    </div>
    <div class="fb-body">
      {% if item.feedbacks|length > 0 %}
        {% for fb in item.feedbacks %}
        <div class="fb-item">
          <div class="sent-badge sent-{{ fb.sentiment ?? 'neutral' }}">
            {% if fb.sentiment == 'positive' %}😊{% elseif fb.sentiment == 'negative' %}😞{% else %}😐{% endif %}
          </div>
          <div style="flex:1">
            <div class="fb-comment">{{ fb.comment }}</div>
            <div class="fb-meta">
              {% if fb.rating %}<span class="fb-stars">{% for i in 1..fb.rating %}⭐{% endfor %}</span>{% endif %}
              <span>{{ fb.createdAt|date('d/m/Y H:i') }}</span>
              {% if fb.confidence %}
                <span>Confiance : {{ (fb.confidence * 100)|round }}%
                  <span class="confidence-bar"><span class="confidence-fill" style="width:{{ fb.confidence * 100 }}%"></span></span>
                </span>
              {% endif %}
              {% if fb.aiSummary %}<span style="font-style:italic">« {{ fb.aiSummary }} »</span>{% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      {% else %}
        <div class="empty-fb">Aucun avis pour cette formation</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}

  {% if dashboardData|length == 0 %}
    <div style="text-align:center;padding:60px;background:#fff;border-radius:var(--radius);color:var(--text-muted)">
      <div style="font-size:48px;margin-bottom:16px">📭</div>
      <p>Aucune formation trouvée. Créez des formations pour voir les feedbacks.</p>
    </div>
  {% endif %}
</div>
{% endblock %}