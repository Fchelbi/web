{% extends 'base.html.twig' %}

{% block title %}{% if 'admin' in app.request.attributes.get('_route') %}Admin Dashboard{% else %}Community{% endif %}{% endblock %}

{% block body %}
<style>
    html, body {
        background-color: #0d1321 !important;
        background: radial-gradient(circle at 50% 20%, #152238 0%, #0d1321 80%, #080c16 100%) fixed !important;
        min-height: 100vh;
        height: auto;
    }
</style>
<div class="layout-wrapper">
    <!-- Main Content -->
    <main class="main-content" style="padding-top:0;">
        <div class="content-container">
            {% block topbar %}
            <nav class="navbar glassmorphism" style="border-radius: 0 0 16px 16px; border-top:none; margin-top:0;">
                <div class="navbar-logo">Echo<span>Care</span></div>
                
                <div class="top-bar-search">
                    <div class="search-container glassmorphism" style="border-radius:30px;padding: 0.2rem; background: rgba(255,255,255,0.03);">
                        <form method="get" action="{{ path('app_post_index') }}">
                            <div class="search-wrapper" style="margin:0;">
                                <i data-lucide="search" class="search-icon" style="color:var(--text-subtle);"></i>
                                <input type="search" name="q" placeholder="Search community..." class="search-input" value="{{ app.request.query.get('q')|default('') }}" style="border:none;background:transparent;width:100%;padding-left:2.8rem;border-radius:30px; font-size:0.85rem;">
                            </div>
                        </form>
                    </div>
                </div>

                <div class="navbar-links">
                    <a href="{{ path('patient_dashboard') }}" class="{% if 'patient_dashboard' in app.request.attributes.get('_route') %}active{% endif %}">Accueil</a>
                    <a href="{{ path('patient_bien_etre') }}" class="{% if 'bien_etre' in app.request.attributes.get('_route') %}active{% endif %}">Bien-etre</a>
                    
                    <div class="nav-dropdown">
                        <a href="{{ path('app_post_index') }}" class="nav-dropbtn {% if 'post' in app.request.attributes.get('_route') or 'category' in app.request.attributes.get('_route') %}active{% endif %}" style="display:flex; align-items:center; gap:4px;">
                            Forum <i data-lucide="chevron-down" style="width:14px;height:14px;"></i>
                        </a>
                        <div class="dropdown-menu glassmorphism">
                            <a href="{{ path('app_post_index') }}">
                                <i data-lucide="newspaper"></i> Forum Feed
                            </a>
                            <a href="{{ path('app_post_new') }}">
                                <i data-lucide="plus-circle"></i> Create Post
                            </a>
                            <a href="{{ path('app_category_index') }}">
                                <i data-lucide="tag"></i> Categories
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="dropdown-divider"></div>
                                <a href="{{ path('app_admin_dashboard') }}">
                                    <i data-lucide="bar-chart-3"></i> Admin Dashboard
                                </a>
                                <a href="{{ path('app_admin_moderation') }}">
                                    <i data-lucide="shield-check"></i> Moderation
                                </a>
                            {% endif %}
                        </div>
                    </div>

                    <a href="{{ path('patient_profile') }}" class="{% if 'profile' in app.request.attributes.get('_route') %}active{% endif %}">Mon profil</a>
                </div>

                <div class="navbar-right">
                    <div class="user-pill-nav">
                        <div class="avatar">{{ app.user.prenom|slice(0,1)|upper }}</div>
                        <span>{{ app.user.prenom }}</span>
                    </div>
                    <a href="{{ path('app_logout') }}" class="btn-logout-nav" title="Deconnexion">
                        <i data-lucide="log-out" style="width:16px;height:16px;"></i>
                    </a>
                </div>
            </nav>
            {% endblock %}

            {% for label, messages in app.flashes %}
                <div class="flash-messages">
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">
                            {{ message }}
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}

            {% block content %}{% endblock %}
        </div>
    </main>
</div>

<!-- ================================================================
     AI IMAGE STUDIO — Floating Widget
     ================================================================ -->
<div class="aicb-widget">

    <!-- Trigger bubble -->
    <button id="aicb-trigger" class="aicb-trigger" onclick="toggleAIChatbot()" aria-label="Open AI Post Assistant">
        <span class="aicb-trigger-icon">✦</span>
    </button>

    <!-- Panel -->
    <div id="aicb-panel" class="aicb-panel" style="display:none;" role="dialog" aria-label="AI Post Assistant">

        <!-- Header -->
        <div class="aicb-header">
            <div class="aicb-header-left">
                <div class="aicb-header-orb">✦</div>
                <div>
                    <div class="aicb-title">AI Post Assistant</div>
                    <div class="aicb-subtitle">
                        <span class="aicb-status-dot"></span>
                        Powered by Gemini API
                    </div>
                </div>
            </div>
            <button class="aicb-close" onclick="toggleAIChatbot()" aria-label="Close">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                </svg>
            </button>
        </div>

        <!-- ── FORM STATE ── -->
        <div id="aicb-form" class="aicb-body" style="display:flex; flex-direction:column;">

            <!-- Prompt input -->
            <div class="aicb-field">
                <label class="aicb-label" for="aicb-prompt">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                    </svg>
                    What do you want to post about?
                </label>
                <textarea id="aicb-prompt" class="aicb-textarea" rows="4"
                    placeholder="e.g. Write a helpful post about managing daily stress..."></textarea>
            </div>

            <!-- Generate button -->
            <button class="aicb-btn-generate" onclick="generateAICBPost()">
                <span>Generate Post</span>
                <svg class="aicb-btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 3l14 9-14 9V3z"/>
                </svg>
            </button>
        </div>

        <!-- ── LOADING STATE ── -->
        <div id="aicb-loading" class="aicb-body aicb-body-center" style="display:none; flex-direction:column;">
            <div class="aicb-spinner">
                <div class="aicb-ring aicb-ring-1"></div>
                <div class="aicb-ring aicb-ring-2"></div>
                <div class="aicb-ring aicb-ring-3"></div>
                <div class="aicb-core"></div>
            </div>
            <p class="aicb-loading-title">Drafting your post…</p>
            <div class="aicb-progress">
                <div class="aicb-progress-bar"></div>
            </div>
            <p class="aicb-loading-hint">This usually takes just a few seconds</p>
        </div>

        <!-- ── RESULT STATE (Used for Errors now) ── -->
        <div id="aicb-result" class="aicb-result-wrap" style="display:none; flex-direction:column; padding: 20px; text-align: center;">
            <p id="aicb-error-text" style="color: var(--danger); font-size: 0.9rem; margin-bottom: 20px;"></p>
            <div class="aicb-result-actions">
                <button class="aicb-btn-back" onclick="resetAICBForm()" style="width: 100%; justify-content: center;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M19 12H5M12 5l-7 7 7 7"/>
                    </svg>
                    Go Back
                </button>
            </div>
        </div>

    </div><!-- /panel -->
</div><!-- /aicb-widget -->

<style>
    .layout-wrapper {
        display: flex;
        min-height: 100vh;
        width: 100%;
        gap: 0;
    }

    .sidebar {
        width: 270px;
        height: 100vh;
        background: var(--card-bg);
        border-right: 1px solid var(--border-color);
        border-radius: 0;
        overflow-y: auto;
        position: sticky;
        top: 0;
        display: flex;
        flex-direction: column;
        box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
        z-index: 10;
    }

    .sidebar-header {
        padding: 1.8rem 1.5rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
    }

    .sidebar-logo {
        color: var(--primary-color);
        margin: 0;
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: -0.3px;
    }

    .sidebar-subtitle {
        color: var(--text-subtle);
        margin: 0.3rem 0 0 0;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .sidebar-search {
        padding: 1rem 1rem;
    }

    .search-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-icon {
        position: absolute;
        left: 0.8rem;
        width: 16px;
        height: 16px;
        color: var(--text-subtle);
        pointer-events: none;
    }

    .search-wrapper .search-input {
        padding-left: 2.4rem;
    }

    .sidebar-nav {
        flex: 1;
        padding: 0.5rem 0;
        overflow-y: auto;
    }

    .nav-section {
        margin-bottom: 0.5rem;
    }

    .nav-section-title {
        color: var(--text-subtle);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 1.2rem 0 0.6rem 0;
        padding: 0 1.2rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .nav-section-divider {
        margin-top: 1.5rem;
        padding-top: 1.2rem;
        border-top: 1px solid var(--border-color);
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.8rem 1.25rem;
        margin: 0.2rem 0.75rem;
        color: var(--text-muted);
        text-decoration: none;
        border-radius: var(--radius-md);
        transition: all var(--transition-normal);
        font-size: 0.9rem;
        font-weight: 500;
        position: relative;
        border-left: 3px solid transparent;
    }

    .nav-item:hover {
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-main);
        transform: translateX(4px);
    }

    .nav-item.active {
        background: linear-gradient(135deg, var(--primary-glow), transparent);
        color: var(--primary-color);
        font-weight: 700;
        border-left-color: var(--primary-color);
        box-shadow: var(--shadow-sm);
    }

    .nav-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.6rem;
    }

    .nav-icon i,
    .nav-icon svg {
        width: 18px;
        height: 18px;
    }

    .nav-label {
        flex: 1;
    }

    .sidebar-footer {
        margin-top: auto;
        border-top: 1px solid var(--border-color);
    }

    .sidebar-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.2rem;
    }

    .sidebar-user-info {
        flex: 1;
        min-width: 0;
    }

    .sidebar-user-name {
        margin: 0;
        color: var(--text-main);
        font-weight: 700;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sidebar-user-role {
        margin: 0.2rem 0 0 0;
        color: var(--text-subtle);
        font-size: 0.75rem;
        font-weight: 500;
    }

    .main-content {
        flex: 1 1 0%;
        min-width: 0;
        min-height: 100vh;
        padding: 1.25rem 1.75rem;
        overflow-x: hidden;
        overflow-y: auto;
        background: radial-gradient(circle at 50% 20%, #152238 0%, #0d1321 80%, #080c16 100%);
        background-color: #0d1321;
        background-attachment: fixed;
        animation: pageTransition 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
        opacity: 0;
    }

    .content-container {
        max-width: 1150px;
        margin: 0 auto;
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    /* Scrollbar styling */
    .top-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 1rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(8px);
        background: linear-gradient(to bottom, var(--bg-color), transparent);
        padding-top: 1rem;
    }

    .flash-messages {
        margin: 1rem 0 0;
    }

    .alert {
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        border-radius: 0.85rem;
        font-weight: 600;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.05);
    }

    .alert-success {
        background: rgba(94, 179, 131, 0.12);
        color: var(--success-text, #166534);
        border: 1px solid rgba(94, 179, 131, 0.2);
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.12);
        color: var(--danger-text, #991b1b);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .alert-info {
        background: rgba(59, 130, 246, 0.12);
        color: var(--text-main);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .search-container {
        width: 100%;
        max-width: 600px;
        transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .search-container:focus-within {
        transform: scale(1.02);
        box-shadow: 0 0 0 2px var(--primary-color), var(--shadow-glow);
    }

    .search-input:focus {
        box-shadow: none !important;
    }

    .sidebar::-webkit-scrollbar,
    .main-content::-webkit-scrollbar {
        width: 4px;
    }

    .sidebar::-webkit-scrollbar-track,
    .main-content::-webkit-scrollbar-track {
        background: transparent;
    }

    .sidebar::-webkit-scrollbar-thumb,
    .main-content::-webkit-scrollbar-thumb {
        background: rgba(232, 117, 154, 0.2);
        border-radius: 2px;
    }

    .sidebar::-webkit-scrollbar-thumb:hover,
    .main-content::-webkit-scrollbar-thumb:hover {
        background: rgba(232, 117, 154, 0.4);
    }

    /* ─── ANIMATIONS & TRANSITIONS ─── */
    @keyframes pageTransition {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes diagonalSlide {
        0% { transform: translate(-100%, 100%) rotate(-45deg); opacity: 0; }
        50% { opacity: 0.6; }
        100% { transform: translate(100%, -100%) rotate(-45deg); opacity: 0; }
    }

    .page-transition-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .transition-shape {
        position: absolute;
        width: 150vmax;
        height: 150vmax;
        background: linear-gradient(135deg, var(--primary-color), var(--accent));
        opacity: 0;
        animation: diagonalSlide 0.5s cubic-bezier(0.77, 0, 0.175, 1) forwards;
    }

    /* Ensure visibility if JS fails or for initial load */
    .main-content {
        opacity: 0;
        animation: pageTransition 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
    }

    /* ─── RESPONSIVE DESIGN ─── */
    .mobile-menu-toggle {
        display: none;
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 1000;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: var(--shadow-sm);
    }

    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        z-index: 99;
        opacity: 0;
        transition: opacity var(--transition-normal);
    }

    @media (max-width: 1024px) {
        .mobile-menu-toggle {
            display: flex;
        }

        .layout-wrapper {
            position: relative;
        }

        .sidebar {
            position: fixed;
            left: -280px;
            top: 0;
            bottom: 0;
            z-index: 100;
            transition: left var(--transition-spring);
            width: 280px;
        }

        .sidebar.active {
            left: 0;
        }

        .sidebar-overlay.active {
            display: block;
            opacity: 1;
        }

        .main-content {
            padding-top: 4.5rem; /* Space for the toggle button */
        }
        
        .top-bar {
            padding-top: 0;
            margin-top: -0.5rem;
        }
    }

    @media (max-width: 768px) {
        .main-content {
            padding: 4.5rem 1rem 1rem 1rem;
        }
        
        .moderation-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
        
        .moderation-item > div:last-child {
            align-self: flex-end;
        }
    }

    .logout-btn:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444 !important;
        transform: scale(1.1);
    }

    /* Dropdown Styles */
    .nav-dropdown {
        position: relative;
        display: inline-block;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        min-width: 220px;
        background: rgba(22, 34, 50, 0.95);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 0.8rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        z-index: 1000;
        margin-top: 10px;
    }

    .nav-dropdown:hover .dropdown-menu {
        display: block;
        animation: slideInDown 0.2s ease forwards;
    }

    .dropdown-menu a {
        display: flex !important;
        align-items: center;
        gap: 12px;
        padding: 0.8rem 1rem !important;
        color: var(--text-subtle) !important;
        text-decoration: none;
        font-size: 0.9rem !important;
        border-radius: 10px;
        transition: all 0.2s;
    }

    .dropdown-menu a:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white !important;
        transform: translateX(5px);
    }

    .dropdown-menu a i {
        width: 16px;
        height: 16px;
        color: var(--primary-color);
    }

    .dropdown-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.05);
        margin: 0.6rem 0.5rem;
    }

    @keyframes slideInDown {
        from { opacity: 0; transform: translate(-50%, -10px); }
        to { opacity: 1; transform: translate(-50%, 0); }
    }

    /* Main Content Full Width */
    .main-content {
        padding: 0 2rem 2rem !important;
    }

    .content-container {
        max-width: 1200px !important;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Simple helper to handle page transitions on link clicks
        document.querySelectorAll('a').forEach(link => {
            if (link.hostname === window.location.hostname && !link.hash && !link.target) {
                link.addEventListener('click', (e) => {
                    const overlay = document.querySelector('.page-transition-overlay');
                    const shape = document.querySelector('.transition-shape');
                    if (overlay && shape) {
                        e.preventDefault();
                        shape.style.animation = 'none';
                        void shape.offsetWidth; // trigger reflow
                        shape.style.animation = 'diagonalSlide 0.5s cubic-bezier(0.77, 0, 0.175, 1) forwards';

                        setTimeout(() => {
                            window.location.href = link.href;
                        }, 250);
                    }
                });
            }
        });

        // Mobile Menu Toggle Logic
        const mobileMenuToggle = document.getElementById('mobileMenuToggle');
        const sidebar = document.querySelector('.sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        if (mobileMenuToggle && sidebar && sidebarOverlay) {
            function toggleMenu() {
                sidebar.classList.toggle('active');
                sidebarOverlay.classList.toggle('active');
            }

            mobileMenuToggle.addEventListener('click', toggleMenu);
            sidebarOverlay.addEventListener('click', toggleMenu);
        }
    });
</script>

<script src="/js/ai-chatbot.js?v=8" defer></script>
{% endblock %}
