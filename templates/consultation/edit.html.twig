<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gérer Consultation · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0D1B2A; min-height: 100vh; color: white; }
        .navbar {
            background: #162232; padding: 0 40px; height: 70px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: white; }
        .navbar-logo span { color: #E8895A; }
        .navbar-right { display: flex; align-items: center; gap: 16px; }
        .user-name { font-size: 14px; color: #8899AA; }
        .btn-logout {
            padding: 8px 18px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border-radius: 8px; text-decoration: none; font-size: 13px;
            font-weight: 600; border: 1px solid rgba(231,76,60,0.2); transition: all 0.2s;
        }
        .btn-logout:hover { background: rgba(231,76,60,0.3); }
        .content { padding: 40px; max-width: 900px; margin: 0 auto; }
        .form-header { margin-bottom: 32px; }
        .form-header h2 { font-size: 26px; font-weight: 700; color: white; margin-bottom: 8px; }
        .form-header p { font-size: 14px; color: #8899AA; }

        .form-card {
            background: #162232; border-radius: 14px; border: 1px solid rgba(255,255,255,0.05);
            padding: 32px;
        }

        .info-section {
            display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px;
        }
        .info-box {
            background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);
            border-radius: 8px; padding: 14px 16px;
        }
        .info-label { font-size: 11px; color: #8899AA; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
        .info-value { font-size: 14px; font-weight: 600; color: white; }

        .form-divider {
            height: 1px; background: rgba(255,255,255,0.05); margin: 28px 0;
        }

        .form-group {
            margin-bottom: 24px;
        }
        .form-group:last-of-type {
            margin-bottom: 0;
        }
        .form-group label {
            display: block; font-size: 13px; color: #CBD5E0; font-weight: 600;
            margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;
        }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%; padding: 12px 14px; background: #0D1B2A;
            border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
            color: white; font-size: 13px; font-family: 'Segoe UI', sans-serif;
            transition: all 0.2s;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none; border-color: rgba(232,137,90,0.5);
            box-shadow: 0 0 8px rgba(232,137,90,0.1);
            background: #162232;
        }
        .form-text { font-size: 12px; color: #8899AA; margin-top: 6px; }

        .alert {
            padding: 14px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 13px;
        }
        .alert-danger {
            background: rgba(244,67,54,0.15); border: 1px solid rgba(244,67,54,0.3); color: #F44336;
        }
        .alert-info {
            background: rgba(74,111,165,0.15); border: 1px solid rgba(74,111,165,0.3); color: #4A6FA5;
        }

        .btn {
            padding: 11px 20px; border-radius: 8px; font-size: 13px; font-weight: 600;
            text-decoration: none; border: 1px solid transparent; cursor: pointer;
            transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-primary {
            background: #4A6FA5; color: white;
        }
        .btn-primary:hover {
            background: #3A5585; box-shadow: 0 4px 12px rgba(74,111,165,0.3);
        }
        .btn-secondary {
            background: rgba(232,137,90,0.15); color: #E8895A; border: 1px solid rgba(232,137,90,0.3);
        }
        .btn-secondary:hover {
            background: rgba(232,137,90,0.25);
        }

        .form-actions {
            display: flex; gap: 12px; margin-top: 28px; align-items: center;
        }

        @media (max-width: 768px) {
            .info-section { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span> · Consultation</div>
    <div class="navbar-right">
        <span class="user-name">👋 {{ app.user.prenom }} {{ app.user.nom }}</span>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪 Déconnexion</a>
    </div>
</nav>

<div class="content">
    <div class="form-header">
        <h2>⚙️ Gérer la Consultation #{{ consultation.id }}</h2>
        <p>Mettez à jour le statut et le lien Meet</p>
    </div>

    <div class="form-card">
        {% if form.vars.submitted and not form.vars.valid %}
            <div class="alert alert-danger">
                <div style="font-weight: 600; margin-bottom: 6px;">Le formulaire contient des erreurs</div>
                {% for error in form.getErrors() %}
                    <div>{{ error.message }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="info-section">
            <div class="info-box">
                <div class="info-label">👤 Patient</div>
                <div class="info-value">{{ consultation.user ? consultation.user.name : 'Non défini' }}</div>
            </div>
            <div class="info-box">
                <div class="info-label">📅 Date de consultation</div>
                <div class="info-value">{{ consultation.dateConsultation|date('d/m/Y H:i') }}</div>
            </div>
        </div>

        <div class="form-divider"></div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_errors(form) }}

            <div class="form-group">
                {{ form_label(form.statut, null, {'label_attr': {'for': 'consultation_statut'}}) }}
                {{ form_widget(form.statut, {'attr': {
                    'id': 'consultation_statut'
                }}) }}
                {% if form.statut.vars.errors|length > 0 %}
                    <div style="color: #F44336; font-size: 12px; margin-top: 6px;">
                        {{ form_errors(form.statut) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.meetLink, null, {'label_attr': {'for': 'consultation_meetLink'}}) }}
                {{ form_widget(form.meetLink, {'attr': {
                    'id': 'consultation_meetLink',
                    'placeholder': 'https://meet.google.com/...'
                }}) }}
                <div class="form-text">Le lien est demandé uniquement pour une consultation confirmée</div>
                {% if form.meetLink.vars.errors|length > 0 %}
                    <div style="color: #F44336; font-size: 12px; margin-top: 6px;">
                        {{ form_errors(form.meetLink) }}
                    </div>
                {% endif %}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">✓ Enregistrer</button>
                <a href="{{ path('psy_consultations') }}" class="btn btn-secondary">← Retour</a>
            </div>

        {{ form_end(form) }}
    </div>
</div>

</body>
</html>
