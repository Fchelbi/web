{% extends 'base.html.twig' %}

{% block title %}Ajouter une consultation{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card page-card">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <div class="text-uppercase small fw-semibold mb-2" style="letter-spacing: 0.08em; color: #4A6FA5;">Prise de rendez-vous</div>
                            <h1 class="h3 mb-1">Demande de consultation</h1>
                            <p class="text-muted mb-0">Choisissez votre psychologue, expliquez votre besoin puis selectionnez une date adaptee.</p>
                        </div>
                        <a href="{{ path('consultation_list') }}" class="btn btn-outline-dark">Retour</a>
                    </div>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        {% if form.vars.submitted and not form.vars.valid %}
                            <div class="alert alert-danger mb-4">
                                <div class="fw-semibold mb-1">Le formulaire contient des erreurs.</div>
                                {{ form_errors(form) }}
                            </div>
                        {% endif %}

                        <div class="mb-3">
                            {{ form_label(form.psychologue, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.psychologue, {'attr': {'class': 'form-select' ~ (form.psychologue.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            {% if form.psychologue.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {{ form_errors(form.psychologue) }}
                                </div>
                            {% endif %}
                            <div class="form-text">
                                <a href="{{ path('psychologue_list') }}">Voir la liste des psychologues</a>
                                {% if psychologueSelectionne %}
                                    <span class="ms-2">Psychologue preselectionne : {{ psychologueSelectionne.nomComplet }}</span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.motif, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.motif, {'attr': {'class': 'form-control' ~ (form.motif.vars.errors|length > 0 ? ' is-invalid' : ''), 'rows': 4}}) }}
                            <div class="form-text">{{ form_help(form.motif) }}</div>
                            <button type="button" id="aiSuggestButton" class="btn btn-outline-primary btn-sm mt-2">
                                💡 Suggérer un psy
                            </button>
                            <div id="aiSuggestion" class="alert alert-info mt-3 d-none"></div>
                            {% if form.motif.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {{ form_errors(form.motif) }}
                                </div>
                            {% endif %}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.dateConsultation, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.dateConsultation, {'attr': {'class': 'form-control' ~ (form.dateConsultation.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                            <div class="form-text">
                                {{ form_help(form.dateConsultation) }}
                                <br>
                                Exemple : 21/05/2026 a 15:00
                            </div>
                            {% if form.dateConsultation.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {{ form_errors(form.dateConsultation) }}
                                </div>
                            {% endif %}
                        </div>

                        <button class="btn btn-primary">Envoyer la demande</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const button = document.getElementById('aiSuggestButton');
            const resultBox = document.getElementById('aiSuggestion');
            const motifField = document.getElementById('{{ form.motif.vars.id }}');

            button.addEventListener('click', async function () {
                const motif = motifField.value.trim();

                resultBox.className = 'alert alert-info mt-3';
                resultBox.textContent = '';

                if (!motif) {
                    resultBox.className = 'alert alert-warning mt-3';
                    resultBox.textContent = 'Veuillez saisir un motif avant de demander une suggestion.';
                    return;
                }

                button.disabled = true;
                button.textContent = 'Analyse en cours...';
                resultBox.textContent = 'Analyse du motif en cours...';

                try {
                    const response = await fetch('{{ path('ai_suggest') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ motif: motif })
                    });

                    const data = await response.json();

                    if (!response.ok || !data.success) {
                        throw new Error(data.message || 'Suggestion indisponible.');
                    }

                    resultBox.className = 'alert alert-success mt-3';
                    resultBox.innerHTML = '<div class="fw-semibold mb-1">Suggestion IA</div>' + data.suggestion;
                } catch (error) {
                    resultBox.className = 'alert alert-danger mt-3';
                    resultBox.textContent = error.message;
                } finally {
                    button.disabled = false;
                    button.textContent = '💡 Suggérer un psy';
                }
            });
        });
    </script>
{% endblock %}
