{% extends 'base.html.twig' %}

{% block title %}Dashboard psychologue{% endblock %}

{% block body %}
    <section class="page-card p-4 p-md-5 mb-4 overflow-hidden" style="background: linear-gradient(135deg, #4A6FA5 0%, #2C4F7C 100%); color: white;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="text-uppercase small fw-semibold mb-2" style="letter-spacing: 0.08em; color: rgba(255,255,255,0.75);">Espace psychologue</div>
                <h1 class="h2 mb-2">Dashboard psychologue</h1>
                <p class="mb-0" style="color: rgba(255,255,255,0.82);">Consultez toutes les demandes et gerez les statuts des rendez-vous en ligne.</p>
            </div>
            <a href="{{ path('consultation_list') }}" class="btn btn-light" style="color: #2C4F7C;">Retour patient</a>
        </div>
    </section>

    <div class="card page-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Patient</th>
                        <th>Psychologue</th>
                        <th>Motif</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Lien</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for consultation in consultations %}
                        <tr>
                            <td>{{ consultation.user ? consultation.user.name : 'Non defini' }}</td>
                            <td>
                                {% if consultation.psychologue %}
                                    <div class="fw-semibold">{{ consultation.psychologue.nomComplet }}</div>
                                    <div class="small text-muted">{{ consultation.psychologue.email }}</div>
                                {% else %}
                                    <span class="text-muted">Non attribue</span>
                                {% endif %}
                            </td>
                            <td>{{ consultation.motif }}</td>
                            <td>{{ consultation.dateConsultation|date('d/m/Y H:i') }}</td>
                            <td>
                                <span class="badge bg-{{ consultation.badgeClass }}">{{ consultation.statutLabel }}</span>
                            </td>
                            <td>
                                {% if consultation.meetLink %}
                                    <a href="{{ consultation.meetLink }}" target="_blank" rel="noopener noreferrer">Ouvrir</a>
                                {% else %}
                                    <span class="text-muted">Aucun lien</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                    {% if consultation.statut == 'en_attente' %}
                                        <form method="post" action="{{ path('psy_accept', {'id': consultation.id}) }}" class="d-inline">
                                            <button class="btn btn-sm btn-success">Accepter</button>
                                        </form>

                                        <form method="post" action="{{ path('psy_cancel', {'id': consultation.id}) }}" class="d-inline">
                                            <button class="btn btn-sm btn-outline-danger">Refuser</button>
                                        </form>
                                    {% endif %}

                                    <a href="{{ path('consultation_edit', {'id': consultation.id}) }}" class="btn btn-sm btn-warning">Gerer</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Aucune consultation trouvee.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
