{% extends 'base.html.twig' %}

{% block title %}Mes consultations{% endblock %}

{% block body %}
    <section class="page-card p-4 p-md-5 mb-4 overflow-hidden" style="background: linear-gradient(135deg, #4A6FA5 0%, #2C4F7C 100%); color: white;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="text-uppercase small fw-semibold mb-2" style="letter-spacing: 0.08em; color: rgba(255,255,255,0.75);">Espace patient</div>
                <h1 class="h2 mb-2">Mes consultations</h1>
                <p class="mb-0" style="color: rgba(255,255,255,0.82);">Retrouvez vos demandes, choisissez un psychologue et suivez l'evolution de vos rendez-vous.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="{{ path('psychologue_list') }}" class="btn btn-light" style="color: #2C4F7C;">Voir les psychologues</a>
                <a href="{{ path('consultation_add') }}" class="btn btn-primary">Nouvelle consultation</a>
                <a href="{{ path('psy_consultations') }}" class="btn btn-outline-light">Espace psychologue</a>
            </div>
        </div>
    </section>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card page-card" style="background: #FFF6D9;">
                <div class="card-body">
                    <div class="text-muted small">En attente</div>
                    <div class="fs-3 fw-bold">{{ countEnAttente }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card page-card" style="background: #DFF5E8;">
                <div class="card-body">
                    <div class="text-muted small">Confirmees</div>
                    <div class="fs-3 fw-bold">{{ countConfirmee }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card page-card" style="background: #FBE1DE;">
                <div class="card-body">
                    <div class="text-muted small">Annulees</div>
                    <div class="fs-3 fw-bold">{{ countAnnulee }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card page-card mb-4">
        <div class="card-body">
            {{ form_start(filterForm, {'attr': {'novalidate': 'novalidate', 'class': 'row g-3 align-items-end'}}) }}
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Filtrer par statut</label>
                    {{ form_widget(filterForm.statut) }}
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-dark">Filtrer</button>
                </div>
                <div class="col-md-auto">
                    <a href="{{ path('consultation_list') }}" class="btn btn-outline-dark">Reinitialiser</a>
                </div>
            {{ form_end(filterForm) }}
        </div>
    </div>

    <div class="card page-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Psychologue</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Lien Meet</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for consultation in consultations %}
                        <tr>
                            <td>
                                {% if consultation.psychologue %}
                                    <div class="fw-semibold">{{ consultation.psychologue.nomComplet }}</div>
                                    <div class="small text-muted">{{ consultation.psychologue.email }}</div>
                                {% else %}
                                    <span class="text-muted">Non choisi</span>
                                {% endif %}
                            </td>
                            <td>{{ consultation.dateConsultation|date('d/m/Y H:i') }}</td>
                            <td>
                                <span class="badge bg-{{ consultation.badgeClass }}">{{ consultation.statutLabel }}</span>
                            </td>
                            <td>
                                {% if consultation.meetLink %}
                                    <a href="{{ consultation.meetLink }}" class="btn btn-sm btn-success" target="_blank" rel="noopener noreferrer">Rejoindre</a>
                                {% else %}
                                    <span class="text-muted">Pas encore disponible</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <form method="post" action="{{ path('consultation_delete', {'id': consultation.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette consultation ?');">
                                    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Aucune consultation trouvee.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-body border-top d-flex justify-content-center">
            {{ knp_pagination_render(pagination, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
        </div>
    </div>
{% endblock %}
