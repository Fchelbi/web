<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau mot de passe · EchoCare</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #F0E6D8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .card {
            background: white;
            border-radius: 20px;
            padding: 50px 40px;
            max-width: 460px;
            width: 100%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }
        .icon { font-size: 50px; text-align: center; margin-bottom: 16px; }
        h2 { color: #2C3E50; font-size: 24px; font-weight: 700; margin-bottom: 6px; text-align: center; }
        .subtitle { color: #999; font-size: 13px; text-align: center; margin-bottom: 28px; }
        .error-box {
            background: #ffe0e0; color: #c0392b;
            padding: 12px; border-radius: 10px;
            font-size: 13px; margin-bottom: 16px; text-align: center;
        }
        .field-label {
            font-size: 11px; font-weight: 700; color: #4A6FA5;
            letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; display: block;
        }
        .password-wrapper { position: relative; margin-bottom: 20px; }
        .password-wrapper input { width: 100%; padding: 13px 44px 13px 16px; border: 1.5px solid #E8E0D5; border-radius: 10px; background: #F5EFE6; font-size: 14px; color: #333; outline: none; }
        .password-wrapper input:focus { border-color: #4A6FA5; background: white; }
        .toggle-pw { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); cursor: pointer; font-size: 16px; }
        .strength-bar { height: 4px; border-radius: 2px; background: #E8E0D5; margin-top: 6px; overflow: hidden; }
        .strength-fill { height: 100%; width: 0%; border-radius: 2px; transition: width 0.3s, background 0.3s; }
        .strength-text { font-size: 11px; color: #999; margin-top: 4px; }
        .btn {
            width: 100%; padding: 14px;
            background: #4A6FA5; color: white; border: none;
            border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer;
        }
        .btn:hover { background: #3a5f95; }
    </style>
</head>
<body>
<div class="card">
    <div class="icon">🔐</div>
    <h2>Nouveau mot de passe</h2>
    <p class="subtitle">Choisissez un mot de passe fort</p>

    {% if error %}
        <div class="error-box">{{ error }}</div>
    {% endif %}

    <form method="post">
        <label class="field-label">Nouveau mot de passe</label>
        <div class="password-wrapper">
            <input type="password" name="password" id="password" placeholder="••••••••" required>
            <span class="toggle-pw" onclick="togglePw('password', this)">👁️</span>
        </div>
        <div class="strength-bar"><div class="strength-fill" id="strength-fill"></div></div>
        <span class="strength-text" id="strength-text"></span>

        <br>
        <label class="field-label">Confirmer mot de passe</label>
        <div class="password-wrapper">
            <input type="password" name="confirm_password" id="confirm" placeholder="••••••••" required>
            <span class="toggle-pw" onclick="togglePw('confirm', this)">👁️</span>
        </div>

        <button type="submit" class="btn" style="margin-top:16px;">✅ Enregistrer</button>
    </form>
</div>
<script>
    function togglePw(id, el) {
        const input = document.getElementById(id);
        input.type = input.type === 'password' ? 'text' : 'password';
        el.textContent = input.type === 'password' ? '👁️' : '🙈';
    }
    document.getElementById('password').addEventListener('input', function () {
        const val = this.value;
        const fill = document.getElementById('strength-fill');
        const text = document.getElementById('strength-text');
        let score = 0;
        if (val.length >= 8) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        const levels = [
            { w: '0%', c: 'transparent', t: '' },
            { w: '25%', c: '#e74c3c', t: '🔴 Très faible' },
            { w: '50%', c: '#e67e22', t: '🟠 Faible' },
            { w: '75%', c: '#f1c40f', t: '🟡 Moyen' },
            { w: '100%', c: '#2ecc71', t: '🟢 Fort' },
        ];
        fill.style.width = levels[score].w;
        fill.style.background = levels[score].c;
        text.textContent = levels[score].t;
    });
</script>
</body>
</html>