<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ patient.prenom }} {{ patient.nom }} · Coach EchoCare</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0D1B2A; min-height: 100vh; color: white; }
        .navbar {
            background: #162232; padding: 0 40px; height: 70px;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky; top: 0; z-index: 100;
        }
        .navbar-logo { font-size: 22px; font-weight: 700; color: white; }
        .navbar-logo span { color: #E8895A; }
        .navbar-right { display: flex; gap: 10px; }
        .btn-back {
            padding: 8px 18px; background: rgba(255,255,255,0.05); color: #8899AA;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(255,255,255,0.05); transition: all 0.2s;
        }
        .btn-back:hover { background: rgba(232,137,90,0.15); color: #E8895A; border-color: rgba(232,137,90,0.3); }
        .btn-logout {
            padding: 8px 18px; background: rgba(231,76,60,0.15); color: #e74c3c;
            border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 600;
            border: 1px solid rgba(231,76,60,0.2); transition: all 0.2s;
        }
        .btn-logout:hover { background: rgba(231,76,60,0.3); }
        .content { padding: 32px 40px; }

        /* HERO */
        .patient-hero {
            background: linear-gradient(135deg, #162232 0%, #1A2B3C 100%);
            border-radius: 20px; padding: 32px; color: white;
            display: flex; align-items: center; gap: 28px;
            margin-bottom: 24px; position: relative; overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
            animation: fadeInUp 0.5s ease;
        }
        .patient-hero::before {
            content: ''; position: absolute; top: -60px; right: -60px;
            width: 250px; height: 250px;
            background: radial-gradient(circle, rgba(232,137,90,0.08) 0%, transparent 70%);
            border-radius: 50%;
        }
        .hero-avatar {
            width: 90px; height: 90px; flex-shrink: 0;
            background: linear-gradient(135deg, #E8895A, #4A6FA5);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 36px; font-weight: 700;
            border: 3px solid rgba(255,255,255,0.1); position: relative; z-index: 1;
        }
        .hero-info { position: relative; z-index: 1; flex: 1; }
        .hero-info h2 { font-size: 26px; font-weight: 700; margin-bottom: 6px; color: white; }
        .hero-info p { font-size: 14px; color: #8899AA; margin-bottom: 12px; }
        .hero-badges { display: flex; gap: 8px; flex-wrap: wrap; }
        .hero-badge {
            padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
            background: rgba(255,255,255,0.08); color: #CBD5E0;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .hero-badge.orange { background: rgba(232,137,90,0.2); color: #E8895A; border-color: rgba(232,137,90,0.3); }

        /* KPI */
        .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
        .kpi-card {
            background: #162232; border-radius: 16px; padding: 22px;
            border: 1px solid rgba(255,255,255,0.05);
            transition: transform 0.3s, box-shadow 0.3s;
            animation: fadeInUp 0.5s ease both; position: relative; overflow: hidden;
        }
        .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.3); }
        .kpi-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; }
        .kpi-card.blue::after { background: #4A6FA5; }
        .kpi-card.orange::after { background: #E8895A; }
        .kpi-card.green::after { background: #27ae60; }
        .kpi-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .kpi-icon-wrap {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 22px;
        }
        .kpi-card.blue .kpi-icon-wrap { background: rgba(74,111,165,0.15); }
        .kpi-card.orange .kpi-icon-wrap { background: rgba(232,137,90,0.15); }
        .kpi-card.green .kpi-icon-wrap { background: rgba(39,174,96,0.15); }
        .kpi-value { font-size: 32px; font-weight: 700; margin-top: 14px; }
        .kpi-card.blue .kpi-value { color: #4A6FA5; }
        .kpi-card.orange .kpi-value { color: #E8895A; }
        .kpi-card.green .kpi-value { color: #27ae60; }
        .kpi-label { font-size: 12px; color: #8899AA; margin-top: 4px; }

        /* PANELS */
        .grid-2 { display: grid; grid-template-columns: 3fr 2fr; gap: 20px; margin-bottom: 24px; }
        .panel {
            background: #162232; border-radius: 16px; padding: 24px;
            border: 1px solid rgba(255,255,255,0.05);
            animation: fadeInUp 0.5s ease both;
        }
        .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .panel-header h3 { font-size: 16px; font-weight: 700; color: white; }
        .date-badge {
            font-size: 12px; color: #E8895A; background: rgba(232,137,90,0.1);
            padding: 4px 10px; border-radius: 8px; font-weight: 600;
            border: 1px solid rgba(232,137,90,0.2);
        }

        /* CALENDAR */
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
        .day-name { text-align: center; font-size: 10px; font-weight: 700; color: #4A5568; padding: 6px 0; text-transform: uppercase; }
        .day-cell {
            aspect-ratio: 1; border-radius: 8px; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: rgba(255,255,255,0.03); color: #4A5568;
            font-size: 10px; font-weight: 700; transition: transform 0.2s;
        }
        .day-cell.empty { background: transparent; }
        .day-cell.has-data { color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.3); transform: scale(1.02); cursor: pointer; }
        .day-cell.has-data:hover { transform: scale(1.08); }
        .day-cell.mood-excellent { background: linear-gradient(135deg, #27ae60, #2ecc71); }
        .day-cell.mood-bien { background: linear-gradient(135deg, #2ecc71, #58d68d); }
        .day-cell.mood-neutre { background: linear-gradient(135deg, #f39c12, #f1c40f); }
        .day-cell.mood-fatigue { background: linear-gradient(135deg, #3498db, #5dade2); }
        .day-cell.mood-triste { background: linear-gradient(135deg, #e74c3c, #ec7063); }
        .day-emoji { font-size: 13px; }
        .day-num { font-size: 9px; margin-top: 1px; }
        .legend { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
        .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: #8899AA; }
        .legend-dot { width: 10px; height: 10px; border-radius: 3px; }

        /* TIMELINE */
        .timeline-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
        .timeline-list { list-style: none; max-height: 320px; overflow-y: auto; padding-right: 4px; }
        .timeline-list::-webkit-scrollbar { width: 4px; }
        .timeline-list::-webkit-scrollbar-track { background: rgba(255,255,255,0.03); border-radius: 2px; }
        .timeline-list::-webkit-scrollbar-thumb { background: #E8895A; border-radius: 2px; }
        .timeline-item {
            display: flex; gap: 14px; padding: 14px; border-radius: 12px;
            margin-bottom: 8px; background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.03); transition: all 0.2s;
        }
        .timeline-item:hover { background: rgba(232,137,90,0.05); border-color: rgba(232,137,90,0.1); }
        .t-emoji { font-size: 24px; flex-shrink: 0; }
        .t-info h4 { font-size: 13px; font-weight: 700; color: white; margin-bottom: 4px; }
        .t-bars { margin-top: 8px; display: flex; flex-direction: column; gap: 4px; }
        .t-bar { display: flex; align-items: center; gap: 6px; }
        .t-bar-label { font-size: 10px; color: #4A5568; width: 50px; }
        .t-bar-track { flex: 1; height: 4px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; }
        .t-bar-fill { height: 100%; border-radius: 2px; }

        /* MOOD SUMMARY */
        .mood-summary { display: flex; flex-direction: column; gap: 8px; }
        .mood-row {
            display: flex; align-items: center; gap: 10px; padding: 8px 12px;
            border-radius: 10px; background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.03); transition: all 0.2s;
        }
        .mood-row:hover { background: rgba(255,255,255,0.05); }
        .mood-emoji { font-size: 20px; }
        .mood-label { flex: 1; font-size: 13px; font-weight: 600; color: white; }
        .mood-count { font-size: 18px; font-weight: 700; padding: 2px 10px; border-radius: 20px; }
        .mood-row.excellent .mood-count { color: #27ae60; background: rgba(39,174,96,0.1); }
        .mood-row.bien .mood-count { color: #2ecc71; background: rgba(46,204,113,0.1); }
        .mood-row.neutre .mood-count { color: #f39c12; background: rgba(243,156,18,0.1); }
        .mood-row.fatigue .mood-count { color: #3498db; background: rgba(52,152,219,0.1); }
        .mood-row.triste .mood-count { color: #e74c3c; background: rgba(231,76,60,0.1); }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }
        .delay-4 { animation-delay: 0.4s; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="navbar-logo">Echo<span>Care</span> · Coach</div>
    <div class="navbar-right">
        <a href="{{ path('coach_dashboard') }}" class="btn-back">← Mes patients</a>
        <a href="{{ path('app_logout') }}" class="btn-logout">🚪</a>
    </div>
</nav>

<div class="content">

    <div class="patient-hero">
        <div class="hero-avatar">{{ patient.prenom|slice(0,1)|upper }}</div>
        <div class="hero-info">
            <h2>{{ patient.prenom }} {{ patient.nom }}</h2>
            <p>📧 {{ patient.email }} &nbsp;&nbsp; 📞 {{ patient.numTel ?? '—' }}</p>
            <div class="hero-badges">
                <span class="hero-badge">✅ Compte verifie</span>
                <span class="hero-badge">🌿 Patient</span>
                <span class="hero-badge orange">📊 {{ totalJours }} evaluation(s)</span>
            </div>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card blue delay-1">
            <div class="kpi-top"><div class="kpi-icon-wrap">📅</div></div>
            <div class="kpi-value">{{ totalJours }}</div>
            <div class="kpi-label">Jours enregistres</div>
        </div>
        <div class="kpi-card blue delay-2">
            <div class="kpi-top"><div class="kpi-icon-wrap">😴</div></div>
            <div class="kpi-value">{{ avgSommeil }}%</div>
            <div class="kpi-label">Sommeil moyen</div>
        </div>
        <div class="kpi-card orange delay-3">
            <div class="kpi-top"><div class="kpi-icon-wrap">🧘</div></div>
            <div class="kpi-value">{{ avgStress }}%</div>
            <div class="kpi-label">Stress moyen</div>
        </div>
        <div class="kpi-card green delay-4">
            <div class="kpi-top"><div class="kpi-icon-wrap">😊</div></div>
            <div class="kpi-value">{{ avgHumeur }}%</div>
            <div class="kpi-label">Humeur moyenne</div>
        </div>
    </div>

    <div class="grid-2">
        <div class="panel delay-1">
            <div class="panel-header">
                <h3>📈 Evolution du bien-etre</h3>
                <span class="date-badge">{{ "now"|date("M Y") }}</span>
            </div>
            {% if data|length > 0 %}
            <canvas id="evolutionChart" height="130"></canvas>
            {% else %}
            <div style="text-align:center;padding:50px;color:#4A5568;">
                <div style="font-size:48px;margin-bottom:12px;">📊</div>
                <p>Aucune donnee disponible</p>
            </div>
            {% endif %}
        </div>

        <div class="panel delay-2">
            <div class="panel-header">
                <h3>🗓️ Calendrier</h3>
                <span class="date-badge">{{ "now"|date("M Y") }}</span>
            </div>
            <div class="calendar-grid">
                <div class="day-name">L</div>
                <div class="day-name">M</div>
                <div class="day-name">M</div>
                <div class="day-name">J</div>
                <div class="day-name">V</div>
                <div class="day-name">S</div>
                <div class="day-name">D</div>
                {% for i in 1..(firstDayOfMonth - 1) %}
                    <div class="day-cell empty"></div>
                {% endfor %}
                {% for day in 1..daysInMonth %}
                    {% set entry = calendarData[day] ?? null %}
                    <div class="day-cell {{ entry ? 'has-data mood-' ~ entry.mood : '' }}">
                        {% if entry %}
                            <span class="day-emoji">
                                {% if entry.mood == 'excellent' %}😄
                                {% elseif entry.mood == 'bien' %}🙂
                                {% elseif entry.mood == 'neutre' %}😐
                                {% elseif entry.mood == 'fatigue' %}😴
                                {% else %}😟{% endif %}
                            </span>
                        {% endif %}
                        <span class="day-num">{{ day }}</span>
                    </div>
                {% endfor %}
            </div>
            <div class="legend">
                <div class="legend-item"><div class="legend-dot" style="background:#27ae60;"></div>Excellent</div>
                <div class="legend-item"><div class="legend-dot" style="background:#f39c12;"></div>Neutre</div>
                <div class="legend-item"><div class="legend-dot" style="background:#3498db;"></div>Fatigue</div>
                <div class="legend-item"><div class="legend-dot" style="background:#e74c3c;"></div>Triste</div>
            </div>
        </div>
    </div>

    <div class="timeline-grid">
        <div class="panel delay-3">
            <div class="panel-header">
                <h3>📋 Historique des evaluations</h3>
            </div>
            {% if data|length > 0 %}
            <ul class="timeline-list">
                {% for entry in data|reverse %}
                <li class="timeline-item">
                    <span class="t-emoji">
                        {% if entry.mood == 'excellent' %}😄
                        {% elseif entry.mood == 'bien' %}🙂
                        {% elseif entry.mood == 'neutre' %}😐
                        {% elseif entry.mood == 'fatigue' %}😴
                        {% else %}😟{% endif %}
                    </span>
                    <div class="t-info">
                        <h4>{{ entry.createdAt|date('d/m/Y') }} — {{ entry.mood ? entry.mood|capitalize : '—' }}</h4>
                        <div class="t-bars">
                            <div class="t-bar">
                                <span class="t-bar-label">😴 Sommeil</span>
                                <div class="t-bar-track"><div class="t-bar-fill" style="width:{{ entry.sommeil }}%;background:#4A6FA5;"></div></div>
                                <span style="font-size:10px;color:#4A6FA5;font-weight:700;">{{ entry.sommeil }}%</span>
                            </div>
                            <div class="t-bar">
                                <span class="t-bar-label">🧘 Stress</span>
                                <div class="t-bar-track"><div class="t-bar-fill" style="width:{{ entry.stress }}%;background:#E8895A;"></div></div>
                                <span style="font-size:10px;color:#E8895A;font-weight:700;">{{ entry.stress }}%</span>
                            </div>
                            <div class="t-bar">
                                <span class="t-bar-label">😊 Humeur</span>
                                <div class="t-bar-track"><div class="t-bar-fill" style="width:{{ entry.humeur }}%;background:#27ae60;"></div></div>
                                <span style="font-size:10px;color:#27ae60;font-weight:700;">{{ entry.humeur }}%</span>
                            </div>
                        </div>
                    </div>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <div style="text-align:center;padding:30px;color:#4A5568;">
                <div style="font-size:40px;margin-bottom:10px;">📋</div>
                <p>Aucune evaluation pour ce patient</p>
            </div>
            {% endif %}
        </div>

        <div class="panel delay-4">
            <div class="panel-header">
                <h3>😊 Repartition humeur</h3>
            </div>
            {% if data|length > 0 %}
            {% set excellent = data|filter(d => d.mood == 'excellent')|length %}
            {% set bien = data|filter(d => d.mood == 'bien')|length %}
            {% set neutre = data|filter(d => d.mood == 'neutre')|length %}
            {% set fatigue = data|filter(d => d.mood == 'fatigue')|length %}
            {% set triste = data|filter(d => d.mood == 'triste')|length %}
            <div style="max-width:180px;margin:0 auto 16px;">
                <canvas id="moodChart"></canvas>
            </div>
            <div class="mood-summary">
                {% if excellent > 0 %}<div class="mood-row excellent"><span class="mood-emoji">😄</span><span class="mood-label">Excellent</span><span class="mood-count">{{ excellent }}</span></div>{% endif %}
                {% if bien > 0 %}<div class="mood-row bien"><span class="mood-emoji">🙂</span><span class="mood-label">Bien</span><span class="mood-count">{{ bien }}</span></div>{% endif %}
                {% if neutre > 0 %}<div class="mood-row neutre"><span class="mood-emoji">😐</span><span class="mood-label">Neutre</span><span class="mood-count">{{ neutre }}</span></div>{% endif %}
                {% if fatigue > 0 %}<div class="mood-row fatigue"><span class="mood-emoji">😴</span><span class="mood-label">Fatigue</span><span class="mood-count">{{ fatigue }}</span></div>{% endif %}
                {% if triste > 0 %}<div class="mood-row triste"><span class="mood-emoji">😟</span><span class="mood-label">Triste</span><span class="mood-count">{{ triste }}</span></div>{% endif %}
            </div>
            {% else %}
            <div style="text-align:center;padding:30px;color:#4A5568;">Aucune donnee</div>
            {% endif %}
        </div>
    </div>

</div>

<script>
Chart.defaults.color = '#8899AA';
Chart.defaults.borderColor = 'rgba(255,255,255,0.05)';

{% if data|length > 0 %}
new Chart(document.getElementById('evolutionChart'), {
    type: '{{ data|length <= 1 ? "bar" : "line" }}',
    data: {
        labels: [{% for d in data %}'{{ d.createdAt|date("d/m") }}'{% if not loop.last %},{% endif %}{% endfor %}],
        datasets: [
            {
                label: 'Sommeil',
                data: [{% for d in data %}{{ d.sommeil }}{% if not loop.last %},{% endif %}{% endfor %}],
                borderColor: '#4A6FA5', backgroundColor: 'rgba(74,111,165,0.1)',
                tension: 0.4, fill: true, pointRadius: 5,
                pointBackgroundColor: '#4A6FA5', pointHoverRadius: 8,
            },
            {
                label: 'Humeur',
                data: [{% for d in data %}{{ d.humeur }}{% if not loop.last %},{% endif %}{% endfor %}],
                borderColor: '#27ae60', backgroundColor: 'rgba(39,174,96,0.1)',
                tension: 0.4, fill: true, pointRadius: 5,
                pointBackgroundColor: '#27ae60', pointHoverRadius: 8,
            },
            {
                label: 'Stress',
                data: [{% for d in data %}{{ d.stress }}{% if not loop.last %},{% endif %}{% endfor %}],
                borderColor: '#E8895A', backgroundColor: 'rgba(232,137,90,0.1)',
                tension: 0.4, fill: true, pointRadius: 5,
                pointBackgroundColor: '#E8895A', pointHoverRadius: 8,
            }
        ]
    },
    options: {
        responsive: true, spanGaps: true,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
            legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, color: '#8899AA' } },
            tooltip: { backgroundColor: '#162232', titleColor: 'white', bodyColor: '#8899AA', borderColor: 'rgba(255,255,255,0.05)', borderWidth: 1 }
        },
        scales: {
            y: { min: 0, max: 100, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#8899AA' } },
            x: { grid: { display: false }, ticks: { color: '#8899AA' } }
        },
        animation: { duration: 1500, easing: 'easeInOutQuart' }
    }
});

new Chart(document.getElementById('moodChart'), {
    type: 'doughnut',
    data: {
        labels: ['Excellent', 'Bien', 'Neutre', 'Fatigue', 'Triste'],
        datasets: [{
            data: [{{ excellent }}, {{ bien }}, {{ neutre }}, {{ fatigue }}, {{ triste }}],
            backgroundColor: ['#27ae60', '#2ecc71', '#f39c12', '#3498db', '#e74c3c'],
            borderWidth: 0, hoverOffset: 8,
        }]
    },
    options: {
        responsive: true, cutout: '65%',
        plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: '#162232', titleColor: 'white', bodyColor: '#8899AA', borderColor: 'rgba(255,255,255,0.05)', borderWidth: 1 }
        },
        animation: { duration: 1500, easing: 'easeInOutQuart' }
    }
});
{% endif %}
</script>
</body>
</html>